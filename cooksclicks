  <div id="gc-lbl">Golden Cookie!</div>
</div>

<script>
// ═══════════════════════════════════════════════════════════
// DATA
// ═══════════════════════════════════════════════════════════
const LEVELS = [
  {level:1,name:"Apprentice Baker",  threshold:0,    emoji:"🍞",bonus:""},
  {level:2,name:"Cookie Journeyman", threshold:1000, emoji:"🥐",bonus:"Click power ×2"},
  {level:3,name:"Pastry Person",    threshold:1e5,  emoji:"🎂",bonus:"All production ×1.5"},
  {level:4,name:"Cookie Collector",      threshold:1e7,  emoji:"👑",bonus:"Click power ×3"},
  {level:5,name:"Cookie God", threshold:1e10, emoji:"🏆",bonus:"All production ×2"},
  {level:6,name:"cookie toucher",      threshold:1e14, emoji:"✦", bonus:"Click power ×10"},
  {level:7,name:"diddy blud",     threshold:1e20, emoji:"🌌",bonus:"Everything ×5"},
];

const BUILDINGS = [
  {id:"cursor",      name:"Cursor",       emoji:"🖱️", baseCost:15,      baseCps:0.1,    desc:"Autoclick",        unlockAt:0},
  {id:"grandma",     name:"Grandma",      emoji:"👵", baseCost:100,     baseCps:0.5,    desc:"Bakes lovingly",   unlockAt:10},
  {id:"farm",        name:"Cookie Farm",  emoji:"🌾", baseCost:1100,    baseCps:4,      desc:"Grows dough",      unlockAt:100},
  {id:"mine",        name:"Sugar Mine",   emoji:"⛏️",  baseCost:12000,   baseCps:10,     desc:"Digs sweetness",   unlockAt:1000},
  {id:"factory",     name:"Factory",      emoji:"🏭", baseCost:130000,  baseCps:40,     desc:"Mass production",  unlockAt:10000},
  {id:"bank",        name:"Cookie Bank",  emoji:"🏦", baseCost:1.4e6,   baseCps:100,    desc:"Compound gains",   unlockAt:1e5},
  {id:"temple",      name:"Temple",       emoji:"🛕", baseCost:2e7,     baseCps:400,    desc:"Divine baking",    unlockAt:1e6},
  {id:"wizard",      name:"Wizard Tower", emoji:"🧙", baseCost:3.3e8,   baseCps:1666,   desc:"Conjure cookies",  unlockAt:1e8},
  {id:"shipment",    name:"Starship",     emoji:"🚀", baseCost:5.1e9,   baseCps:7778,   desc:"Planet imports",   unlockAt:1e10},
  {id:"alchemy",     name:"Alchemy Lab",  emoji:"⚗️",  baseCost:7.5e10,  baseCps:37800,  desc:"Gold to cookies",  unlockAt:1e12},
  {id:"portal",      name:"Cookie Portal",emoji:"🌀", baseCost:1e12,    baseCps:200000, desc:"Multiverse dough", unlockAt:1e14},
  {id:"timemachine", name:"Time Machine", emoji:"⏱️", baseCost:1.4e13,  baseCps:900000, desc:"Past production",  unlockAt:1e16},
];

const UPGRADES = [
  {id:"u1", icon:"🔥",name:"Reinforced Oven",    cost:100,    desc:"Double click power",         apply:s=>{s.cm*=2},                             check:s=>s.tb>=50},
  {id:"u2", icon:"🍫",name:"Chocolate Selection", cost:500,    desc:"Cursors produce 2× more",    apply:s=>{s.bm.cursor=(s.bm.cursor||1)*2},      check:s=>(s.b.cursor||0)>=1},
  {id:"u3", icon:"📖",name:"Grandma's Secret",    cost:1000,   desc:"Grandmas produce 2× more",   apply:s=>{s.bm.grandma=(s.bm.grandma||1)*2},    check:s=>(s.b.grandma||0)>=1},
  {id:"u4", icon:"⚙️", name:"Steel Rolling Pin",  cost:5000,   desc:"Click power ×3",             apply:s=>{s.cm*=3},                             check:s=>s.tb>=2500},
  {id:"u5", icon:"🌱",name:"Bio-Fertilizer",      cost:10000,  desc:"Farms produce 2× more",      apply:s=>{s.bm.farm=(s.bm.farm||1)*2},          check:s=>(s.b.farm||0)>=1},
  {id:"u6", icon:"💎",name:"Sugar Crystals",      cost:50000,  desc:"All buildings +50% output",  apply:s=>{s.gm*=1.5},                           check:s=>s.tb>=25000},
  {id:"u7", icon:"📜",name:"Artisan Recipes",     cost:200000, desc:"All buildings +50% output",  apply:s=>{s.gm*=1.5},                           check:s=>s.lv>=2},
  {id:"u8", icon:"✨",name:"Golden Ovens",        cost:5e5,    desc:"Click power ×5",             apply:s=>{s.cm*=5},                             check:s=>s.lv>=3},
  {id:"u9", icon:"⛏️", name:"Industrial Mining",  cost:2e6,    desc:"Mines produce 3× more",      apply:s=>{s.bm.mine=(s.bm.mine||1)*3},          check:s=>(s.b.mine||0)>=5},
  {id:"u10",icon:"⚛️", name:"Quantum Baking",     cost:5e7,    desc:"All buildings ×3 output",    apply:s=>{s.gm*=3},                             check:s=>s.lv>=4},
  {id:"u11",icon:"🧠",name:"Neural Recipes",      cost:5e8,    desc:"Click power ×10",            apply:s=>{s.cm*=10},                            check:s=>s.lv>=4},
  {id:"u12",icon:"🌌",name:"Singularity",         cost:1e10,   desc:"All buildings ×5 output",    apply:s=>{s.gm*=5},                             check:s=>s.lv>=5},
  {id:"u13",icon:"👑",name:"Cookie Dominion",     cost:1e13,   desc:"Click power ×50",            apply:s=>{s.cm*=50},                            check:s=>s.lv>=6},
  {id:"u14",icon:"♾️", name:"The Eternal Batch",  cost:1e15,   desc:"All buildings ×10 output",   apply:s=>{s.gm*=10},                            check:s=>s.lv>=6},
];

const ACHIEVEMENTS = [
  {id:"a1", ico:"🍪",name:"First Crumb",        sub:"Bake your very first cookie",  check:s=>s.tb>=1},
  {id:"a2", ico:"🔢",name:"Century Baker",       sub:"Bake 100 cookies",             check:s=>s.tb>=100},
  {id:"a3", ico:"📦",name:"Cookie Stockpile",    sub:"Bake 10,000 cookies",          check:s=>s.tb>=10000},
  {id:"a4", ico:"💰",name:"Cookie Millionaire",  sub:"Bake 1,000,000 cookies",       check:s=>s.tb>=1e6},
  {id:"a5", ico:"🏗️",name:"First Hire",          sub:"Buy your first building",      check:s=>Object.values(s.b).some(v=>v>0)},
  {id:"a6", ico:"👵",name:"Indentured Servant",  sub:"Employ 10 grandmas",           check:s=>(s.b.grandma||0)>=10},
  {id:"a7", ico:"🌟",name:"Golden Touch",        sub:"Catch a golden cookie",        check:s=>s.gc>=1},
  {id:"a8", ico:"⬆️",name:"Rising Star",         sub:"Reach Level 2",                check:s=>s.lv>=2},
  {id:"a9", ico:"🏆",name:"Cookie Pro",        sub:"Reach Level 3",                check:s=>s.lv>=3},
  {id:"a10",ico:"💎",name:"Cookie Billionaire",  sub:"Bake 1,000,000,000 cookies",   check:s=>s.tb>=1e9},
];

// ═══════════════════════════════════════════════════════════
// STATE  (short keys to avoid any accidental minification clashes)
// ═══════════════════════════════════════════════════════════
const S = {
  c:0,   // current cookies
  tb:0,  // total baked
  cps:0,
  cm:1,  // click multiplier
  gm:1,  // global CPS multiplier
  bm:{}, // per-building multipliers
  b:{},  // building counts
  bought:new Set(),
  ach:new Set(),
  lv:1,
  gc:0,  // golden cookies caught
  gAct:false,
  gMult:1,
  gRem:0,
};

BUILDINGS.forEach(b=>{S.b[b.id]=0;S.bm[b.id]=1;});

// ═══════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════
function N(n){
  if(!isFinite(n)||n<0)return'0';
  if(n<1000)return Math.floor(n).toLocaleString();
  const W=['','thousand','million','billion','trillion','quadrillion','quintillion',
    'sextillion','septillion','octillion','nonillion','decillion','undecillion','duodecillion'];
  const t=Math.min(Math.floor(Math.log10(n)/3),W.length-1);
  const v=n/Math.pow(1000,t);
  return(v>=100?v.toFixed(1):v>=10?v.toFixed(2):v.toFixed(3)).replace(/\.?0+$/,'')+' '+W[t];
}
function Ns(n){
  if(!isFinite(n)||n<0)return'0';
  if(n<1000)return Math.floor(n).toString();
  const S2=['','K','M','B','T','Qa','Qi','Sx','Sp','Oc','No','Dc','Ud','Dd','Td'];
  const t=Math.min(Math.floor(Math.log10(n)/3),S2.length-1);
  const v=n/Math.pow(1000,t);
  return(v<10?v.toFixed(2):v<100?v.toFixed(1):Math.floor(v))+S2[t];
}
function calcCps(){
  let tot=0;
  for(const b of BUILDINGS)tot+=S.b[b.id]*b.baseCps*(S.bm[b.id]||1);
  return tot*S.gm;
}
function bCost(b){return Math.ceil(b.baseCost*Math.pow(1.15,S.b[b.id]));}
function unlocked(b){return S.tb>=b.unlockAt||S.b[b.id]>0;}

// ═══════════════════════════════════════════════════════════
// RENDER  — diff-keyed to avoid full DOM reconstruction every frame
// ═══════════════════════════════════════════════════════════
function render(){
  const lvl=LEVELS[S.lv-1],nxt=LEVELS[S.lv];
  document.getElementById('big').textContent=Ns(S.c);
  document.getElementById('unit').textContent=S.c===1?'cookie':'cookies';
  document.getElementById('cps-v').textContent=Ns(S.cps);
  document.getElementById('t-tot').textContent=Ns(S.tb);
  document.getElementById('t-cps').textContent=Ns(S.cps)+'/s';
  document.getElementById('t-clk').textContent=Ns(Math.ceil(S.cm));
  document.getElementById('t-lvl').textContent='LVL '+S.lv;
  document.getElementById('t-name').textContent=lvl.name;
  const pct=nxt?Math.min(100,(S.tb/nxt.threshold)*100):100;
  document.getElementById('xp-fill').style.width=pct+'%';
  document.getElementById('xp-lbl').textContent=nxt?Ns(S.tb)+' / '+Ns(nxt.threshold):'MAX';
  renderUpg();
  renderBld();
}

function renderUpg(){
  const el=document.getElementById('upg-list');
  const vis=UPGRADES.filter(u=>S.bought.has(u.id)||u.check(S));
  if(!vis.length){
    const k='empty';
    if(el.dataset.k===k)return;
    el.dataset.k=k;
    el.innerHTML='<div style="padding:22px 16px;text-align:center;font-size:11px;color:var(--text3);line-height:1.7;">Keep baking to<br>unlock upgrades</div>';
    return;
  }
  const k=vis.map(u=>u.id+(S.bought.has(u.id)?'b':S.c>=u.cost?'a':'p')).join(',');
  if(el.dataset.k===k)return;
  el.dataset.k=k;
  el.innerHTML='';
  vis.forEach(u=>{
    const bought=S.bought.has(u.id);
    const can=S.c>=u.cost;
    const d=document.createElement('div');
    d.className='uc'+(bought?' bought':can?'':' poor');
    d.innerHTML=
      `<div class="ui">${u.icon}</div>`+
      `<div style="flex:1;min-width:0"><div class="un">${u.name}</div><div class="ud">${u.desc}</div></div>`+
      (bought?'':`<div class="ucost">${Ns(u.cost)}</div>`);
    if(!bought){
      d.addEventListener('click',()=>{
        if(S.bought.has(u.id))return;
        if(S.c<u.cost){flash(d);return;}
        S.c-=u.cost;
        S.bought.add(u.id);
        u.apply(S);
        S.cps=calcCps();
        burst(window.innerWidth/2,window.innerHeight*0.45,10);
        render();
      });
    }
    el.appendChild(d);
  });
}

function renderBld(){
  const el=document.getElementById('bld-list');
  const vis=BUILDINGS.filter(unlocked);
  if(!vis.length){
    const k='empty';
    if(el.dataset.k===k)return;
    el.dataset.k=k;
    el.innerHTML='<div style="padding:22px 16px;text-align:center;font-size:11px;color:var(--text3);line-height:1.7;">Bake a few cookies<br>to open your bakery</div>';
    return;
  }
  const k=vis.map(b=>b.id+S.b[b.id]+(S.c>=bCost(b)?'a':'p')).join(',');
  if(el.dataset.k===k)return;
  el.dataset.k=k;
  el.innerHTML='';
  vis.forEach(b=>{
    const cost=bCost(b);
    const can=S.c>=cost;
    const cnt=S.b[b.id];
    const cpsT=cnt*b.baseCps*(S.bm[b.id]||1)*S.gm;
    const d=document.createElement('div');
    d.className='bc'+(can?' can':' poor');
    d.innerHTML=
      `<div class="bi">${b.emoji}${cnt>0?`<div class="bb">${cnt}</div>`:''}</div>`+
      `<div style="flex:1;min-width:0">`+
        `<div class="bn">${b.name}</div>`+
        `<div class="bs">${b.desc}${cnt>0?` <span class="bcps">· ${Ns(cpsT)}/s</span>`:''}</div>`+
      `</div>`+
      `<div class="bcc"><span class="bcl">cost</span><span class="bcv">${Ns(cost)}</span></div>`;
    // click handler always attached — no disabled state blocking it
    d.addEventListener('click',()=>{
      const c=bCost(b);
      if(S.c<c){flash(d);return;}
      S.c-=c;
      S.b[b.id]++;
      S.cps=calcCps();
      render();
    });
    el.appendChild(d);
  });
}

// ═══════════════════════════════════════════════════════════
// COOKIE CLICK
// ═══════════════════════════════════════════════════════════
document.getElementById('ck-btn').addEventListener('click',function(e){
  const gain=Math.ceil(S.cm)*S.gMult;
  S.c+=gain;S.tb+=gain;
  // float label
  const lbl=document.createElement('div');
  lbl.className='fl';
  lbl.textContent='+'+Ns(gain);
  lbl.style.cssText=`left:${e.clientX}px;top:${e.clientY-8}px`;
  document.body.appendChild(lbl);
  setTimeout(()=>lbl.remove(),900);
  // dot particles
  const cols=['#e8c46a','#c9963a','#f0e8d6','#d4924a','rgba(255,255,255,0.8)'];
  const n=6+Math.floor(Math.random()*6);
  for(let i=0;i<n;i++){
    const p=document.createElement('div');
    p.className='dp';
    const sz=3+Math.random()*5;
    const ang=(Math.PI*2*i/n)+(Math.random()-0.5)*0.7;
    const dist=35+Math.random()*55;
    const dur=(0.45+Math.random()*0.4).toFixed(2);
    p.style.cssText=
      `width:${sz}px;height:${sz}px;background:${cols[i%cols.length]};`+
      `left:${e.clientX}px;top:${e.clientY}px;`+
      `--tx:${(Math.cos(ang)*dist).toFixed(1)}px;`+
      `--ty:${(Math.sin(ang)*dist-28).toFixed(1)}px;`+
      `--dur:${dur}s`;
    document.body.appendChild(p);
    setTimeout(()=>p.remove(),dur*1000+50);
  }
  // crumb emojis
  const crumbs=['🍪','✦','·','◦','∘'];
  for(let i=0;i<3;i++){
    const c=document.createElement('div');
    c.className='cr';
    const dur=(0.6+Math.random()*0.5).toFixed(2);
    c.textContent=crumbs[Math.floor(Math.random()*crumbs.length)];
    c.style.cssText=
      `left:${e.clientX+(Math.random()-0.5)*50}px;top:${e.clientY}px;`+
      `color:var(--gold);font-size:${12+Math.random()*8}px;`+
      `--tx:${((Math.random()-0.5)*100).toFixed(1)}px;`+
      `--ty:${-(40+Math.random()*70).toFixed(1)}px;`+
      `--rot:${((Math.random()-0.5)*360).toFixed(0)}deg;`+
      `--dur:${dur}s`;
    document.body.appendChild(c);
    setTimeout(()=>c.remove(),dur*1000+100);
  }
  // squish
  const svg=document.getElementById('ck-svg');
  svg.style.transform=`scale(0.9) rotate(${((Math.random()-0.5)*7).toFixed(1)}deg)`;
  setTimeout(()=>{svg.style.transform='';},110);
  checkLvl();checkAch();render();
});

// ═══════════════════════════════════════════════════════════
// LEVEL UP
// ═══════════════════════════════════════════════════════════
function checkLvl(){
  const nxt=LEVELS[S.lv];
  if(!nxt||S.tb<nxt.threshold)return;
  S.lv=nxt.level;
  S.cps=calcCps();
  document.getElementById('lu-emoji').textContent=nxt.emoji;
  document.getElementById('lu-title').textContent=nxt.name;
  document.getElementById('lu-sub').textContent='Level '+nxt.level+' Unlocked';
  document.getElementById('lu-desc').textContent=
    'Welcome to the rank of '+nxt.name+'.'+(nxt.bonus?' Bonus: '+nxt.bonus+'.':' New buildings and upgrades await.');
  document.getElementById('lu').classList.add('show');
  burst(window.innerWidth/2,window.innerHeight/2,30);
}
document.getElementById('lu-btn').addEventListener('click',()=>{
  document.getElementById('lu').classList.remove('show');
});

// ═══════════════════════════════════════════════════════════
// ACHIEVEMENTS
// ═══════════════════════════════════════════════════════════
let achQ=[],achBusy=false;
function checkAch(){
  ACHIEVEMENTS.forEach(a=>{if(!S.ach.has(a.id)&&a.check(S)){S.ach.add(a.id);achQ.push(a);}});
  if(!achBusy)nextAch();
}
function nextAch(){
  if(!achQ.length){achBusy=false;return;}
  achBusy=true;
  const a=achQ.shift();
  const t=document.getElementById('ach');
  document.getElementById('ach-ico').textContent=a.ico;
  document.getElementById('ach-t').textContent=a.name;
  document.getElementById('ach-s').textContent=a.sub;
  t.classList.add('show');
  setTimeout(()=>{t.classList.remove('show');setTimeout(nextAch,450);},3000);
}

// ═══════════════════════════════════════════════════════════
// PARTICLES HELPER
// ═══════════════════════════════════════════════════════════
function flash(el){
  el.classList.add('flash');
  el.addEventListener('animationend',()=>el.classList.remove('flash'),{once:true});
}
function burst(x,y,count){
  const pops=['🍪','✨','⭐','✦','·'];
  for(let i=0;i<count;i++){
    setTimeout(()=>{
      const p=document.createElement('div');
      p.className='burst';
      const ang=Math.random()*Math.PI*2;
      const d=60+Math.random()*160;
      const dur=(0.7+Math.random()*0.7).toFixed(2);
      p.textContent=pops[Math.floor(Math.random()*pops.length)];
      p.style.cssText=
        `left:${x}px;top:${y}px;`+
        `--tx:${(Math.cos(ang)*d).toFixed(1)}px;`+
        `--ty:${(Math.sin(ang)*d).toFixed(1)}px;`+
        `--rot:${((Math.random()-0.5)*360).toFixed(0)}deg;`+
        `--dur:${dur}s`;
      document.body.appendChild(p);
      setTimeout(()=>p.remove(),dur*1000+100);
    },i*35);
  }
}

// ═══════════════════════════════════════════════════════════
// GOLDEN COOKIE
// ═══════════════════════════════════════════════════════════
let gcFade=null;
function spawnGc(){
  const gc=document.getElementById('gc');
  const m=90,W=window.innerWidth,H=window.innerHeight;
  gc.style.left=(m+Math.random()*(W-m*2)-32)+'px';
  gc.style.top=(m+Math.random()*(H-m*2-72)-32)+'px';
  gc.style.display='block';
  gc.style.opacity='0';
  requestAnimationFrame(()=>requestAnimationFrame(()=>{gc.style.opacity='1';}));
  gcFade=setTimeout(()=>{
    gc.style.opacity='0';
    setTimeout(()=>{gc.style.display='none';},500);
    schedGc();
  },13000);
}
function schedGc(){setTimeout(spawnGc,28000+Math.random()*52000);}
document.getElementById('gc').addEventListener('click',function(e){
  clearTimeout(gcFade);
  const gc=document.getElementById('gc');
  gc.style.opacity='0';
  setTimeout(()=>{gc.style.display='none';},400);
  const bonus=Math.floor(S.cps*15+15*S.cm+100);
  S.c+=bonus;S.tb+=bonus;S.gc++;
  S.gAct=true;S.gMult=7;S.gRem=30;
  document.getElementById('gc-banner').style.display='block';
  burst(e.clientX,e.clientY,20);
  const lbl=document.createElement('div');
  lbl.className='fl';
  lbl.style.cssText=`left:${e.clientX}px;top:${e.clientY-14}px;color:#ffd060;font-size:16px`;
  lbl.textContent='✦ +'+Ns(bonus)+' golden bonus!';
  document.body.appendChild(lbl);
  setTimeout(()=>lbl.remove(),900);
  checkAch();render();schedGc();
});
setInterval(()=>{
  if(!S.gAct)return;
  S.gRem--;
  document.getElementById('gc-sec').textContent=S.gRem;
  if(S.gRem<=0){S.gAct=false;S.gMult=1;document.getElementById('gc-banner').style.display='none';}
},1000);

// ═══════════════════════════════════════════════════════════
// GAME LOOP
// ═══════════════════════════════════════════════════════════
let last=performance.now();
function loop(now){
  const dt=Math.min((now-last)/1000,0.5);last=now;
  const gain=S.cps*dt*S.gMult;
  if(gain>0){S.c+=gain;S.tb+=gain;}
  checkLvl();
  if(Math.random()<0.05)checkAch();
  render();
  requestAnimationFrame(loop);
}

// INIT
S.cps=calcCps();
render();
requestAnimationFrame(loop);
schedGc();
</script>
</body>
