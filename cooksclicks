<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TL GAMES+ — Cookie Clicker</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #0d0c0a;
  --surface:  #141310;
  --surface2: #1c1a17;
  --border:   rgba(255,220,130,0.08);
  --border2:  rgba(255,220,130,0.16);
  --gold:     #e8c46a;
  --gold2:    #c9963a;
  --gold-dim: rgba(232,196,106,0.12);
  --text:     #f0e8d6;
  --text2:    #9a8f7a;
  --text3:    #5a5246;
  --cream:    #fdf6e3;
  --green:    #7ab88a;
  --r:        10px;
  --r2:       16px;
  --ad-h:     72px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;background:var(--bg);font-family:'DM Sans',sans-serif;color:var(--text);overflow:hidden}

/* LAYOUT */
#app{display:grid;grid-template-columns:280px 1fr 300px;grid-template-rows:56px 1fr var(--ad-h);height:100vh;width:100vw}

/* TOPBAR */
#topbar{grid-column:1/-1;display:flex;align-items:center;padding:0 24px;border-bottom:1px solid var(--border);gap:20px;background:var(--surface)}
#logo{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:var(--gold);letter-spacing:4px;text-transform:uppercase;flex-shrink:0;line-height:1}
#logo small{color:var(--text3);font-weight:400;font-size:10px;letter-spacing:2px;display:block;margin-top:1px}
#lvl-badge{display:flex;align-items:center;gap:10px;padding:5px 14px;border:1px solid var(--border2);border-radius:20px;background:var(--gold-dim);flex-shrink:0}
.lvl-n{font-family:'DM Mono',monospace;font-size:11px;color:var(--gold);font-weight:500;letter-spacing:1px}
.lvl-nm{font-size:12px;color:var(--text2);font-weight:300}
#xp-wrap{display:flex;align-items:center;gap:10px;flex:1;max-width:300px}
#xp-bg{flex:1;height:3px;background:var(--border);border-radius:2px;overflow:hidden}
#xp-fill{height:100%;background:linear-gradient(90deg,var(--gold2),var(--gold));width:0%;transition:width .5s ease;border-radius:2px}
#xp-lbl{font-size:10px;color:var(--text3);font-family:'DM Mono',monospace;white-space:nowrap;flex-shrink:0}
#tb-right{margin-left:auto;display:flex;align-items:center;gap:24px}
.tstat .val{font-family:'DM Mono',monospace;font-size:14px;color:var(--text)}
.tstat .lbl{font-size:10px;color:var(--text3);letter-spacing:1px;text-transform:uppercase}

/* LEFT PANEL */
#left{border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;background:var(--surface)}
.phdr{padding:16px 18px 12px;border-bottom:1px solid var(--border);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);font-weight:500;flex-shrink:0}
#upg-list{flex:1;overflow-y:auto;padding:8px;display:flex;flex-direction:column;gap:5px}
#upg-list::-webkit-scrollbar{width:3px}
#upg-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* UPGRADE CARDS — note: NO pointer-events:none anywhere */
.uc{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;cursor:pointer;display:flex;align-items:center;gap:10px;transition:border-color .15s,background .15s,transform .1s;position:relative}
.uc:hover{border-color:var(--border2);background:rgba(232,196,106,0.05);transform:translateX(2px)}
.uc:active{transform:translateX(2px) scale(0.97)}
.uc.poor{opacity:0.4}
.uc.poor:hover{opacity:0.55}
.uc.bought{opacity:0.55;cursor:default;border-color:rgba(122,184,138,0.18);background:rgba(122,184,138,0.04)}
.uc.bought:hover{transform:none;background:rgba(122,184,138,0.04)}
.uc.bought::after{content:'✓';position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--green);font-size:13px}
.ui{width:32px;height:32px;border-radius:8px;background:var(--gold-dim);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.un{font-size:12px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ud{font-size:11px;color:var(--text3);margin-top:1px}
.ucost{font-family:'DM Mono',monospace;font-size:11px;color:var(--gold);flex-shrink:0}

/* flash animation */
@keyframes flashNo{0%,100%{border-color:var(--border2)}50%{border-color:#e07060;box-shadow:0 0 0 2px rgba(224,112,96,0.15)}}
.flash{animation:flashNo 0.35s ease}

/* CENTER */
#center{display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden}
#bg-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 55%,rgba(180,110,30,0.06) 0%,transparent 65%);pointer-events:none}
#gc-banner{position:absolute;top:12px;background:rgba(232,196,106,0.1);border:1px solid rgba(232,196,106,0.28);border-radius:20px;padding:5px 18px;font-size:11px;color:var(--gold);font-family:'DM Mono',monospace;letter-spacing:1px;display:none;z-index:20}
#ck-wrap{position:relative;display:flex;align-items:center;justify-content:center;margin-bottom:28px}
#ring{position:absolute;width:195px;height:195px;border-radius:50%;border:1px solid rgba(232,196,106,0.1);animation:spin 22s linear infinite;pointer-events:none}
#ring::before{content:'';position:absolute;inset:-8px;border-radius:50%;border:1px dashed rgba(232,196,106,0.05)}
@keyframes spin{to{transform:rotate(360deg)}}
#ck-btn{width:160px;height:160px;border-radius:50%;border:none;cursor:pointer;background:none;padding:0;position:relative;outline:none;-webkit-tap-highlight-color:transparent;transition:transform .12s cubic-bezier(.34,1.56,.64,1)}
#ck-btn:active{transform:scale(0.91)!important}
#ck-btn:hover #ck-svg{filter:drop-shadow(0 14px 50px rgba(200,140,40,0.55))}
#ck-svg{width:100%;height:100%;filter:drop-shadow(0 8px 28px rgba(170,100,20,0.3));transition:filter .2s}
#ck-lbl{position:absolute;bottom:-16px;left:50%;transform:translateX(-50%);font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--text3);white-space:nowrap}
#counter{text-align:center}
#big{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:600;color:var(--text);line-height:1;letter-spacing:-1px}
#unit{font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--gold);font-style:italic;display:block;margin-top:3px}
#cpsln{font-size:12px;color:var(--text3);margin-top:10px;font-family:'DM Mono',monospace}
#cpsln span{color:var(--text2)}

/* GOLDEN COOKIE */
#gc{position:fixed;display:none;cursor:pointer;z-index:500;opacity:0;transition:opacity .5s}
#gc svg{animation:gpulse 1.4s ease-in-out infinite alternate}
@keyframes gpulse{from{filter:drop-shadow(0 0 8px rgba(255,200,50,0.45))}to{filter:drop-shadow(0 0 22px rgba(255,210,60,0.9))}}
#gc-lbl{position:absolute;bottom:-22px;left:50%;transform:translateX(-50%);font-size:10px;color:var(--gold);white-space:nowrap;font-family:'DM Mono',monospace;background:var(--surface);padding:2px 7px;border-radius:4px;border:1px solid var(--border2);letter-spacing:1px}

/* RIGHT PANEL */
#right{border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;background:var(--surface)}
#bld-list{flex:1;overflow-y:auto;padding:8px;display:flex;flex-direction:column;gap:5px}
#bld-list::-webkit-scrollbar{width:3px}
#bld-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* BUILDING CARDS — NO pointer-events:none */
.bc{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;cursor:pointer;display:flex;align-items:center;gap:10px;transition:border-color .15s,background .15s,transform .1s}
.bc:hover{border-color:var(--border2);background:rgba(232,196,106,0.05);transform:translateX(-2px)}
.bc:active{transform:translateX(-2px) scale(0.97)}
.bc.poor{opacity:0.4}
.bc.poor:hover{opacity:0.58}
.bc.can{border-color:rgba(232,196,106,0.2)}
.bi{width:36px;height:36px;border-radius:9px;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;position:relative}
.bb{position:absolute;top:-5px;right:-5px;background:var(--gold2);color:#0d0c0a;font-size:9px;font-weight:500;font-family:'DM Mono',monospace;border-radius:5px;padding:1px 4px;line-height:1.5;min-width:16px;text-align:center}
.bn{font-size:12px;font-weight:500;color:var(--text)}
.bs{font-size:11px;color:var(--text3);font-family:'DM Mono',monospace;margin-top:2px}
.bcps{color:var(--gold2)}
.bcc{text-align:right;flex-shrink:0}
.bcl{font-size:9px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;display:block;margin-bottom:1px}
.bcv{font-family:'DM Mono',monospace;font-size:11px;color:var(--gold)}

/* AD BAR */
#ad-bar{grid-column:1/-1;border-top:1px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
#ad-inner{width:100%;height:100%;display:flex;align-items:center;justify-content:center}

/* PARTICLES */
.fl{position:fixed;pointer-events:none;z-index:9999;font-family:'DM Mono',monospace;font-size:14px;font-weight:500;color:var(--gold);animation:floatUp .85s ease-out forwards;transform:translateX(-50%)}
@keyframes floatUp{0%{opacity:1;transform:translateX(-50%) translateY(0)}100%{opacity:0;transform:translateX(-50%) translateY(-55px)}}
.dp{position:fixed;pointer-events:none;z-index:9999;border-radius:50%;animation:dotFly var(--dur,.7s) ease-out forwards}
@keyframes dotFly{0%{opacity:1;transform:translate(0,0) scale(1)}100%{opacity:0;transform:translate(var(--tx,0),var(--ty,-60px)) scale(0)}}
.cr{position:fixed;pointer-events:none;z-index:9999;animation:crFly var(--dur,.9s) ease-out forwards}
@keyframes crFly{0%{opacity:1;transform:translate(0,0) rotate(0deg) scale(1)}100%{opacity:0;transform:translate(var(--tx,0),var(--ty,-80px)) rotate(var(--rot,180deg)) scale(0.2)}}
.burst{position:fixed;pointer-events:none;z-index:9999;font-size:18px;animation:burstFly var(--dur,1s) ease-out forwards}
@keyframes burstFly{0%{opacity:1;transform:translate(0,0) scale(1) rotate(0deg)}100%{opacity:0;transform:translate(var(--tx,0),var(--ty,-120px)) scale(0.3) rotate(var(--rot,180deg))}}

/* LEVEL UP */
#lu{display:none;position:fixed;inset:0;z-index:10000;background:rgba(10,9,7,0.9);align-items:center;justify-content:center}
#lu.show{display:flex}
#lu-box{background:var(--surface);border:1px solid rgba(232,196,106,0.22);border-radius:22px;padding:44px 52px;max-width:440px;width:90%;text-align:center}
#lu-emoji{font-size:50px;margin-bottom:10px}
#lu-title{font-family:'Cormorant Garamond',serif;font-size:38px;font-weight:600;color:var(--gold);letter-spacing:2px}
#lu-sub{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--text3);margin:6px 0 18px}
#lu-desc{font-size:15px;color:var(--text2);line-height:1.7;font-weight:300;margin-bottom:28px}
#lu-btn{background:var(--gold);color:var(--bg);border:none;border-radius:28px;padding:11px 34px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:background .15s,transform .1s}
#lu-btn:hover{background:var(--cream)}
#lu-btn:active{transform:scale(0.97)}

/* ACHIEVEMENT TOAST */
#ach{position:fixed;bottom:calc(var(--ad-h) + 16px);left:50%;transform:translateX(-50%) translateY(80px);background:var(--surface);border:1px solid rgba(232,196,106,0.18);border-radius:var(--r2);padding:13px 18px;display:flex;align-items:center;gap:13px;z-index:9998;transition:transform .4s cubic-bezier(.34,1.56,.64,1),opacity .4s;opacity:0;min-width:270px;max-width:340px}
#ach.show{transform:translateX(-50%) translateY(0);opacity:1}
#ach-ico{width:38px;height:38px;background:var(--gold-dim);border:1px solid var(--border2);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0}
.at{font-size:13px;font-weight:500;color:var(--text)}
.as{font-size:11px;color:var(--text3);margin-top:2px}
</style>
