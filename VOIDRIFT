<script>
// ══════════════════════════════════════════════════════════════════════════════
// VOIDRIFT v2 — Battle Royal · Teams · Takeover
// Asteroids, 8-level ship upgrades, 3 lives, mode-based map sizes
// ══════════════════════════════════════════════════════════════════════════════

const SYSTEMS = ['UTIPA','XYLAR','NOVAN','DREVOS','KETHON','ZIRAEL','PROSYN','VELUUN','AXTROS','CALYPH'];

// ─── MAP SIZE BY MODE ─────────────────────────────────────────────────────────
const MAP_SIZES = { battleroyal: 10000, teams: 10000, takeover: 3500 };

// ─── BASE CONFIG ──────────────────────────────────────────────────────────────
const CFG = {
  MAP_SIZE: 10000,       // set dynamically at game start
  PLAYER_SPEED: 340,
  SIDE_THRUST_SPEED: 80,
  PLAYER_RADIUS: 26,
  BULLET_SPEED: 840,
  BULLET_LIFETIME: 3.2,
  BULLET_DAMAGE: 10,
  SHOOT_COOLDOWN: 0.25,
  RESPAWN_INVULN: 3.0,
  REGEN_RATE: 2,
  REGEN_DELAY: 10,
  BOOST_MAX: 100,
  BOOST_DRAIN: 20,
  BOOST_RECHARGE: 4,
  BOOST_SPEED_MULT: 2.2,
  BOOST_RECHARGE_DELAY: 1.0,
  BORDER_CROSS_COOLDOWN: 10, // seconds, for BR and Teams
  ENEMY_RESPAWN_TIME: 6,
  PLAYER_FOCUS_WEIGHT: 0.4,
  AMMO_MAX: 100,
  AMMO_PER_PICKUP: 15,
  AMMO_PICKUP_COUNT: 30,
  AMMO_PICKUP_RADIUS: 20,
  ASTEROID_COUNT: 120,   // scales with map
  MAX_LIVES: 3,
};

// ─── LEVEL DEFINITIONS ────────────────────────────────────────────────────────
// Each level: {pointsRequired, maxHp, bulletMode, bulletDamage, bulletRadius, description}
// bulletMode: 'single'|'double'|'heavy'|'triple'|'burst'|'spread'|'plasma'|'nova'
const LEVELS = [
  {pts:0,   maxHp:100, bulletMode:'single', bulletDmg:10, bulletR:3,   shootCd:0.25, desc:'SCOUT'},
  {pts:10,  maxHp:125, bulletMode:'double', bulletDmg:10, bulletR:3,   shootCd:0.25, desc:'FIGHTER'},
  {pts:100, maxHp:150, bulletMode:'heavy',  bulletDmg:22, bulletR:7,   shootCd:0.32, desc:'DESTROYER'},
  {pts:250, maxHp:185, bulletMode:'triple', bulletDmg:12, bulletR:4,   shootCd:0.28, desc:'INTERCEPTOR'},
  {pts:500, maxHp:220, bulletMode:'burst',  bulletDmg:18, bulletR:5,   shootCd:0.20, desc:'GUNSHIP'},
  {pts:900, maxHp:265, bulletMode:'spread', bulletDmg:14, bulletR:4.5, shootCd:0.22, desc:'WARBIRD'},
  {pts:1500,maxHp:320, bulletMode:'plasma', bulletDmg:35, bulletR:9,   shootCd:0.40, desc:'DREADNOUGHT'},
  {pts:2500,maxHp:400, bulletMode:'nova',   bulletDmg:50, bulletR:12,  shootCd:0.50, desc:'OMEGA'},
];

// ─── KEY BINDINGS ─────────────────────────────────────────────────────────────
const BIND_DEFS = [
  {id:'thrust',    label:'Thrust Forward', def:'KeyW'},
  {id:'brake',     label:'Brake',          def:'KeyS'},
  {id:'sideLeft',  label:'Strafe Left',    def:'KeyA'},
  {id:'sideRight', label:'Strafe Right',   def:'KeyD'},
  {id:'rotLeft',   label:'Rotate Left',    def:'ArrowLeft'},
  {id:'rotRight',  label:'Rotate Right',   def:'ArrowRight'},
  {id:'shoot',     label:'Shoot',          def:'Space'},
  {id:'boost',     label:'Boost',          def:'ShiftLeft'},
  {id:'escMenu',   label:'Pause Menu',     def:'Escape'},
];
const Binds = {
  map:{},
  load(){ const sv=JSON.parse(localStorage.getItem('vr2_binds')||'{}'); for(const d of BIND_DEFS) this.map[d.id]=sv[d.id]||d.def; },
  save(){ localStorage.setItem('vr2_binds',JSON.stringify(this.map)); },
  idFor(code){ for(const[id,c]of Object.entries(this.map))if(c===code)return id; return null; },
  label(code){ return code.replace('Key','').replace('Arrow','').replace('Left','←').replace('Right','→').replace('Up','↑').replace('Down','↓').replace('Space','SPC').replace('Shift','SHFT'); },
};
Binds.load();

// ─── PARTICLES ────────────────────────────────────────────────────────────────
const Particles = {
  pool:[],
  spawn(x,y,vx,vy,color,size,life){ this.pool.push({x,y,vx,vy,color,size,life,maxLife:life}); },
  tick(dt){ this.pool=this.pool.filter(p=>{p.life-=dt;p.x+=p.vx*dt;p.y+=p.vy*dt;p.vx*=0.91;p.vy*=0.91;return p.life>0;}); },
  draw(ctx){
    for(const p of this.pool){
      ctx.globalAlpha=Math.max(0,p.life/p.maxLife);
      ctx.fillStyle=p.color;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;
  },
  emitThrust(ship,boosting=false){
    const R=CFG.PLAYER_RADIUS,ba=ship.angle+Math.PI,cnt=boosting?6:3;
    for(let i=0;i<cnt;i++){
      const a=ba+(Math.random()-.5)*(boosting?.7:.45),sp=(boosting?120:55)+Math.random()*85;
      const col=boosting?`hsl(${40+Math.random()*30},100%,${60+Math.random()*20}%)`:`hsl(${185+Math.random()*30},100%,${58+Math.random()*22}%)`;
      this.spawn(ship.x+Math.cos(ba)*R*.45,ship.y+Math.sin(ba)*R*.45,Math.cos(a)*sp+ship.vx*.25,Math.sin(a)*sp+ship.vy*.25,col,boosting?2.8:1.8+Math.random()*1.8,.3+Math.random()*.15);
    }
  },
  emitSide(ship,dir){
    const R=CFG.PLAYER_RADIUS,oa=ship.angle+Math.PI/2*dir+Math.PI;
    for(let i=0;i<2;i++){const sp=35+Math.random()*50;this.spawn(ship.x+Math.cos(oa)*R*.55,ship.y+Math.sin(oa)*R*.55,Math.cos(oa+(Math.random()-.5)*.55)*sp,Math.sin(oa+(Math.random()-.5)*.55)*sp,'rgba(0,200,255,0.75)',1.4+Math.random()*1.3,.16+Math.random()*.1);}
  },
  emitHit(x,y,col='#00d4ff'){
    for(let i=0;i<10;i++){const a=Math.random()*Math.PI*2,sp=80+Math.random()*160;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,col,1.2+Math.random()*1.5,.18+Math.random()*.18);}
    this.spawn(x,y,0,0,'rgba(255,255,255,0.9)',4,.08);
  },
  emitExplosion(x,y){
    for(let i=0;i<22;i++){const a=Math.random()*Math.PI*2,sp=120+Math.random()*220;const h=Math.random()<.5?`hsl(${20+Math.random()*30},100%,60%)`:`hsl(${185+Math.random()*30},100%,65%)`;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,h,2.5+Math.random()*2.5,.5+Math.random()*.4);}
    for(let i=0;i<30;i++){const a=Math.random()*Math.PI*2,sp=30+Math.random()*90;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,'rgba(255,220,100,0.9)',1+Math.random()*2,.8+Math.random()*.6);}
    this.spawn(x,y,0,0,'rgba(255,255,255,1)',18,.12);
    this.spawn(x,y,0,0,'rgba(255,180,60,0.8)',12,.22);
  },
  emitAsteroidHit(x,y,size){
    const cnt=Math.floor(6+size*0.4);
    for(let i=0;i<cnt;i++){const a=Math.random()*Math.PI*2,sp=40+Math.random()*100;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,`hsl(${20+Math.random()*30},50%,${40+Math.random()*25}%)`,1.5+Math.random()*2,.4+Math.random()*.4);}
    this.spawn(x,y,0,0,'rgba(255,200,80,0.7)',size*.4,.2);
  },
  emitAmmoPickup(x,y){
    for(var i=0;i<8;i++){var a=Math.random()*Math.PI*2,sp=40+Math.random()*80;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,'rgba(255,220,0,0.9)',1.5+Math.random()*1.5,.25+Math.random()*.2);}
    this.spawn(x,y,0,0,'rgba(255,255,180,0.95)',5,.1);
  },
};

// ─── STARFIELD ────────────────────────────────────────────────────────────────
(function(){
  const c=document.getElementById('stars-canvas'),ctx=c.getContext('2d');
  let layers=[],nebCanvas=document.createElement('canvas'),nebCtx=nebCanvas.getContext('2d');
  function build(){
    c.width=innerWidth;c.height=innerHeight;nebCanvas.width=c.width;nebCanvas.height=c.height;
    nebCtx.clearRect(0,0,c.width,c.height);
    [{x:.15,y:.25,r:.38,col:'rgba(0,55,115,'},{x:.78,y:.62,r:.3,col:'rgba(40,0,80,'},{x:.5,y:.82,r:.24,col:'rgba(0,38,75,'},{x:.88,y:.18,r:.2,col:'rgba(55,0,75,'}].forEach(b=>{
      const gx=b.x*c.width,gy=b.y*c.height,gr=b.r*Math.max(c.width,c.height);
      const g=nebCtx.createRadialGradient(gx,gy,0,gx,gy,gr);
      g.addColorStop(0,b.col+'.06)');g.addColorStop(.5,b.col+'.025)');g.addColorStop(1,b.col+'0)');
      nebCtx.fillStyle=g;nebCtx.beginPath();nebCtx.arc(gx,gy,gr,0,Math.PI*2);nebCtx.fill();
    });
    layers=[
      Array.from({length:300},()=>({x:Math.random()*c.width,y:Math.random()*c.height,r:.4+Math.random()*.5,a:.12+Math.random()*.2,speed:.007+Math.random()*.011,tw:false})),
      Array.from({length:120},()=>({x:Math.random()*c.width,y:Math.random()*c.height,r:.75+Math.random()*.85,a:.28+Math.random()*.32,speed:.022+Math.random()*.028,tw:Math.random()<.18,ts:.8+Math.random()*1.6,tp:Math.random()*Math.PI*2})),
      Array.from({length:40},()=>({x:Math.random()*c.width,y:Math.random()*c.height,r:1.1+Math.random()*1.9,a:.5+Math.random()*.42,speed:.055+Math.random()*.055,tw:true,ts:.35+Math.random()*.9,tp:Math.random()*Math.PI*2,tint:Math.random()<.3})),
    ];
  }
  build();window.addEventListener('resize',build);
  let t=0;
  (function draw(ts){t=(ts||0)/1000;ctx.clearRect(0,0,c.width,c.height);ctx.drawImage(nebCanvas,0,0);
    for(const layer of layers)for(const s of layer){let a=s.a;if(s.tw)a*=.62+.38*Math.sin(t*s.ts+s.tp);ctx.globalAlpha=a;ctx.fillStyle=s.tint?`rgba(${180+Math.random()*30},${200+Math.random()*30},255,1)`:'rgba(210,228,255,1)';ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fill();s.y+=s.speed;if(s.y>c.height+2){s.y=-2;s.x=Math.random()*c.width;}}
    ctx.globalAlpha=1;requestAnimationFrame(draw);})(0);
})();

// ─── GAME STATE ───────────────────────────────────────────────────────────────
let nextId=1,gameRunning=false,deathLingerTimer=0;
let currentSystemName='',gameMode='battleroyal';

const GS = {
  player:null, bots:[], bullets:[], asteroids:[], ammoPickups:[],
  score:0, kills:0, deaths:0, lives:CFG.MAX_LIVES, level:0,
  over:false,
  borderCrossTimer:0, // cooldown tracker for player border crossing
};

// ─── TEAM LOGIC ───────────────────────────────────────────────────────────────
function areEnemies(a,b){
  if(!a||!b||a.id===b.id) return false;
  if(gameMode==='teams') return a.team!==b.team;
  return true; // BR and takeover: everyone vs everyone
}

// ─── NAMES ────────────────────────────────────────────────────────────────────
const NAMES_POOL=['Vega','Drax','Orion','Lyra','Siris','Nova','Cygnus','Pulsar','Quasar','Zenith','Altair','Rigel','Deneb','Spica','Mizar','Corvus','Hades','Lycon','Tanis','Pyrex','Solus','Kalix','Vorn','Trex','Aeon','Brix','Cael','Dusk','Eryx','Flux','Gale','Haze','Iris','Jett','Kova','Nex','Pyre','Rook','Sola','Typh'];
let usedNames=new Set();
function pickName(){ const av=NAMES_POOL.filter(n=>!usedNames.has(n)); if(!av.length){usedNames.clear();return NAMES_POOL[Math.floor(Math.random()*NAMES_POOL.length)];} const n=av[Math.floor(Math.random()*av.length)];usedNames.add(n);return n; }

function randPos(margin){ margin=margin||200; return {x:margin+Math.random()*(CFG.MAP_SIZE-margin*2),y:margin+Math.random()*(CFG.MAP_SIZE-margin*2)}; }
function angleDiff(a,b){let d=((b-a+Math.PI)%(Math.PI*2))-Math.PI;if(d<-Math.PI)d+=Math.PI*2;return d;}

// ─── SHIP DESIGNS BY LEVEL ────────────────────────────────────────────────────
function drawShipDesign(ctx, level, skin, R, angle){
  // level 0-7 → increasingly complex hull shapes
  ctx.save();
  ctx.rotate(angle);
  const fill=skin.fill,body=skin.body,cock=skin.cockpit;

  if(level===0){ // Scout — simple triangle
    ctx.beginPath();ctx.moveTo(R,0);ctx.lineTo(-R*.7,R*.5);ctx.lineTo(-R*.5,0);ctx.lineTo(-R*.7,-R*.5);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.stroke();
    ctx.beginPath();ctx.arc(R*.25,0,R*.18,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===1){ // Fighter — wider wings
    ctx.beginPath();ctx.moveTo(R,0);ctx.lineTo(-R*.5,R*.7);ctx.lineTo(-R*.7,R*.35);ctx.lineTo(-R*.4,0);ctx.lineTo(-R*.7,-R*.35);ctx.lineTo(-R*.5,-R*.7);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.stroke();
    ctx.fillStyle=body;ctx.fillRect(R*.3,-1.5,R*.5,3);
    ctx.beginPath();ctx.arc(R*.2,0,R*.22,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===2){ // Destroyer — heavy with fins
    ctx.beginPath();ctx.moveTo(R*1.1,0);ctx.lineTo(R*.3,R*.35);ctx.lineTo(-R*.3,R*.8);ctx.lineTo(-R*.8,R*.4);ctx.lineTo(-R*.9,0);ctx.lineTo(-R*.8,-R*.4);ctx.lineTo(-R*.3,-R*.8);ctx.lineTo(R*.3,-R*.35);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    ctx.beginPath();ctx.arc(R*.3,0,R*.26,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();
    // Armor plates
    ctx.strokeStyle=body;ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(-R*.2,R*.4);ctx.lineTo(R*.1,R*.5);ctx.stroke();
    ctx.beginPath();ctx.moveTo(-R*.2,-R*.4);ctx.lineTo(R*.1,-R*.5);ctx.stroke();

  } else if(level===3){ // Interceptor — swept back
    ctx.beginPath();ctx.moveTo(R*1.2,0);ctx.lineTo(R*.4,R*.25);ctx.lineTo(-R*.2,R*.9);ctx.lineTo(-R*.6,R*.7);ctx.lineTo(-R*.55,R*.2);ctx.lineTo(-R*.7,0);ctx.lineTo(-R*.55,-R*.2);ctx.lineTo(-R*.6,-R*.7);ctx.lineTo(-R*.2,-R*.9);ctx.lineTo(R*.4,-R*.25);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    ctx.beginPath();ctx.arc(R*.35,0,R*.24,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===4){ // Gunship — dual nacelles
    ctx.beginPath();ctx.moveTo(R,0);ctx.lineTo(R*.6,R*.4);ctx.lineTo(-R*.4,R*.7);ctx.lineTo(-R*.9,R*.4);ctx.lineTo(-R*.75,0);ctx.lineTo(-R*.9,-R*.4);ctx.lineTo(-R*.4,-R*.7);ctx.lineTo(R*.6,-R*.4);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    // Nacelle pods
    [[R*.3,R*.55],[R*.3,-R*.55]].forEach(([nx,ny])=>{
      ctx.beginPath();ctx.ellipse(nx,ny,R*.22,R*.1,0,0,Math.PI*2);ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.2;ctx.stroke();
    });
    ctx.beginPath();ctx.arc(R*.2,0,R*.28,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===5){ // Warbird — angular predator
    ctx.beginPath();ctx.moveTo(R*1.3,0);ctx.lineTo(R*.5,R*.3);ctx.lineTo(R*.2,R*.8);ctx.lineTo(-R*.5,R*.9);ctx.lineTo(-R*1.0,R*.5);ctx.lineTo(-R*.8,0);ctx.lineTo(-R*1.0,-R*.5);ctx.lineTo(-R*.5,-R*.9);ctx.lineTo(R*.2,-R*.8);ctx.lineTo(R*.5,-R*.3);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    ctx.beginPath();ctx.arc(R*.4,0,R*.28,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();
    ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(-R*.2,0);ctx.lineTo(R*.8,0);ctx.stroke();

  } else if(level===6){ // Dreadnought — massive bulk
    ctx.beginPath();ctx.moveTo(R*1.4,0);ctx.lineTo(R*.8,R*.5);ctx.lineTo(R*.3,R*.9);ctx.lineTo(-R*.4,R*1.0);ctx.lineTo(-R*1.1,R*.6);ctx.lineTo(-R*1.2,0);ctx.lineTo(-R*1.1,-R*.6);ctx.lineTo(-R*.4,-R*1.0);ctx.lineTo(R*.3,-R*.9);ctx.lineTo(R*.8,-R*.5);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2.5;ctx.stroke();
    ctx.beginPath();ctx.arc(R*.45,0,R*.32,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();
    // Armor bands
    ctx.strokeStyle=body;ctx.lineWidth=1.2;ctx.globalAlpha=0.4;
    ctx.beginPath();ctx.arc(0,0,R*.65,Math.PI*0.3,Math.PI*1.7);ctx.stroke();
    ctx.globalAlpha=1;

  } else { // level 7 — OMEGA — crown of stars
    // Main hull
    ctx.beginPath();ctx.moveTo(R*1.5,0);ctx.lineTo(R*.9,R*.6);ctx.lineTo(R*.4,R*1.1);ctx.lineTo(-R*.3,R*1.1);ctx.lineTo(-R*.9,R*.8);ctx.lineTo(-R*1.3,R*.3);ctx.lineTo(-R*1.3,-R*.3);ctx.lineTo(-R*.9,-R*.8);ctx.lineTo(-R*.3,-R*1.1);ctx.lineTo(R*.4,-R*1.1);ctx.lineTo(R*.9,-R*.6);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2.5;ctx.stroke();
    // Energy ring
    ctx.beginPath();ctx.arc(0,0,R*.75,0,Math.PI*2);ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.globalAlpha=0.5;ctx.stroke();ctx.globalAlpha=1;
    // Cockpit glow
    const cg=ctx.createRadialGradient(R*.45,0,0,R*.45,0,R*.38);
    cg.addColorStop(0,'rgba(255,255,180,0.9)');cg.addColorStop(0.5,cock);cg.addColorStop(1,'transparent');
    ctx.beginPath();ctx.arc(R*.45,0,R*.38,0,Math.PI*2);ctx.fillStyle=cg;ctx.fill();
    // Wing spikes
    [[R*.6,R*.8],[-R*.3,R*1.0],[-R*.3,-R*1.0],[R*.6,-R*.8]].forEach(([sx,sy])=>{
      ctx.beginPath();ctx.moveTo(sx,sy);ctx.lineTo(sx+R*.2*Math.sign(sx),sy+R*.25*Math.sign(sy));ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    });
  }
  ctx.restore();
}

// ─── ASTEROID GENERATION ──────────────────────────────────────────────────────
function createAsteroid(forced){
  const R=CFG.PLAYER_RADIUS;
  // Vary size: small ~0.5R, medium ~R, large ~1.8R
  const tier=Math.random(); // 0=large,1=med,2=small
  let size,pts,hp;
  if(tier<0.25){size=R*1.6+Math.random()*R*.8;pts=3;hp=3;}      // large
  else if(tier<0.6){size=R*0.9+Math.random()*R*.5;pts=2;hp=2;}   // medium
  else{size=R*0.4+Math.random()*R*.4;pts=1;hp=1;}                // small
  const pos=randPos(200);
  // Random polygon shape offsets
  const sides=6+Math.floor(Math.random()*5);
  const verts=[];
  for(let i=0;i<sides;i++){
    const a=(i/sides)*Math.PI*2;
    const r=size*(0.75+Math.random()*0.5);
    verts.push([Math.cos(a)*r,Math.sin(a)*r]);
  }
  const speed=8+Math.random()*28;
  const dir=Math.random()*Math.PI*2;
  return {
    id:nextId++,
    x:pos.x,y:pos.y,
    vx:Math.cos(dir)*speed,vy:Math.sin(dir)*speed,
    rot:Math.random()*Math.PI*2, rotSpeed:(Math.random()-.5)*0.6,
    size,pts,hp,maxHp:hp, verts,
    pulse:Math.random()*Math.PI*2,
  };
}

function spawnAsteroids(){
  GS.asteroids=[];
  const count=Math.floor(CFG.ASTEROID_COUNT*(CFG.MAP_SIZE/5000));
  for(let i=0;i<count;i++) GS.asteroids.push(createAsteroid());
}

