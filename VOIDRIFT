// ─── LEVEL UP ─────────────────────────────────────────────────────────────────
function checkLevelUp(ship){
  let newLevel=ship.level;
  for(let i=LEVELS.length-1;i>=0;i--){
    if(ship.score>=LEVELS[i].pts){ newLevel=i; break; }
  }
  if(newLevel>ship.level){
    const old=ship.level;
    ship.level=newLevel;
    const lv=LEVELS[newLevel];
    const hpRatio=ship.hp/ship.maxHp;
    ship.maxHp=lv.maxHp;
    ship.hp=Math.min(ship.maxHp,ship.maxHp*hpRatio+20);
    if(ship.isPlayer){
      flashUpgrade(lv.desc,newLevel+1);
    }
  }
}

function flashUpgrade(desc,lv){
  const el=document.getElementById('upgrade-flash');
  el.innerHTML=`LEVEL ${lv}<br><span style="font-size:0.6em;color:#adf">${desc}</span>`;
  el.classList.remove('show');
  void el.offsetWidth;
  el.classList.add('show');
}

// ─── BULLET SPAWN ─────────────────────────────────────────────────────────────
function spawnBullets(owner){
  const lv=LEVELS[owner.level||0];
  const mode=lv.bulletMode;
  const R=CFG.PLAYER_RADIUS;
  const tip=R+4;
  function mkBullet(ax,ay,angle){
    GS.bullets.push({
      id:nextId++,ownerId:owner.id,ownerTeam:owner.team??-1,
      x:ax,y:ay,
      vx:Math.cos(angle)*CFG.BULLET_SPEED+owner.vx*.3,
      vy:Math.sin(angle)*CFG.BULLET_SPEED+owner.vy*.3,
      lifetime:CFG.BULLET_LIFETIME,
      dmg:lv.bulletDmg, radius:lv.bulletR,
      level:owner.level||0,
    });
  }
  const cx=owner.x+Math.cos(owner.angle)*tip;
  const cy=owner.y+Math.sin(owner.angle)*tip;
  const a=owner.angle;
  if(mode==='single'){
    mkBullet(cx,cy,a);
  } else if(mode==='double'){
    const off=7;
    mkBullet(cx+Math.cos(a+Math.PI/2)*off,cy+Math.sin(a+Math.PI/2)*off,a);
    mkBullet(cx+Math.cos(a-Math.PI/2)*off,cy+Math.sin(a-Math.PI/2)*off,a);
  } else if(mode==='heavy'||mode==='plasma'||mode==='nova'){
    mkBullet(cx,cy,a);
  } else if(mode==='triple'){
    mkBullet(cx,cy,a);
    mkBullet(cx,cy,a+0.18);
    mkBullet(cx,cy,a-0.18);
  } else if(mode==='burst'){
    for(let i=0;i<3;i++) setTimeout(()=>{ if(!owner.alive)return; mkBullet(owner.x+Math.cos(owner.angle)*tip,owner.y+Math.sin(owner.angle)*tip,owner.angle); },i*60);
  } else if(mode==='spread'){
    for(let i=-2;i<=2;i++) mkBullet(cx,cy,a+i*0.12);
  }
}

// ─── INPUT ────────────────────────────────────────────────────────────────────
const Input={
  keys:{up:false,down:false,shoot:false,sideLeft:false,sideRight:false,boost:false},
  mouseAngle:0,mouseX:innerWidth/2,mouseY:innerHeight/2,
  arrowLeft:false,arrowRight:false,
  init(){
    window.addEventListener('keydown',e=>this._down(e));
    window.addEventListener('keyup',e=>this._up(e));
    window.addEventListener('mousemove',e=>{this.mouseX=e.clientX;this.mouseY=e.clientY;});
    window.addEventListener('mousedown',e=>{if(!gameRunning)return;if(e.button===0)this.keys.shoot=true;if(e.button===2)this.keys.up=true;});
    window.addEventListener('mouseup',e=>{if(e.button===0)this.keys.shoot=false;if(e.button===2)this.keys.up=false;});
    window.addEventListener('contextmenu',e=>{if(gameRunning)e.preventDefault();});
  },
  _down(e){
    if(!document.getElementById('settings-overlay').classList.contains('hidden'))return;
    if(!document.getElementById('esc-overlay').classList.contains('hidden')){if(Binds.idFor(e.code)==='escMenu'){EscMenu.close();e.preventDefault();}return;}
    if(gameRunning&&Binds.idFor(e.code)==='escMenu'){EscMenu.open();e.preventDefault();return;}
    this._apply(e.code,true,e);
  },
  _up(e){this._apply(e.code,false,e);},
  _apply(code,val,e){
    const id=Binds.idFor(code);if(!id)return;
    switch(id){
      case 'thrust':   this.keys.up=val;break;
      case 'brake':    this.keys.down=val;break;
      case 'sideLeft': this.keys.sideLeft=val;break;
      case 'sideRight':this.keys.sideRight=val;break;
      case 'rotLeft':  this.arrowLeft=val;if(val)e?.preventDefault();break;
      case 'rotRight': this.arrowRight=val;if(val)e?.preventDefault();break;
      case 'shoot':    this.keys.shoot=val;if(val)e?.preventDefault();break;
      case 'boost':    this.keys.boost=val;break;
    }
  },
  updateMouseAngle(){
    if(!Render.canvas)return;
    const W=Render.canvas.width,H=Render.canvas.height;
    if(!this.arrowLeft&&!this.arrowRight) this.mouseAngle=Math.atan2(this.mouseY-H/2,this.mouseX-W/2);
  },
};

// ─── PHYSICS / GAME TICK ──────────────────────────────────────────────────────
let lastTickTime=0;
let lastPlayerShoot=false;

function tickGame(now){
  if(!gameRunning||GS.over)return;
  const dt=Math.min((now-lastTickTime)/1000,.05);
  lastTickTime=now;
  const nowSec=now/1000;
  const p=GS.player;
  if(!p)return;

  const allShips=[p,...GS.bots];

  // ── PLAYER ──────────────────────────────────────────────────────────────
  if(p.alive){
    if(p.invuln>0) p.invuln-=dt;

    // Rotation
    if(this.arrowLeft||this.arrowRight){
      // handled below
    }
    if(Input.arrowLeft||Input.arrowRight){
      const dir=(Input.arrowRight?1:0)+(Input.arrowLeft?-1:0);
      p.angle+=dir*Math.PI*4*dt;p.angle=((p.angle+Math.PI)%(Math.PI*2))-Math.PI;
      Input.mouseAngle=p.angle;
    } else p.angle=Input.mouseAngle;

    const wantBoost=Input.keys.boost&&p.boostFuel>0;
    p.boosting=wantBoost;
    if(wantBoost){p.boostFuel=Math.max(0,p.boostFuel-CFG.BOOST_DRAIN*dt);p.boostRechargeTimer=CFG.BOOST_RECHARGE_DELAY;}
    else{if(p.boostRechargeTimer>0)p.boostRechargeTimer-=dt;else p.boostFuel=Math.min(CFG.BOOST_MAX,p.boostFuel+CFG.BOOST_RECHARGE*dt);}

    const bm=wantBoost?CFG.BOOST_SPEED_MULT:1;
    const effSpd=CFG.PLAYER_SPEED*bm;

    if(Input.keys.up){p.vx+=Math.cos(p.angle)*effSpd*dt*2.5;p.vy+=Math.sin(p.angle)*effSpd*dt*2.5;Particles.emitThrust(p,wantBoost);}
    if(Input.keys.sideLeft||Input.keys.sideRight){const dir=Input.keys.sideRight?1:-1;p.vx+=(-Math.sin(p.angle))*dir*CFG.SIDE_THRUST_SPEED*dt*4;p.vy+=(Math.cos(p.angle))*dir*CFG.SIDE_THRUST_SPEED*dt*4;Particles.emitSide(p,dir);}
    const drag=Input.keys.down?0.88:0.97;
    const fd=Math.pow(drag,dt*60);if(!isNaN(fd)){p.vx*=fd;p.vy*=fd;}
    const spd=Math.hypot(p.vx,p.vy);if(spd>effSpd){p.vx=p.vx/spd*effSpd;p.vy=p.vy/spd*effSpd;}

    // Map border — mode-dependent
    let nx=p.x+p.vx*dt, ny=p.y+p.vy*dt;
    const M=CFG.MAP_SIZE;
    if(gameMode==='takeover'){
      // Hard walls — no crossing
      if(nx<CFG.PLAYER_RADIUS){nx=CFG.PLAYER_RADIUS;p.vx=Math.abs(p.vx)*0.3;}
      if(nx>M-CFG.PLAYER_RADIUS){nx=M-CFG.PLAYER_RADIUS;p.vx=-Math.abs(p.vx)*0.3;}
      if(ny<CFG.PLAYER_RADIUS){ny=CFG.PLAYER_RADIUS;p.vy=Math.abs(p.vy)*0.3;}
      if(ny>M-CFG.PLAYER_RADIUS){ny=M-CFG.PLAYER_RADIUS;p.vy=-Math.abs(p.vy)*0.3;}
      p.x=nx;p.y=ny;
    } else {
      // BR and Teams: wrap with 10s cooldown
      const crossed=(nx<0||nx>M||ny<0||ny>M);
      if(GS.borderCrossTimer>0) GS.borderCrossTimer-=dt;
      if(crossed&&GS.borderCrossTimer<=0){
        p.x=((nx%M)+M)%M;p.y=((ny%M)+M)%M;
        GS.borderCrossTimer=CFG.BORDER_CROSS_COOLDOWN;
      } else if(crossed&&GS.borderCrossTimer>0){
        // Blocked — bounce softly
        if(nx<0||nx>M){p.vx*=-0.4;nx=Math.max(CFG.PLAYER_RADIUS,Math.min(M-CFG.PLAYER_RADIUS,p.x));}
        if(ny<0||ny>M){p.vy*=-0.4;ny=Math.max(CFG.PLAYER_RADIUS,Math.min(M-CFG.PLAYER_RADIUS,p.y));}
        p.x=nx;p.y=ny;
      } else {
        p.x=nx;p.y=ny;
      }
    }

    // Regen
    if(p.hp<p.maxHp&&(nowSec-p.lastDamageTime)>=CFG.REGEN_DELAY)
      p.hp=Math.min(p.maxHp,p.hp+CFG.REGEN_RATE*dt);

    // Shooting
    const lv=LEVELS[p.level||0];
    if(p.shootCooldown>0) p.shootCooldown-=dt;
    const wantShoot=Input.keys.shoot&&p.shootCooldown<=0&&p.ammo>0;
    if(wantShoot&&!lastPlayerShoot){
      spawnBullets(p);
      p.ammo=Math.max(0,p.ammo-1);
      p.shootCooldown=lv.shootCd;
    }
    lastPlayerShoot=Input.keys.shoot;

    // Level up check
    checkLevelUp(p);
  } else {
    if(deathLingerTimer>0){deathLingerTimer-=dt;if(deathLingerTimer<=0)UI.showRespawnScreen();}
  }

  // ── BOTS ────────────────────────────────────────────────────────────────
  for(const bot of GS.bots){
    if(!bot.alive){
      bot._ai.respawnTimer-=dt;
      if(bot._ai.respawnTimer<=0){
        const rp=randPos(300);bot.x=rp.x;bot.y=rp.y;bot.vx=0;bot.vy=0;
        bot.hp=bot.maxHp;bot.alive=true;bot.invuln=CFG.RESPAWN_INVULN;
        bot.shootCooldown=0;bot.lastDamageTime=-999;
        bot._ai.state='patrol';bot._ai.fleeTimer=0;
      }
      continue;
    }
    tickAI(bot,allShips,p,dt,nowSec);
  }

  // ── BULLETS ─────────────────────────────────────────────────────────────
  GS.bullets=GS.bullets.filter(b=>{
    b.lifetime-=dt;if(b.lifetime<=0)return false;
    const M=CFG.MAP_SIZE;
    b.x=((b.x+b.vx*dt)%M+M)%M;
    b.y=((b.y+b.vy*dt)%M+M)%M;

    // Check ships
    for(const target of allShips){
      if(!target.alive||target.id===b.ownerId||target.invuln>0)continue;
      if(b.ownerTeam!==-1&&b.ownerTeam===target.team)continue;
      if(Math.hypot(target.x-b.x,target.y-b.y)<CFG.PLAYER_RADIUS+b.radius){
        target.hp-=b.dmg;target.lastDamageTime=nowSec;
        Particles.emitHit(b.x,b.y,'#00d4ff');
        if(target.hp<=0){
          target.hp=0;target.alive=false;
          Particles.emitExplosion(target.x,target.y);
          if(target.isPlayer){
            GS.deaths++;GS.lives--;
            deathLingerTimer=3;UI.startDeathLinger();
          } else {
            const killer=allShips.find(s=>s.id===b.ownerId);
            if(killer){
              killer.kills++;killer.score+=50;
              if(killer.isPlayer){GS.kills++;GS.score+=50;checkLevelUp(p);}
            }
            target._ai.respawnTimer=CFG.ENEMY_RESPAWN_TIME;
            UI.addKillFeed(killer?.username,target.username);
          }
          checkWinCondition();
        }
        return false;
      }
    }

    // Check asteroids
    for(let ai=0;ai<GS.asteroids.length;ai++){
      const ast=GS.asteroids[ai];
      if(Math.hypot(ast.x-b.x,ast.y-b.y)<ast.size+b.radius){
        ast.hp-=b.dmg;
        Particles.emitAsteroidHit(b.x,b.y,ast.size);
        if(ast.hp<=0){
          // Award points to bullet owner
          const killer=allShips.find(s=>s.id===b.ownerId);
          if(killer){
            killer.score+=ast.pts;
            if(killer.isPlayer){GS.score+=ast.pts;checkLevelUp(p);}
          }
          // Spawn smaller shards
          if(ast.size>CFG.PLAYER_RADIUS*0.6){
            const shards=Math.floor(1+Math.random()*2);
            for(let s=0;s<shards;s++){
              const na=createAsteroid();
              na.x=ast.x+(Math.random()-.5)*ast.size*2;
              na.y=ast.y+(Math.random()-.5)*ast.size*2;
              na.size=ast.size*0.45*(0.8+Math.random()*0.4);
              na.pts=Math.max(1,ast.pts-1);
              na.hp=1;na.maxHp=1;
              GS.asteroids.push(na);
            }
          }
          Particles.emitExplosion(ast.x,ast.y);
          GS.asteroids.splice(ai,1);
          // Respawn a new asteroid after delay
          setTimeout(()=>{ if(gameRunning) GS.asteroids.push(createAsteroid()); },3000+Math.random()*5000);
        }
        return false;
      }
    }

    return true;
  });

  // ── ASTEROIDS (movement + player collision) ───────────────────────────
  for(let ai=0;ai<GS.asteroids.length;ai++){
    const ast=GS.asteroids[ai];
    ast.rot+=ast.rotSpeed*dt;ast.pulse+=dt*2;
    const M=CFG.MAP_SIZE;
    ast.x=((ast.x+ast.vx*dt)%M+M)%M;
    ast.y=((ast.y+ast.vy*dt)%M+M)%M;
    // Asteroid ramming player
    if(p.alive&&p.invuln<=0&&Math.hypot(ast.x-p.x,ast.y-p.y)<ast.size+CFG.PLAYER_RADIUS){
      p.hp-=5*ast.hp;p.lastDamageTime=nowSec;
      Particles.emitAsteroidHit(p.x,p.y,ast.size);
      const pushA=Math.atan2(p.y-ast.y,p.x-ast.x);
      p.vx+=Math.cos(pushA)*80;p.vy+=Math.sin(pushA)*80;
      if(p.hp<=0){
        p.hp=0;p.alive=false;Particles.emitExplosion(p.x,p.y);
        GS.deaths++;GS.lives--;
        deathLingerTimer=3;UI.startDeathLinger();
        checkWinCondition();
      }
    }
  }

  // ── AMMO PICKUPS ────────────────────────────────────────────────────────
  if(p.alive){
    for(let ai2=0;ai2<GS.ammoPickups.length;ai2++){
      const ap=GS.ammoPickups[ai2];if(!ap)continue;
      ap.pulse+=dt*3;
      if(Math.hypot(p.x-ap.x,p.y-ap.y)<CFG.AMMO_PICKUP_RADIUS+CFG.PLAYER_RADIUS){
        p.ammo=Math.min(CFG.AMMO_MAX,p.ammo+CFG.AMMO_PER_PICKUP);
        Particles.emitAmmoPickup(ap.x,ap.y);
        respawnAmmoPickup(ai2);
      }
    }
  }

  Particles.tick(dt);
  UI.updateHUD();
}

// ─── AI TICK ─────────────────────────────────────────────────────────────────
function tickAI(bot,allShips,player,dt,nowSec){
  const ai=bot._ai;
  if(bot.invuln>0)bot.invuln-=dt;
  ai.stateTimer-=dt;

  const fleeHp=bot.maxHp*0.20,fleeRecover=bot.maxHp*0.30;
  if(bot.hp<=fleeHp&&ai.state!=='evade'){ai.state='evade';ai.fleeTimer=4+Math.random()*3;}
  if(ai.state==='evade'){
    ai.fleeTimer-=dt;
    if(ai.fleeTimer<=0&&bot.hp>=fleeRecover){ai.state='patrol';ai.stateTimer=0;}
  }

  // Pick target: ships + asteroids
  let target=null,targetAst=null;
  const enemies=allShips.filter(s=>s.alive&&s.id!==bot.id&&areEnemies(bot,s));
  if(ai.state!=='evade'){
    // Find nearest enemy ship
    if(enemies.length){
      enemies.sort((a,b)=>Math.hypot(a.x-bot.x,a.y-bot.y)-Math.hypot(b.x-bot.x,b.y-bot.y));
      target=(player.alive&&Math.random()<CFG.PLAYER_FOCUS_WEIGHT)?player:enemies[0];
    }
    // Find nearest asteroid if no nearby ship or as supplement
    if(!target||Math.hypot(target.x-bot.x,target.y-bot.y)>800){
      const nearAst=GS.asteroids.filter(a=>Math.hypot(a.x-bot.x,a.y-bot.y)<600);
      if(nearAst.length&&Math.random()<0.5) targetAst=nearAst.sort((a,b)=>Math.hypot(a.x-bot.x,a.y-bot.y)-Math.hypot(b.x-bot.x,b.y-bot.y))[0];
    }
  }

  const eff = targetAst&&!target ? targetAst : target;
  const dx=eff?eff.x-bot.x:0;
  const dy=eff?eff.y-bot.y:0;
  const dist=eff?Math.hypot(dx,dy):Infinity;
  const angleToTarget=eff?Math.atan2(dy,dx):bot.angle;

  let wantThrust=false,wantShoot=false,targetAngle=bot.angle;

  if(ai.state==='evade'){
    const nearestThreat=enemies.sort((a,b)=>Math.hypot(a.x-bot.x,a.y-bot.y)-Math.hypot(b.x-bot.x,b.y-bot.y))[0];
    const fleeAngle=nearestThreat?Math.atan2(bot.y-nearestThreat.y,bot.x-nearestThreat.x):bot.angle+Math.PI;
    targetAngle=fleeAngle+(Math.random()-.5)*0.6;wantThrust=true;
  } else if(!eff){
    ai.state='patrol';
    if(ai.stateTimer<0){ai.patrolAngle+=((Math.random()-.5)*1.5);ai.stateTimer=2+Math.random()*3;}
    targetAngle=ai.patrolAngle;wantThrust=Math.random()<0.6;
  } else if(dist>500){
    targetAngle=angleToTarget;wantThrust=true;
  } else {
    targetAngle=angleToTarget;wantThrust=dist>200;
    if(Math.abs(angleDiff(bot.angle,angleToTarget))<0.35) wantShoot=true;
  }

  const diff=angleDiff(bot.angle,targetAngle);
  bot.angle+=Math.sign(diff)*Math.min(Math.abs(diff),Math.PI*3.5*dt);
  bot.angle=((bot.angle+Math.PI)%(Math.PI*2))-Math.PI;
  if(wantThrust){bot.vx+=Math.cos(bot.angle)*CFG.PLAYER_SPEED*dt*2;bot.vy+=Math.sin(bot.angle)*CFG.PLAYER_SPEED*dt*2;}
  bot.vx*=0.97;bot.vy*=0.97;
  const spd=Math.hypot(bot.vx,bot.vy);
  if(spd>CFG.PLAYER_SPEED){bot.vx=bot.vx/spd*CFG.PLAYER_SPEED;bot.vy=bot.vy/spd*CFG.PLAYER_SPEED;}

  const M=CFG.MAP_SIZE;
  bot.x=((bot.x+bot.vx*dt)%M+M)%M;
  bot.y=((bot.y+bot.vy*dt)%M+M)%M;

  if(bot.shootCooldown>0) bot.shootCooldown-=dt;
  if(wantShoot&&bot.shootCooldown<=0){
    spawnBullets(bot);
    const blv=LEVELS[bot.level||0];
    bot.shootCooldown=blv.shootCd*(1+Math.random()*.4);
  }
  if(bot.hp<bot.maxHp&&(nowSec-bot.lastDamageTime)>=CFG.REGEN_DELAY)
    bot.hp=Math.min(bot.maxHp,bot.hp+CFG.REGEN_RATE*dt);

  // Bots also level up
  checkLevelUp(bot);
}

// ─── WIN CONDITION ────────────────────────────────────────────────────────────
function checkWinCondition(){
  if(GS.lives<=0&&!GS.player.alive){
    endGame(false,'ELIMINATED — OUT OF LIVES');
    return;
  }
  if(gameMode==='battleroyal'){
    const aliveCount=GS.bots.filter(b=>b.alive).length+(GS.player.alive?1:0);
    if(aliveCount<=1&&GS.player.alive) endGame(true,'LAST PILOT STANDING');
  }
}

function endGame(won,subtitle){
  GS.over=true;gameRunning=false;
