<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VOIDRIFT</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#050810;--surface:#0a1020;--border:#1a2a4a;
  --accent:#00d4ff;--accent2:#ff4060;--green:#00ff88;--gold:#ffd700;
  --text:#c8ddf0;--dim:#4a6080;--glow:0 0 20px rgba(0,212,255,0.4);
  --sb-width:clamp(180px,16vw,260px);--sb-top:0px;
}
html,body{width:100%;height:100%;background:var(--bg);color:var(--text);font-family:'Share Tech Mono',monospace;overflow:hidden;user-select:none;}
.screen{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.4s;}
.screen.hidden{opacity:0;pointer-events:none;}
#stars-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}

#credit{position:fixed;top:14px;left:18px;z-index:200;font-size:0.62rem;color:rgba(0,180,255,0.7);letter-spacing:0.08em;pointer-events:none;transition:opacity 0.5s;}
#credit.hidden{opacity:0;}

/* ── ENTER ── */
#enter-screen{z-index:10;}
.logo{font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(2.5rem,7vw,5rem);letter-spacing:0.15em;color:var(--accent);text-shadow:0 0 40px rgba(0,212,255,0.8),0 0 80px rgba(0,212,255,0.3);animation:pulse 3s ease-in-out infinite;}
.logo-sub{font-size:0.7rem;letter-spacing:0.4em;color:var(--dim);margin-top:0.3em;margin-bottom:2rem;text-transform:uppercase;}
@keyframes pulse{0%,100%{text-shadow:0 0 40px rgba(0,212,255,0.8),0 0 80px rgba(0,212,255,0.3);}50%{text-shadow:0 0 70px rgba(0,212,255,1),0 0 130px rgba(0,212,255,0.5);}}
.enter-card{background:rgba(6,10,22,0.93);border:1px solid var(--border);border-top:2px solid var(--accent);padding:2rem 2.5rem;width:min(480px,95vw);display:flex;flex-direction:column;gap:0.9rem;box-shadow:0 0 80px rgba(0,212,255,0.06);}
.field-label{font-size:0.62rem;letter-spacing:0.25em;color:var(--dim);text-transform:uppercase;margin-bottom:0.3rem;}
.field-hint{font-size:0.58rem;color:var(--dim);margin-top:0.2rem;min-height:1em;}
.field-hint.err{color:var(--accent2);}
.field-hint.ok{color:var(--green);}
input[type="text"],input[type="number"]{width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--border);border-bottom:2px solid var(--accent);color:var(--accent);font-family:'Share Tech Mono',monospace;font-size:0.95rem;padding:0.5rem 0.7rem;outline:none;transition:box-shadow 0.2s;caret-color:var(--accent);}
input[type="text"]:focus,input[type="number"]:focus{box-shadow:var(--glow);}
input[type="text"]::placeholder,input[type="number"]::placeholder{color:var(--dim);}
input[type="text"].invalid{border-bottom-color:var(--accent2);}
input[type="number"]{-moz-appearance:textfield;}
input[type="number"]::-webkit-outer-spin-button,input[type="number"]::-webkit-inner-spin-button{-webkit-appearance:none;}
.mode-row{display:flex;gap:0.5rem;}
.mode-btn{flex:1;font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.6rem 0.3rem;background:transparent;border:1px solid var(--border);color:var(--dim);cursor:pointer;transition:all 0.2s;}
.mode-btn.active{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,0.07);}
.mode-btn:hover{border-color:var(--accent);color:var(--accent);}
.btn-row{display:flex;gap:0.8rem;}
.btn-primary{font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.82rem;letter-spacing:0.18em;text-transform:uppercase;padding:0.8rem 1.6rem;background:transparent;border:1px solid var(--accent);color:var(--accent);cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden;flex:1;}
.btn-primary::before{content:'';position:absolute;inset:0;background:var(--accent);transform:scaleX(0);transform-origin:left;transition:transform 0.2s;z-index:-1;}
.btn-primary:hover{color:var(--bg);box-shadow:var(--glow);}
.btn-primary:hover::before{transform:scaleX(1);}
.btn-primary:disabled{opacity:0.4;cursor:not-allowed;}
.btn-primary:disabled:hover{color:var(--accent);}
.btn-primary:disabled:hover::before{transform:scaleX(0);}
.btn-secondary{font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.82rem;letter-spacing:0.18em;text-transform:uppercase;padding:0.8rem 1.2rem;background:transparent;border:1px solid var(--dim);color:var(--dim);cursor:pointer;transition:all 0.2s;}
.btn-secondary:hover{border-color:var(--accent);color:var(--accent);}
.status-line{font-size:0.68rem;color:var(--dim);text-align:center;min-height:1em;}
.controls-hint-txt{font-size:0.57rem;color:var(--dim);text-align:center;line-height:2;border-top:1px solid var(--border);padding-top:0.75rem;}
.controls-hint-txt span{color:rgba(0,212,255,0.75);}

/* ── CONNECTING ── */
#connecting-screen{z-index:15;}
.conn-box{display:flex;flex-direction:column;align-items:center;gap:1.2rem;text-align:center;}
.conn-system{font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(1.8rem,5vw,3.2rem);letter-spacing:0.15em;color:var(--accent);text-shadow:0 0 30px rgba(0,212,255,0.7);}
.conn-subtitle{font-size:0.7rem;letter-spacing:0.35em;color:var(--dim);text-transform:uppercase;}
.conn-log{width:min(480px,90vw);text-align:left;font-size:0.68rem;color:var(--dim);display:flex;flex-direction:column;gap:0.3rem;margin-top:0.5rem;}
.conn-line{display:flex;align-items:center;gap:0.6rem;opacity:0;transition:opacity 0.3s;}
.conn-line.show{opacity:1;}
.conn-line .ok{color:var(--green);}
.conn-line .spin{display:inline-block;animation:spin .6s linear infinite;color:var(--accent);}
@keyframes spin{to{transform:rotate(360deg)}}
.conn-bar-wrap{width:min(400px,80vw);height:4px;background:rgba(255,255,255,0.07);border:1px solid var(--border);margin-top:0.5rem;}
.conn-bar{height:100%;background:var(--accent);width:0%;transition:width 0.3s ease;}

/* ── SETTINGS ── */
#settings-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:100;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
#settings-overlay.hidden{display:none;}
.settings-panel{background:rgba(6,10,22,0.98);border:1px solid var(--border);border-top:2px solid var(--accent);width:min(560px,95vw);max-height:88vh;overflow-y:auto;padding:2rem;}
.settings-panel h2{font-family:'Orbitron',sans-serif;font-size:0.95rem;letter-spacing:0.2em;color:var(--accent);margin-bottom:1.5rem;}
.settings-section{margin-bottom:1.5rem;}
.settings-section h3{font-size:0.6rem;letter-spacing:0.25em;color:var(--dim);text-transform:uppercase;margin-bottom:0.75rem;border-bottom:1px solid var(--border);padding-bottom:0.35rem;}
.keybind-row{display:flex;align-items:center;justify-content:space-between;padding:0.38rem 0;border-bottom:1px solid rgba(255,255,255,0.04);}
.keybind-label{font-size:0.68rem;color:var(--text);}
.keybind-btn{font-family:'Share Tech Mono',monospace;font-size:0.65rem;background:rgba(0,0,0,0.4);border:1px solid var(--border);color:var(--accent);padding:0.28rem 0.75rem;cursor:pointer;min-width:95px;text-align:center;transition:border-color 0.2s;}
.keybind-btn:hover{border-color:var(--accent);}
.keybind-btn.listening{border-color:var(--accent2);color:var(--accent2);animation:blink .6s step-end infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.25}}

/* ── ESC MENU ── */
#esc-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.72);z-index:50;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(3px);}
#esc-overlay.hidden{display:none;}
.esc-panel{background:rgba(6,10,22,0.97);border:1px solid var(--border);border-top:2px solid var(--accent);padding:2.5rem 3rem;display:flex;flex-direction:column;gap:0.9rem;width:min(320px,92vw);align-items:stretch;}
.esc-title{font-family:'Orbitron',sans-serif;font-size:1.1rem;letter-spacing:0.25em;color:var(--accent);text-align:center;margin-bottom:0.5rem;}

/* ── GAME ── */
#game-screen{z-index:1;}
#game-canvas{display:block;cursor:none;}

/* ── HUD ── */
#hud{position:fixed;inset:0;z-index:5;pointer-events:none;}
#status-bars-wrap{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;gap:14px;align-items:flex-end;}
.stat-bar-col{display:flex;flex-direction:column;align-items:center;gap:4px;width:140px;}
.stat-bar-label{font-size:0.52rem;letter-spacing:0.2em;color:var(--dim);text-transform:uppercase;}
.stat-bar-bg{width:100%;height:7px;background:rgba(255,255,255,0.07);border:1px solid var(--border);}
.stat-bar-bg div{height:100%;transition:width 0.12s,background 0.3s;}
.stat-bar-text{font-size:0.68rem;color:var(--text);}
#hp-bar{background:var(--green);}
#boost-bar{background:#ffcc00;}
#ammo-bar-inner{background:#ffdd00;}
#mini-map{position:absolute;bottom:24px;right:24px;width:160px;height:160px;border:1px solid var(--border);background:rgba(5,8,16,0.85);}
#scoreboard{position:absolute;top:24px;right:24px;width:200px;background:rgba(5,8,16,0.78);border:1px solid var(--border);border-top:2px solid var(--accent);padding:0.8rem;font-size:0.68rem;}
#scoreboard h3{font-family:'Orbitron',sans-serif;font-size:0.58rem;letter-spacing:0.2em;color:var(--accent);margin-bottom:0.6rem;text-transform:uppercase;}
.score-row{display:flex;justify-content:space-between;padding:2px 0;border-bottom:1px solid rgba(255,255,255,0.04);color:var(--text);}
.score-row .sname{max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.score-row.player-row{color:var(--accent);}
.score-row.ally-row{color:var(--green);}
.score-row.enemy-row{color:var(--accent2);}
#kill-feed{position:absolute;top:70px;left:24px;width:290px;display:flex;flex-direction:column;gap:4px;pointer-events:none;}
.kill-entry{background:rgba(5,8,16,0.82);border-left:2px solid var(--accent2);padding:4px 8px;font-size:0.66rem;animation:fadeSlide 0.3s ease,fadeOut 0.5s ease 3.5s forwards;}
@keyframes fadeSlide{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeOut{to{opacity:0}}
#coords{position:absolute;bottom:24px;left:24px;font-size:0.62rem;color:var(--dim);}
#border-warning{position:absolute;top:46%;left:50%;transform:translate(-50%,-50%);font-family:'Orbitron',sans-serif;font-size:0.7rem;letter-spacing:0.2em;color:var(--accent2);pointer-events:none;opacity:0;transition:opacity 0.3s;text-align:center;}
#border-warning.hw{opacity:1;}
#alive-counter{position:absolute;top:24px;left:24px;background:rgba(5,8,16,0.8);border:1px solid var(--border);padding:5px 12px;font-size:0.7rem;display:flex;flex-direction:column;gap:1px;}
#alive-counter .ac-label{font-size:0.52rem;letter-spacing:0.2em;color:var(--dim);text-transform:uppercase;}
#alive-counter .ac-val{font-family:'Orbitron',sans-serif;font-size:1.2rem;color:var(--text);}
/* Level / upgrade HUD */
#level-hud{position:absolute;top:24px;left:50%;transform:translateX(-50%);text-align:center;background:rgba(5,8,16,0.8);border:1px solid var(--border);border-top:2px solid var(--gold);padding:6px 18px;font-size:0.65rem;}
#level-hud .lv-num{font-family:'Orbitron',sans-serif;font-size:1.1rem;color:var(--gold);}
#level-hud .lv-pts{color:var(--dim);font-size:0.58rem;}
/* Lives HUD */
#lives-hud{position:absolute;top:80px;left:24px;display:flex;gap:6px;align-items:center;}
.life-icon{width:18px;height:18px;opacity:1;}
.life-icon.lost{opacity:0.18;}
/* Upgrade flash */
#upgrade-flash{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Orbitron',sans-serif;font-size:1.4rem;letter-spacing:0.2em;color:var(--gold);text-shadow:0 0 30px rgba(255,215,0,0.9);pointer-events:none;opacity:0;text-align:center;}
#upgrade-flash.show{animation:upFlash 2s ease forwards;}
@keyframes upFlash{0%{opacity:0;transform:translate(-50%,-50%) scale(0.7)}20%{opacity:1;transform:translate(-50%,-60%) scale(1.1)}70%{opacity:1;transform:translate(-50%,-60%) scale(1)}100%{opacity:0;transform:translate(-50%,-70%) scale(1)}}
/* Border cooldown indicator */
#border-cd{position:absolute;bottom:110px;left:50%;transform:translateX(-50%);font-family:'Orbitron',sans-serif;font-size:0.65rem;letter-spacing:0.15em;color:var(--accent2);pointer-events:none;opacity:0;text-align:center;}
#border-cd.show{opacity:1;}
/* Ammo warning */
#ammo-warning{display:none;position:absolute;bottom:80px;left:50%;transform:translateX(-50%);font-family:'Orbitron',sans-serif;font-size:0.72rem;letter-spacing:0.2em;color:#ff4060;text-shadow:0 0 12px rgba(255,64,96,0.8);pointer-events:none;text-transform:uppercase;}

/* ── WIN / LOSE ── */
#end-screen{z-index:25;background:rgba(5,8,16,0.92);backdrop-filter:blur(8px);}
.end-title{font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(2.5rem,7vw,5rem);letter-spacing:0.1em;margin-bottom:0.4rem;animation:endPulse 1.2s ease-in-out infinite;}
.end-title.win{color:var(--gold);text-shadow:0 0 40px rgba(255,215,0,0.8);}
.end-title.lose{color:var(--accent2);text-shadow:0 0 40px rgba(255,64,96,0.7);}
@keyframes endPulse{0%,100%{opacity:1}50%{opacity:0.75}}
.end-sub{font-size:0.72rem;letter-spacing:0.25em;color:var(--dim);margin-bottom:2.5rem;text-transform:uppercase;}
.end-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2.5rem;text-align:center;width:min(560px,90vw);}
.stat-box{border:1px solid var(--border);padding:1rem;background:rgba(10,16,32,0.7);}
.stat-val{font-family:'Orbitron',sans-serif;font-size:1.6rem;font-weight:700;color:var(--accent);display:block;}
.stat-lbl{font-size:0.55rem;letter-spacing:0.2em;color:var(--dim);text-transform:uppercase;margin-top:0.2rem;}
.end-system{font-size:0.65rem;color:var(--dim);margin-bottom:1.8rem;}
.end-system span{color:var(--accent);}

/* ── RESPAWN / DEATH ── */
#respawn-screen{z-index:20;background:rgba(5,8,16,0.88);backdrop-filter:blur(6px);}
.death-title{font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(2.5rem,6vw,4.5rem);color:var(--accent2);text-shadow:0 0 40px rgba(255,64,96,0.7);letter-spacing:0.1em;margin-bottom:0.5rem;animation:deathPulse 1s ease-in-out infinite;}
@keyframes deathPulse{0%,100%{text-shadow:0 0 40px rgba(255,64,96,0.7)}50%{text-shadow:0 0 80px rgba(255,64,96,1)}}
.death-sub{color:var(--dim);font-size:0.73rem;letter-spacing:0.2em;margin-bottom:2rem;}
.death-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-bottom:2rem;text-align:center;width:min(420px,90vw);}
.killed-by{font-size:0.73rem;color:var(--dim);margin-bottom:1.5rem;min-height:1.2em;}
.killed-by span{color:var(--accent2);}
#lives-remaining{font-family:'Orbitron',sans-serif;font-size:1.1rem;color:var(--gold);margin-bottom:1rem;letter-spacing:0.15em;}

/* ── SIDEBARS ── */
.sidebar{position:fixed;top:var(--sb-top);width:var(--sb-width);height:calc(100vh - var(--sb-top));z-index:300;background:rgba(4,8,18,0.97);display:flex;flex-direction:column;align-items:center;overflow:hidden;transition:transform 0.45s cubic-bezier(0.4,0,0.2,1),opacity 0.45s ease;}
#sidebar-left{left:0;border-right:1px solid rgba(0,212,255,0.28);transform:translateX(0);}
#sidebar-right{right:0;border-left:1px solid rgba(0,212,255,0.28);transform:translateX(0);}
#sidebar-left.sb-hidden{transform:translateX(-100%);opacity:0.3;}
#sidebar-right.sb-hidden{transform:translateX(100%);opacity:0.3;}
.sidebar::before,.sidebar::after{content:'';position:absolute;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent 0%,rgba(0,212,255,0.55) 30%,rgba(0,212,255,1) 50%,rgba(0,212,255,0.55) 70%,transparent 100%);z-index:2;}
.sidebar::before{top:0;}
.sidebar::after{bottom:0;}
.sidebar-glow{position:absolute;top:0;width:2px;height:180px;background:linear-gradient(180deg,transparent 0%,rgba(0,212,255,0) 8%,rgba(0,212,255,0.95) 50%,rgba(0,212,255,0) 92%,transparent 100%);filter:blur(3px);animation:glowTravel 3.2s linear infinite;pointer-events:none;z-index:2;}
#sidebar-left .sidebar-glow{right:0;}
#sidebar-right .sidebar-glow{left:0;animation-delay:-1.6s;}
@keyframes glowTravel{0%{top:-180px;opacity:0.6}10%{opacity:1}90%{opacity:1}100%{top:calc(100vh + 20px);opacity:0.6}}
.sidebar-lines{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.sidebar-lines::before{content:'';position:absolute;top:80px;bottom:80px;left:50%;width:1px;transform:translateX(-50%);background:rgba(0,212,255,0.06);}
.sidebar-header{position:relative;z-index:1;width:100%;padding:16px 8px 12px;text-align:center;border-bottom:1px solid rgba(0,212,255,0.18);background:rgba(0,212,255,0.04);flex-shrink:0;}
.sidebar-header-title{font-family:'Orbitron',sans-serif;font-weight:700;font-size:clamp(0.42rem,0.8vw,0.62rem);letter-spacing:0.22em;color:rgba(0,212,255,0.8);text-transform:uppercase;}
.sidebar-content{position:relative;z-index:1;width:100%;flex:1;padding:14px 10px;display:flex;flex-direction:column;gap:12px;overflow-y:auto;scrollbar-width:none;}
.sidebar-content::-webkit-scrollbar{display:none;}
.sidebar-slot{width:100%;min-height:80px;border:1px solid rgba(0,212,255,0.14);background:rgba(0,212,255,0.03);position:relative;display:flex;align-items:flex-start;justify-content:center;padding:10px 8px;flex-shrink:0;}
.slot-placeholder{font-family:'Share Tech Mono',monospace;font-size:clamp(0.45rem,0.7vw,0.55rem);color:rgba(0,212,255,0.2);text-align:center;letter-spacing:0.12em;text-transform:uppercase;line-height:1.8;}
.news-item{font-family:'Share Tech Mono',monospace;font-size:clamp(0.48rem,0.75vw,0.6rem);color:rgba(180,210,255,0.6);line-height:1.75;border-left:2px solid rgba(0,212,255,0.2);padding-left:8px;}
.sidebar-scanline{position:absolute;left:0;right:0;height:60px;background:linear-gradient(180deg,transparent 0%,rgba(0,212,255,0.025) 50%,transparent 100%);pointer-events:none;animation:scanline 5s linear infinite;z-index:0;}
@keyframes scanline{0%{top:-60px}100%{top:100vh}}
</style>
</head>
<body>

<!-- SIDEBARS -->
<div id="sidebar-left" class="sidebar">
  <div class="sidebar-glow"></div><div class="sidebar-lines"></div><div class="sidebar-scanline"></div>
  <div class="sidebar-header"><div class="sidebar-header-title">NEWS</div></div>
  <div class="sidebar-content">
    <div class="sidebar-slot"><p class="news-item">VOIDRIFT v2.0<br>Battle Royal · Teams · Takeover<br>Asteroid fields · 8-level upgrades</p></div>
    <div class="sidebar-slot"><p class="news-item">Break asteroids for points.<br>Reach 10pts → Level 2.<br>Max out at Level 8.</p></div>
    <div class="sidebar-slot"><p class="news-item">Battle Royal & Teams:<br>10s border crossing cooldown.<br>Takeover: no border cross.</p></div>
  </div>
</div>
<div id="sidebar-right" class="sidebar">
  <div class="sidebar-glow"></div><div class="sidebar-lines"></div><div class="sidebar-scanline"></div>
  <div class="sidebar-header"><div class="sidebar-header-title">ADVERTISEMENTS</div></div>
  <div class="sidebar-content">
    <div class="sidebar-slot"><span class="slot-placeholder">Ad Slot 1</span></div>
    <div class="sidebar-slot"><span class="slot-placeholder">Ad Slot 2</span></div>
  </div>
</div>

<canvas id="stars-canvas"></canvas>
<div id="credit">credit to TL BAGS</div>

<!-- ENTER -->
<div id="enter-screen" class="screen">
  <div class="logo">VOIDRIFT</div>
  <div class="logo-sub">Space Combat Simulator</div>
  <div class="enter-card">
    <div>
      <div class="field-label">Pilot Name</div>
      <input type="text" id="username-input" maxlength="20" placeholder="min 3 chars" autocomplete="off" spellcheck="false">
      <div class="field-hint" id="name-hint">Letters, numbers, underscores</div>
    </div>
    <div>
      <div class="field-label">Game Mode</div>
      <div class="mode-row">
        <button class="mode-btn active" data-mode="battleroyal">Battle Royal</button>
        <button class="mode-btn" data-mode="teams">Teams</button>
        <button class="mode-btn" data-mode="takeover">Takeover</button>
      </div>
    </div>
    <div>
      <div class="field-label">Bot Count</div>
      <input type="number" id="br-bots" value="24" min="1" max="49">
      <div class="field-hint">Bots in session (1–49)</div>
    </div>
    <div class="btn-row">
      <button class="btn-primary" id="launch-btn">LAUNCH</button>
