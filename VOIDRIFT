      const lc=ic.getContext('2d');lc.strokeStyle=i<GS.lives?'#00d4ff':'#1a2a4a';lc.lineWidth=1.5;
      lc.beginPath();lc.moveTo(9,2);lc.lineTo(16,16);lc.lineTo(9,13);lc.lineTo(2,16);lc.closePath();lc.stroke();
      lhud.appendChild(ic);
    }
    // Alive counter
    const acEl=document.getElementById('ac-val');
    if(acEl){const alive=GS.bots.filter(b=>b.alive).length+(p.alive?1:0);acEl.textContent=alive;}
