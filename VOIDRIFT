// ─── CONNECTION SEQUENCE ──────────────────────────────────────────────────────
const CONN_MESSAGES=['Initializing warp drive...','Calculating jump coordinates...','Charging hyperdrive capacitors...','Scanning sector for hostiles...','Deploying combat systems...','Entering battle zone...'];
const CONN_MODE_LABELS={battleroyal:'BATTLE ROYAL SECTOR',teams:'TEAMS SECTOR',takeover:'TAKEOVER ZONE'};

function runConnectionSequence(onDone){
  const sysName=SYSTEMS[Math.floor(Math.random()*SYSTEMS.length)];
  currentSystemName=sysName;
  document.getElementById('enter-screen').classList.add('hidden');
  document.getElementById('connecting-screen').classList.remove('hidden');
  document.getElementById('conn-system-name').textContent=sysName;
  document.getElementById('conn-mode-label').textContent=CONN_MODE_LABELS[gameMode]||'SECTOR';
  document.getElementById('conn-log').innerHTML='';
  document.getElementById('conn-bar').style.width='0%';
  let step=0;
  const totalSteps=CONN_MESSAGES.length;
  function nextStep(){
    if(step>=totalSteps){document.getElementById('conn-bar').style.width='100%';setTimeout(onDone,500);return;}
    const log=document.getElementById('conn-log');
    const line=document.createElement('div');line.className='conn-line';
    const icon=document.createElement('span');icon.className='spin';icon.textContent='◌';
    const txt=document.createElement('span');txt.textContent=CONN_MESSAGES[step];
    line.appendChild(icon);line.appendChild(txt);log.appendChild(line);
    setTimeout(()=>line.classList.add('show'),20);
    document.getElementById('conn-bar').style.width=((step+1)/totalSteps*100)+'%';
    step++;
    const holdMs=250+Math.random()*650,gapMs=50+Math.random()*100;
    setTimeout(()=>{try{icon.className='ok';icon.textContent='✓';}catch(e){}setTimeout(nextStep,gapMs);},holdMs);
  }
  setTimeout(nextStep,300);
}

// ─── SETTINGS UI ──────────────────────────────────────────────────────────────
function buildSettingsUI(){
  const list=document.getElementById('keybind-list');list.innerHTML='';let lid=null;
  for(const def of BIND_DEFS){
    const row=document.createElement('div');row.className='keybind-row';
    row.innerHTML=`<span class="keybind-label">${def.label}</span><button class="keybind-btn" data-id="${def.id}">${Binds.label(Binds.map[def.id])}</button>`;
    list.appendChild(row);
  }
  list.addEventListener('click',e=>{
    const btn=e.target.closest('.keybind-btn');if(!btn)return;
    list.querySelectorAll('.keybind-btn.listening').forEach(b=>{b.classList.remove('listening');b.textContent=Binds.label(Binds.map[b.dataset.id]);});
    btn.classList.add('listening');btn.textContent='Press a key...';lid=btn.dataset.id;
  });
  document.addEventListener('keydown',e=>{
    if(!lid)return;
    if(e.key==='Escape'){list.querySelectorAll('.keybind-btn.listening').forEach(b=>{b.classList.remove('listening');b.textContent=Binds.label(Binds.map[b.dataset.id]);});lid=null;return;}
    const conflict=Object.entries(Binds.map).find(([oid,c])=>c===e.code&&oid!==lid);
    if(conflict){Binds.map[conflict[0]]=Binds.map[lid];const cb=list.querySelector(`[data-id="${conflict[0]}"]`);if(cb)cb.textContent=Binds.label(Binds.map[conflict[0]]);}
    Binds.map[lid]=e.code;Binds.save();
    const ab=list.querySelector(`[data-id="${lid}"]`);if(ab){ab.classList.remove('listening');ab.textContent=Binds.label(e.code);}
    lid=null;e.preventDefault();
  });
  updateControlsHint();
}
function updateControlsHint(){
  const B=id=>Binds.label(Binds.map[id]);
  document.getElementById('controls-hint-display').innerHTML=`<span>${B('thrust')}</span> thrust &nbsp;·&nbsp; <span>${B('brake')}</span> brake &nbsp;·&nbsp; <span>${B('sideLeft')}/${B('sideRight')}</span> strafe &nbsp;·&nbsp; <span>${B('rotLeft')}/${B('rotRight')}</span> rotate<br><span>${B('shoot')}/LMB</span> shoot &nbsp;·&nbsp; <span>RMB</span> thrust &nbsp;·&nbsp; <span>${B('boost')}</span> boost`;
}

