    } else if(isBeta){
      // OMEGA BETA — speed hunter, swept delta + twin side blades
      // Core dart
      ctx.beginPath();ctx.moveTo(R*1.6,0);ctx.lineTo(R*.3,R*.18);ctx.lineTo(-R*1.2,R*.25);ctx.lineTo(-R*1.35,0);ctx.lineTo(-R*1.2,-R*.25);ctx.lineTo(R*.3,-R*.18);ctx.closePath();
      ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
      // Twin razor side blades
      [1,-1].forEach(s=>{
        ctx.beginPath();ctx.moveTo(R*.6,s*R*.18);ctx.lineTo(R*.9,s*R*.9);ctx.lineTo(-R*.2,s*R*1.15);ctx.lineTo(-R*.8,s*R*.8);ctx.lineTo(-R*1.2,s*R*.25);ctx.closePath();
        ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.8;ctx.stroke();
        // blade tip spikes
        ctx.shadowColor=body;ctx.shadowBlur=10;
        _edge(ctx,body,R*.9,s*R*.9,R*1.05,s*R*1.05,2.5);
        _edge(ctx,body,-R*.2,s*R*1.15,-R*.25,s*R*1.32,2.5);
        ctx.shadowBlur=0;
      });
      // Pulsing elongated cockpit
      const bg=ctx.createLinearGradient(R*1.6,0,-R*1.2,0);
      bg.addColorStop(0,'rgba(255,255,255,0.0)');bg.addColorStop(0.3,'rgba(100,220,255,0.8)');bg.addColorStop(0.6,cock);bg.addColorStop(1,'transparent');
      ctx.beginPath();ctx.ellipse(R*.25,0,R*.85,R*.13,0,0,Math.PI*2);ctx.fillStyle=bg;ctx.fill();
      // Speed streak lines
      ctx.globalAlpha=0.3;ctx.strokeStyle=body;ctx.lineWidth=0.8;
      for(let i=-1;i<=1;i++) _edge(ctx,body,R*.5,i*R*.08,-R*1.3,i*R*.08,0.7);
