        // Glowing leading edges
        ctx.shadowColor=body;ctx.shadowBlur=14;
        _edge(ctx,body,R*1.4,s*R*.25,R*1.8,s*R*.7,2.5);
        _edge(ctx,body,R*1.8,s*R*.7,R*.6,s*R*1.8,3);
        _edge(ctx,body,R*.6,s*R*1.8,-R*.5,s*R*2.1,2.5);
        ctx.shadowBlur=0;
        // Wing section markings
        ctx.globalAlpha=0.35;
        _edge(ctx,body,R*1.0,s*R*.6,R*.0,s*R*1.4,1.2);
        _edge(ctx,body,R*.2,s*R*1.6,-R*.8,s*R*1.6,1.2);
        ctx.globalAlpha=1;
      });
      // Dyson sphere rings (3 ellipses at different angles)
      ctx.globalAlpha=0.65;
      [[0,R*1.0,R*.4],[0.55,R*.88,R*.32],[-0.55,R*.88,R*.32]].forEach(([tilt,rx,ry])=>{
        ctx.beginPath();ctx.ellipse(0,0,rx,ry,tilt,0,Math.PI*2);ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
      });
      ctx.globalAlpha=1;
      // Pulsing energy core
      const ecol=`rgba(180,80,255,${0.6+0.35*Math.sin(animT*3)})`;
      const eg=ctx.createRadialGradient(0,0,0,0,0,R*.5);
      eg.addColorStop(0,'rgba(255,200,255,0.95)');eg.addColorStop(0.5,ecol);eg.addColorStop(1,'transparent');
      ctx.beginPath();ctx.arc(0,0,R*.5,0,Math.PI*2);ctx.fillStyle=eg;ctx.fill();
      // Spine glow line
      ctx.shadowColor='rgba(180,80,255,0.9)';ctx.shadowBlur=18;
      _edge(ctx,body,R*2.2,0,-R*2.2,0,2);
      ctx.shadowBlur=0;
      // Forward lance tip
      ctx.shadowColor=body;ctx.shadowBlur=14;
      _edge(ctx,body,R*2.0,0,R*2.25,0,4);
