<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VOIDRIFT</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#050810;--surface:#0a1020;--border:#1a2a4a;
  --accent:#00d4ff;--accent2:#ff4060;--green:#00ff88;--gold:#ffd700;
  --text:#c8ddf0;--dim:#4a6080;--glow:0 0 20px rgba(0,212,255,0.4);
}
html,body{width:100%;height:100%;background:var(--bg);color:var(--text);
  font-family:'Share Tech Mono',monospace;overflow:hidden;user-select:none;}
.screen{position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;transition:opacity 0.4s;}
.screen.hidden{opacity:0;pointer-events:none;}
#stars-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}

/* ── CREDIT ── */
#credit{position:fixed;top:14px;left:18px;z-index:200;
  font-size:0.62rem;color:rgba(0,180,255,0.7);letter-spacing:0.08em;
  pointer-events:none;transition:opacity 0.5s;}
#credit.hidden{opacity:0;}

/* ── ENTER ── */
#enter-screen{z-index:10;}
.logo{font-family:'Orbitron',sans-serif;font-weight:900;
  font-size:clamp(2.8rem,8vw,5.5rem);letter-spacing:0.15em;color:var(--accent);
  text-shadow:0 0 40px rgba(0,212,255,0.8),0 0 80px rgba(0,212,255,0.3);
  animation:pulse 3s ease-in-out infinite;}
.logo-offline{font-size:0.45em;letter-spacing:0.3em;color:rgba(0,212,255,0.45);vertical-align:middle;font-weight:400;}
.logo-sub{font-size:0.7rem;letter-spacing:0.4em;color:var(--dim);
  margin-top:0.3em;margin-bottom:2.5rem;text-transform:uppercase;}
@keyframes pulse{0%,100%{text-shadow:0 0 40px rgba(0,212,255,0.8),0 0 80px rgba(0,212,255,0.3);}50%{text-shadow:0 0 70px rgba(0,212,255,1),0 0 130px rgba(0,212,255,0.5);}}
.enter-card{background:rgba(6,10,22,0.93);border:1px solid var(--border);
  border-top:2px solid var(--accent);padding:2.2rem 2.8rem;width:min(500px,95vw);
  display:flex;flex-direction:column;gap:1rem;
  box-shadow:0 0 80px rgba(0,212,255,0.06),inset 0 1px 0 rgba(0,212,255,0.08);}
.field-label{font-size:0.62rem;letter-spacing:0.25em;color:var(--dim);text-transform:uppercase;margin-bottom:0.3rem;}
.field-hint{font-size:0.58rem;color:var(--dim);margin-top:0.25rem;min-height:1em;}
.field-hint.err{color:var(--accent2);}
.field-hint.ok{color:var(--green);}
.row-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.8rem;}
input[type="text"],input[type="number"]{width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--border);
  border-bottom:2px solid var(--accent);color:var(--accent);
  font-family:'Share Tech Mono',monospace;font-size:0.95rem;padding:0.5rem 0.7rem;
  outline:none;transition:box-shadow 0.2s;caret-color:var(--accent);}
input[type="text"]:focus,input[type="number"]:focus{box-shadow:var(--glow);}
input[type="text"]::placeholder,input[type="number"]::placeholder{color:var(--dim);}
input[type="text"].invalid{border-bottom-color:var(--accent2);}
input[type="number"]{-moz-appearance:textfield;}
input[type="number"]::-webkit-outer-spin-button,input[type="number"]::-webkit-inner-spin-button{-webkit-appearance:none;}
.mode-row{display:flex;gap:0.6rem;}
.mode-btn{flex:1;font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.7rem;
  letter-spacing:0.12em;text-transform:uppercase;padding:0.6rem 0.5rem;
  background:transparent;border:1px solid var(--border);color:var(--dim);
  cursor:pointer;transition:all 0.2s;}
.mode-btn.active{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,0.07);}
.mode-btn:hover{border-color:var(--accent);color:var(--accent);}
.team-config{display:flex;flex-direction:column;gap:0.6rem;}
.team-config.hidden-cfg{display:none;}
.btn-row{display:flex;gap:0.8rem;}
.btn-primary{font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.82rem;
  letter-spacing:0.18em;text-transform:uppercase;padding:0.8rem 1.6rem;
  background:transparent;border:1px solid var(--accent);color:var(--accent);
  cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden;flex:1;}
.btn-primary::before{content:'';position:absolute;inset:0;background:var(--accent);
  transform:scaleX(0);transform-origin:left;transition:transform 0.2s;z-index:-1;}
.btn-primary:hover{color:var(--bg);box-shadow:var(--glow);}
.btn-primary:hover::before{transform:scaleX(1);}
.btn-primary:disabled{opacity:0.4;cursor:not-allowed;}
.btn-primary:disabled:hover{color:var(--accent);}
.btn-primary:disabled:hover::before{transform:scaleX(0);}
.btn-secondary{font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.82rem;
  letter-spacing:0.18em;text-transform:uppercase;padding:0.8rem 1.2rem;
  background:transparent;border:1px solid var(--dim);color:var(--dim);cursor:pointer;transition:all 0.2s;}
.btn-secondary:hover{border-color:var(--accent);color:var(--accent);}
.status-line{font-size:0.68rem;color:var(--dim);text-align:center;min-height:1em;}
.controls-hint-txt{font-size:0.57rem;color:var(--dim);text-align:center;line-height:2;
  border-top:1px solid var(--border);padding-top:0.75rem;}
.controls-hint-txt span{color:rgba(0,212,255,0.75);}

/* ── CONNECTING SCREEN ── */
#connecting-screen{z-index:15;}
.conn-box{display:flex;flex-direction:column;align-items:center;gap:1.2rem;text-align:center;}
.conn-system{font-family:'Orbitron',sans-serif;font-weight:900;
  font-size:clamp(1.8rem,5vw,3.2rem);letter-spacing:0.15em;color:var(--accent);
  text-shadow:0 0 30px rgba(0,212,255,0.7);}
.conn-subtitle{font-size:0.7rem;letter-spacing:0.35em;color:var(--dim);text-transform:uppercase;}
.conn-log{width:min(480px,90vw);text-align:left;font-size:0.68rem;color:var(--dim);
  display:flex;flex-direction:column;gap:0.3rem;margin-top:0.5rem;}
.conn-line{display:flex;align-items:center;gap:0.6rem;opacity:0;transition:opacity 0.3s;}
.conn-line.show{opacity:1;}
.conn-line .ok{color:var(--green);}
.conn-line .spin{display:inline-block;animation:spin .6s linear infinite;color:var(--accent);}
@keyframes spin{to{transform:rotate(360deg)}}
.conn-bar-wrap{width:min(400px,80vw);height:4px;background:rgba(255,255,255,0.07);
  border:1px solid var(--border);margin-top:0.5rem;}
.conn-bar{height:100%;background:var(--accent);width:0%;transition:width 0.3s ease;}

/* ── SETTINGS ── */
#settings-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.78);
  z-index:100;display:flex;align-items:center;justify-content:center;-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);}
#settings-overlay.hidden{display:none;}
.settings-panel{background:rgba(6,10,22,0.98);border:1px solid var(--border);
  border-top:2px solid var(--accent);width:min(560px,95vw);max-height:88vh;
  overflow-y:auto;padding:2rem;}
.settings-panel h2{font-family:'Orbitron',sans-serif;font-size:0.95rem;
  letter-spacing:0.2em;color:var(--accent);margin-bottom:1.5rem;}
.settings-section{margin-bottom:1.5rem;}
.settings-section h3{font-size:0.6rem;letter-spacing:0.25em;color:var(--dim);
  text-transform:uppercase;margin-bottom:0.75rem;border-bottom:1px solid var(--border);padding-bottom:0.35rem;}
.keybind-row{display:flex;align-items:center;justify-content:space-between;
  padding:0.38rem 0;border-bottom:1px solid rgba(255,255,255,0.04);}
.keybind-label{font-size:0.68rem;color:var(--text);}
.keybind-btn{font-family:'Share Tech Mono',monospace;font-size:0.65rem;
  background:rgba(0,0,0,0.4);border:1px solid var(--border);color:var(--accent);
  padding:0.28rem 0.75rem;cursor:pointer;min-width:95px;text-align:center;transition:border-color 0.2s;}
.keybind-btn:hover{border-color:var(--accent);}
.keybind-btn.listening{border-color:var(--accent2);color:var(--accent2);animation:blink .6s step-end infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.25}}
.toggle-row{display:flex;align-items:center;justify-content:space-between;
  padding:0.45rem 0;border-bottom:1px solid rgba(255,255,255,0.04);}
.toggle-label{font-size:0.68rem;color:var(--text);}
.toggle{position:relative;width:40px;height:20px;cursor:pointer;}
.toggle input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;inset:0;background:var(--border);border-radius:20px;transition:background 0.2s;}
.toggle-slider::before{content:'';position:absolute;width:14px;height:14px;left:3px;top:3px;background:var(--dim);border-radius:50%;transition:transform 0.2s,background 0.2s;}
.toggle input:checked+.toggle-slider{background:rgba(0,212,255,0.28);}
.toggle input:checked+.toggle-slider::before{transform:translateX(20px);background:var(--accent);}

/* ── ESC MENU ── */
#esc-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.72);
  z-index:50;display:flex;align-items:center;justify-content:center;-webkit-backdrop-filter:blur(3px);backdrop-filter:blur(3px);}
#esc-overlay.hidden{display:none;}
.esc-panel{background:rgba(6,10,22,0.97);border:1px solid var(--border);
  border-top:2px solid var(--accent);padding:2.5rem 3rem;
  display:flex;flex-direction:column;gap:0.9rem;width:min(320px,92vw);align-items:stretch;}
.esc-title{font-family:'Orbitron',sans-serif;font-size:1.1rem;letter-spacing:0.25em;
  color:var(--accent);text-align:center;margin-bottom:0.5rem;}
.esc-resume-btn{font-family:'Orbitron',sans-serif;font-weight:700;font-size:0.82rem;
  letter-spacing:0.18em;text-transform:uppercase;padding:0.65rem 1.6rem;
  background:transparent;border:1px solid var(--dim);color:var(--dim);
  cursor:pointer;transition:all 0.2s;text-align:center;}
.esc-resume-btn:hover{border-color:var(--accent);color:var(--accent);}

/* ── GAME ── */
#game-screen{z-index:1;}
#game-canvas{display:block;cursor:none;}

/* ── HUD ── */
#hud{position:fixed;inset:0;z-index:5;pointer-events:none;}
#status-bars-wrap{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);
  display:flex;gap:20px;align-items:flex-end;}
.stat-bar-col{display:flex;flex-direction:column;align-items:center;gap:4px;width:160px;}
.stat-bar-label{font-size:0.55rem;letter-spacing:0.2em;color:var(--dim);text-transform:uppercase;}
.stat-bar-bg{width:100%;height:7px;background:rgba(255,255,255,0.07);border:1px solid var(--border);}
.stat-bar-bg div{height:100%;transition:width 0.12s,background 0.3s;}
.stat-bar-text{font-size:0.72rem;color:var(--text);}
#hp-bar{background:var(--green);}
#boost-bar{background:#ffcc00;}
#team-bar-wrap{position:absolute;top:24px;left:50%;transform:translateX(-50%);
  display:flex;gap:16px;align-items:center;pointer-events:none;}
.team-count-box{background:rgba(5,8,16,0.8);border:1px solid var(--border);
  padding:5px 14px;font-size:0.68rem;display:flex;flex-direction:column;align-items:center;gap:2px;}
.team-count-box .tc-label{font-size:0.52rem;letter-spacing:0.2em;color:var(--dim);text-transform:uppercase;}
.team-count-box .tc-val{font-family:'Orbitron',sans-serif;font-size:1.1rem;font-weight:700;}
.team-count-box.ally .tc-val{color:var(--green);}
.team-count-box.enemy .tc-val{color:var(--accent2);}
#mini-map{position:absolute;bottom:24px;right:24px;width:160px;height:160px;
  border:1px solid var(--border);background:rgba(5,8,16,0.85);}
#scoreboard{position:absolute;top:24px;right:24px;width:190px;
  background:rgba(5,8,16,0.78);border:1px solid var(--border);
  border-top:2px solid var(--accent);padding:0.8rem;font-size:0.68rem;}
#scoreboard h3{font-family:'Orbitron',sans-serif;font-size:0.58rem;letter-spacing:0.2em;
  color:var(--accent);margin-bottom:0.6rem;text-transform:uppercase;}
.score-row{display:flex;justify-content:space-between;padding:2px 0;
  border-bottom:1px solid rgba(255,255,255,0.04);color:var(--text);}
.score-row .sname{max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.score-row.player-row{color:var(--accent);}
.score-row.ally-row{color:var(--green);}
.score-row.enemy-row{color:var(--accent2);}
#kill-feed{position:absolute;top:70px;left:24px;width:290px;
  display:flex;flex-direction:column;gap:4px;pointer-events:none;}
.kill-entry{background:rgba(5,8,16,0.82);border-left:2px solid var(--accent2);
  padding:4px 8px;font-size:0.66rem;
  animation:fadeSlide 0.3s ease,fadeOut 0.5s ease 3.5s forwards;}
@keyframes fadeSlide{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeOut{to{opacity:0}}
#coords{position:absolute;bottom:24px;left:24px;font-size:0.62rem;color:var(--dim);}
#border-warning{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  font-family:'Orbitron',sans-serif;font-size:0.7rem;letter-spacing:0.2em;
  color:var(--accent2);pointer-events:none;opacity:0;transition:opacity 0.3s;text-align:center;}
#border-warning.hw{opacity:1;}
#alive-counter{position:absolute;top:24px;left:24px;
  background:rgba(5,8,16,0.8);border:1px solid var(--border);
  padding:5px 12px;font-size:0.7rem;display:flex;flex-direction:column;gap:1px;}
#alive-counter .ac-label{font-size:0.52rem;letter-spacing:0.2em;color:var(--dim);text-transform:uppercase;}
#alive-counter .ac-val{font-family:'Orbitron',sans-serif;font-size:1.2rem;color:var(--text);}

/* ── WIN / LOSE ── */
#end-screen{z-index:25;background:rgba(5,8,16,0.92);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);}
.end-title{font-family:'Orbitron',sans-serif;font-weight:900;
  font-size:clamp(2.5rem,7vw,5rem);letter-spacing:0.1em;margin-bottom:0.4rem;
  animation:endPulse 1.2s ease-in-out infinite;}
.end-title.win{color:var(--gold);text-shadow:0 0 40px rgba(255,215,0,0.8);}
.end-title.lose{color:var(--accent2);text-shadow:0 0 40px rgba(255,64,96,0.7);}
@keyframes endPulse{0%,100%{opacity:1}50%{opacity:0.75}}
.end-sub{font-size:0.72rem;letter-spacing:0.25em;color:var(--dim);margin-bottom:2.5rem;text-transform:uppercase;}
.end-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;
  margin-bottom:2.5rem;text-align:center;width:min(480px,90vw);}
.stat-box{border:1px solid var(--border);padding:1rem;background:rgba(10,16,32,0.7);}
.stat-val{font-family:'Orbitron',sans-serif;font-size:1.8rem;font-weight:700;color:var(--accent);display:block;}
.stat-lbl{font-size:0.58rem;letter-spacing:0.2em;color:var(--dim);text-transform:uppercase;margin-top:0.2rem;}
.end-system{font-size:0.65rem;color:var(--dim);margin-bottom:1.8rem;}
.end-system span{color:var(--accent);}

/* ── RESPAWN ── */
#respawn-screen{z-index:20;background:rgba(5,8,16,0.88);-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);}
.death-title{font-family:'Orbitron',sans-serif;font-weight:900;
  font-size:clamp(2.5rem,6vw,4.5rem);color:var(--accent2);
  text-shadow:0 0 40px rgba(255,64,96,0.7);letter-spacing:0.1em;margin-bottom:0.5rem;
  animation:deathPulse 1s ease-in-out infinite;}
@keyframes deathPulse{0%,100%{text-shadow:0 0 40px rgba(255,64,96,0.7)}50%{text-shadow:0 0 80px rgba(255,64,96,1)}}
.death-sub{color:var(--dim);font-size:0.73rem;letter-spacing:0.2em;margin-bottom:2rem;}
.death-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-bottom:2rem;text-align:center;width:min(420px,90vw);}
.killed-by{font-size:0.73rem;color:var(--dim);margin-bottom:1.5rem;min-height:1.2em;}
.killed-by span{color:var(--accent2);}

/* ═══════════════════════════════════════════════════════════
   SIDEBARS — left: news column  |  right: ad column
   Width = 12vw (scales with screen, ~156px on 1280px wide,
   ~130px on 1080px — fits 13-inch Chromebook at 1366×768).
   Min 110px, max 200px so it never gets silly on huge screens.
   Sidebars slide off-screen when game starts (transform:
   translateX) and slide back when returning to menu.
   ═══════════════════════════════════════════════════════════ */

:root {
  --sb-width: clamp(200px, 18vw, 280px);
  --sb-top: 80px; /* sidebar starts below the title area */
}

/* Sidebar column base */
.sidebar {
  position: fixed;
  top: var(--sb-top);
  width: var(--sb-width);
  height: calc(100vh - var(--sb-top));
  z-index: 300;
  background: rgba(4, 8, 18, 0.97);
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1),
              opacity   0.45s ease;
}
#sidebar-left  {
  left: 0;
  border-right: 1px solid rgba(0,212,255,0.28);
  transform: translateX(0);
}
#sidebar-right {
  right: 0;
  border-left: 1px solid rgba(0,212,255,0.28);
  transform: translateX(0);
}
/* Hidden state — slid fully off screen */
#sidebar-left.sb-hidden  { transform: translateX(-100%); opacity: 0.3; }
#sidebar-right.sb-hidden { transform: translateX(100%);  opacity: 0.3; }

/* Top and bottom accent bars */
.sidebar::before,
.sidebar::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(0,212,255,0.55) 30%,
    rgba(0,212,255,1)    50%,
    rgba(0,212,255,0.55) 70%,
    transparent 100%);
  z-index: 2;
}
.sidebar::before { top: 0; }
.sidebar::after  { bottom: 0; }

/* Animated travelling glow along the inner edge */
.sidebar-glow {
  position: absolute;
  top: 0;
  width: 2px;
  height: 180px;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(0,212,255,0.0)  8%,
    rgba(0,212,255,0.95) 50%,
    rgba(0,212,255,0.0)  92%,
    transparent 100%
  );
  filter: blur(3px);
  animation: glowTravel 3.2s linear infinite;
  pointer-events: none;
  z-index: 2;
}
#sidebar-left  .sidebar-glow { right: 0; }
#sidebar-right .sidebar-glow { left:  0; }
#sidebar-right .sidebar-glow { animation-delay: -1.6s; }

@keyframes glowTravel {
  0%   { top: -180px; opacity: 0.6; }
  10%  { opacity: 1; }
  90%  { opacity: 1; }
  100% { top: calc(100vh + 20px); opacity: 0.6; }
}

/* Decorative vertical trace lines */
.sidebar-lines {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.sidebar-lines::before {
  content: '';
  position: absolute;
  top: 80px; bottom: 80px;
  left: 50%; width: 1px;
  transform: translateX(-50%);
  background: rgba(0,212,255,0.06);
}
.sidebar-lines::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  left: 22%; width: 1px;
  background: rgba(0,212,255,0.04);
}

/* Header strip */
.sidebar-header {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 16px 8px 12px;
  text-align: center;
  border-bottom: 1px solid rgba(0,212,255,0.18);
  background: rgba(0,212,255,0.04);
  flex-shrink: 0;
}
.sidebar-header-title {
  font-family: 'Orbitron', sans-serif;
  font-weight: 700;
  font-size: clamp(0.42rem, 0.8vw, 0.62rem);
  letter-spacing: 0.22em;
  color: rgba(0,212,255,0.8);
  text-transform: uppercase;
  text-shadow: 0 0 10px rgba(0,212,255,0.45);
  word-break: break-all;
}
.sidebar-header-dots {
  margin-top: 7px;
  display: flex;
  justify-content: center;
  gap: 5px;
}
.sidebar-header-dots span {
  display: inline-block;
  width: 4px; height: 4px;
  background: rgba(0,212,255,0.55);
  border-radius: 50%;
}
.sidebar-header-dots span:nth-child(2) { opacity: 0.35; }
.sidebar-header-dots span:nth-child(3) { opacity: 0.15; }

/* Content area */
.sidebar-content {
  position: relative;
  z-index: 1;
  width: 100%;
  flex: 1;
  padding: 14px 10px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  overflow-y: auto;
  scrollbar-width: none;
}
.sidebar-content::-webkit-scrollbar { display: none; }

/* Slot box */
.sidebar-slot {
  width: 100%;
  min-height: 100px;
  border: 1px solid rgba(0,212,255,0.14);
  background: rgba(0,212,255,0.03);
