// ─── LEVEL UP ─────────────────────────────────────────────────────────────────
function checkLevelUp(ship){
  // Don't auto-upgrade omega variants (8/9)
  if(ship.level>=8) return;
  // Don't re-trigger omega picker if already pending
  if(ship._pendingOmega) return;

  let newLevel=ship.level;
  // Only check up to level 7 (index 7) from LEVELS — 8/9 are omega variants
  for(let i=7;i>=0;i--){
    if(ship.score>=LEVELS[i].pts){ newLevel=i; break; }
  }
  if(newLevel<=ship.level) return;

  ship.level=newLevel;
  const lv=LEVELS[newLevel];
  const hpRatio=ship.hp/ship.maxHp;
  ship.maxHp=lv.maxHp;
  ship.hp=Math.min(ship.maxHp,ship.maxHp*hpRatio+20);

  if(ship.isPlayer){
    if(newLevel===7){
      showOmegaPicker(ship);
      ship.level=6; // hold at dreadnought until variant chosen
    } else {
      flashUpgrade(lv.desc,newLevel+1);
    }
  } else {
    // Bot auto-picks omega variant randomly
    if(newLevel===7){
      ship.level=Math.random()<0.5?8:9;
      const lv2=LEVELS[ship.level];
      ship.maxHp=lv2.maxHp;
      ship.hp=Math.min(ship.maxHp,ship.hp+80);
    }
  }
}

function flashUpgrade(desc,lv){
  const el=document.getElementById('upgrade-flash');
  el.innerHTML=`LEVEL ${lv}<br><span style="font-size:0.6em;color:#adf">${desc}</span>`;
  el.classList.remove('show');
  void el.offsetWidth;
  el.classList.add('show');
}

function showOmegaPicker(ship){
  const el=document.getElementById('omega-picker');
  if(el){el.style.display='flex';}
  // Pause shooting but not movement
  ship._pendingOmega=true;
}
function selectOmega(ship,variant){
  // variant: 8=alpha, 9=beta
  ship.level=variant;
  const lv=LEVELS[variant];
  ship.maxHp=lv.maxHp;
  ship.hp=Math.min(ship.maxHp,ship.hp+80);
  ship._pendingOmega=false;
  const el=document.getElementById('omega-picker');
  if(el)el.style.display='none';
  flashUpgrade(lv.desc,8);
}

// ─── BULLET SPAWN ─────────────────────────────────────────────────────────────
function spawnBullets(owner){
  const lv=LEVELS[Math.min(owner.level||0,LEVELS.length-1)];
  const mode=lv.bulletMode;
  const R=CFG.PLAYER_RADIUS;
  const tip=R+4;

  function mkBullet(ax,ay,angle,dmgOverride,radOverride,lvOverride){
    const bdmg=dmgOverride??lv.bulletDmg;
    const brad=radOverride??lv.bulletR;
    const blv=lvOverride??owner.level??0;
    GS.bullets.push({
      id:nextId++,ownerId:owner.id,ownerTeam:owner.team??-1,
      x:ax,y:ay,
      vx:Math.cos(angle)*CFG.BULLET_SPEED+owner.vx*.3,
      vy:Math.sin(angle)*CFG.BULLET_SPEED+owner.vy*.3,
      lifetime:CFG.BULLET_LIFETIME,
      dmg:bdmg, radius:brad, level:blv,
    });
    // Pushback — larger bullets push the shooter back
    const pushForce=brad*2.2;
    owner.vx-=Math.cos(angle)*pushForce;
    owner.vy-=Math.sin(angle)*pushForce;
  }

  const cx=owner.x+Math.cos(owner.angle)*tip;
  const cy=owner.y+Math.sin(owner.angle)*tip;
  const a=owner.angle;
  const perp=a+Math.PI/2;

  if(mode==='single'){
    mkBullet(cx,cy,a);

  } else if(mode==='double'){
    const off=7;
    mkBullet(cx+Math.cos(perp)*off,cy+Math.sin(perp)*off,a);
    mkBullet(cx-Math.cos(perp)*off,cy-Math.sin(perp)*off,a);

  } else if(mode==='heavy'){
    mkBullet(cx,cy,a);

  } else if(mode==='triple'){
    mkBullet(cx,cy,a);
    mkBullet(cx,cy,a+0.18);
    mkBullet(cx,cy,a-0.18);

  } else if(mode==='burst'){
    for(let i=0;i<3;i++) setTimeout(()=>{
      if(!owner.alive)return;
      mkBullet(owner.x+Math.cos(owner.angle)*tip,owner.y+Math.sin(owner.angle)*tip,owner.angle);
    },i*60);

  } else if(mode==='spread'){
    for(let i=-2;i<=2;i++) mkBullet(cx,cy,a+i*0.12);

  } else if(mode==='plasma'){
    mkBullet(cx,cy,a);

  } else if(mode==='nova'){
    // LV7 base omega placeholder — big single + 2 rear exhaust mini-bullets at 45deg back
    mkBullet(cx,cy,a);
    const back=a+Math.PI;
    const rx=owner.x+Math.cos(back)*tip*0.7;const ry=owner.y+Math.sin(back)*tip*0.7;
    mkBullet(rx+Math.cos(perp)*10,ry+Math.sin(perp)*10,back+Math.PI/4,8,2.5,1);
    mkBullet(rx-Math.cos(perp)*10,ry-Math.sin(perp)*10,back-Math.PI/4,8,2.5,1);

  } else if(mode==='omega_alpha'){
    // ALPHA — one massive slow round
    mkBullet(cx,cy,a,lv.bulletDmg,lv.bulletR,8);
    // + 2 rear exhaust micro-bullets at 45deg
    const back=a+Math.PI;
    const rx=owner.x+Math.cos(back)*tip*0.6,ry=owner.y+Math.sin(back)*tip*0.6;
    mkBullet(rx+Math.cos(perp)*12,ry+Math.sin(perp)*12,back+Math.PI/4,6,2,7);
    mkBullet(rx-Math.cos(perp)*12,ry-Math.sin(perp)*12,back-Math.PI/4,6,2,7);

  } else if(mode==='omega_beta'){
    // BETA — 1 big front + 2 small parallel behind it
    mkBullet(cx+Math.cos(a)*8,cy+Math.sin(a)*8,a,lv.bulletDmg,lv.bulletR,9);
    const off2=9;
    mkBullet(cx+Math.cos(perp)*off2,cy+Math.sin(perp)*off2,a,Math.floor(lv.bulletDmg*.4),Math.floor(lv.bulletR*.5),9);
    mkBullet(cx-Math.cos(perp)*off2,cy-Math.sin(perp)*off2,a,Math.floor(lv.bulletDmg*.4),Math.floor(lv.bulletR*.5),9);
    // + 2 rear exhaust micro-bullets at 45deg
    const back=a+Math.PI;
    const rx=owner.x+Math.cos(back)*tip*0.6,ry=owner.y+Math.sin(back)*tip*0.6;
    mkBullet(rx+Math.cos(perp)*12,ry+Math.sin(perp)*12,back+Math.PI/4,6,2,7);
    mkBullet(rx-Math.cos(perp)*12,ry-Math.sin(perp)*12,back-Math.PI/4,6,2,7);
  }
}

// ─── INPUT ────────────────────────────────────────────────────────────────────
const Input={
  keys:{up:false,down:false,shoot:false,sideLeft:false,sideRight:false,boost:false},
  mouseAngle:0,mouseX:innerWidth/2,mouseY:innerHeight/2,
  arrowLeft:false,arrowRight:false,
  init(){
    window.addEventListener('keydown',e=>this._down(e));
    window.addEventListener('keyup',e=>this._up(e));
    window.addEventListener('mousemove',e=>{this.mouseX=e.clientX;this.mouseY=e.clientY;});
    window.addEventListener('mousedown',e=>{if(!gameRunning)return;if(e.button===0)this.keys.shoot=true;if(e.button===2)this.keys.up=true;});
    window.addEventListener('mouseup',e=>{if(e.button===0)this.keys.shoot=false;if(e.button===2)this.keys.up=false;});
    window.addEventListener('contextmenu',e=>{if(gameRunning)e.preventDefault();});
  },
  _down(e){
    if(!document.getElementById('settings-overlay').classList.contains('hidden'))return;
    if(!document.getElementById('esc-overlay').classList.contains('hidden')){if(Binds.idFor(e.code)==='escMenu'){EscMenu.close();e.preventDefault();}return;}
    if(gameRunning&&Binds.idFor(e.code)==='escMenu'){EscMenu.open();e.preventDefault();return;}
    // Bomb drop — R key
    if(gameRunning&&Binds.idFor(e.code)==='bomb'&&GS.player&&GS.player.alive&&!GS.over){
      if(playerBombCd<=0){
        GS.bombs.push({id:nextId++,x:GS.player.x,y:GS.player.y,timer:10,age:0,radius:22,ownerId:GS.player.id});
        playerBombCd=30;
      }
      e.preventDefault();
      return;
    }
    // Dev mode shortcuts
    if(devMode&&gameRunning&&GS.player&&!GS.over){
      if(e.code==='KeyP'){
        GS.score+=100;GS.player.score+=100;checkLevelUp(GS.player);
        UI.updateHUD();e.preventDefault();return;
      }
      if(e.code==='KeyX'){
        GS.bots.forEach(b=>{b.alive=false;b._ai.respawnTimer=999999;});
        UI.addKillFeed('[DEV]','ALL BOTS');e.preventDefault();return;
      }
    }
    this._apply(e.code,true,e);
  },
  _up(e){this._apply(e.code,false,e);},
  _apply(code,val,e){
    const id=Binds.idFor(code);if(!id)return;
    switch(id){
      case 'thrust':   this.keys.up=val;break;
      case 'brake':    this.keys.down=val;break;
      case 'sideLeft': this.keys.sideLeft=val;break;
      case 'sideRight':this.keys.sideRight=val;break;
      case 'rotLeft':  this.arrowLeft=val;if(val)e?.preventDefault();break;
      case 'rotRight': this.arrowRight=val;if(val)e?.preventDefault();break;
      case 'shoot':    this.keys.shoot=val;if(val)e?.preventDefault();break;
      case 'boost':    this.keys.boost=val;break;
    }
  },
  updateMouseAngle(){
    if(!Render.canvas)return;
    const W=Render.canvas.width,H=Render.canvas.height;
    if(!this.arrowLeft&&!this.arrowRight) this.mouseAngle=Math.atan2(this.mouseY-H/2,this.mouseX-W/2);
  },
};

// ─── PHYSICS / GAME TICK ──────────────────────────────────────────────────────
let lastTickTime=0;

function tickGame(now){
  if(!gameRunning||GS.over)return;
  const dt=Math.min((now-lastTickTime)/1000,.05);
  lastTickTime=now;
  const nowSec=now/1000;
  const p=GS.player;
  if(!p)return;

  const allShips=[p,...GS.bots];

  // ── PLAYER ──────────────────────────────────────────────────────────────
  if(p.alive){
    if(p.invuln>0) p.invuln-=dt;

    // Rotation
    if(this.arrowLeft||this.arrowRight){
      // handled below
    }
    if(Input.arrowLeft||Input.arrowRight){
      const dir=(Input.arrowRight?1:0)+(Input.arrowLeft?-1:0);
      p.angle+=dir*Math.PI*4*dt;p.angle=((p.angle+Math.PI)%(Math.PI*2))-Math.PI;
      Input.mouseAngle=p.angle;
    } else {
      // Omega Alpha: cap mouse turn speed to 720 deg/s = 4π rad/s
      if(p.level===8){
        const maxTurn=Math.PI*4*dt;
        const diff=angleDiff(p.angle,Input.mouseAngle);
        const step=Math.sign(diff)*Math.min(Math.abs(diff),maxTurn);
        p.angle+=step;p.angle=((p.angle+Math.PI)%(Math.PI*2))-Math.PI;
      } else p.angle=Input.mouseAngle;
    }

    const wantBoost=Input.keys.boost&&p.boostFuel>0;
    p.boosting=wantBoost;
    if(wantBoost){p.boostFuel=Math.max(0,p.boostFuel-CFG.BOOST_DRAIN*dt);p.boostRechargeTimer=CFG.BOOST_RECHARGE_DELAY;}
    else{if(p.boostRechargeTimer>0)p.boostRechargeTimer-=dt;else p.boostFuel=Math.min(CFG.BOOST_MAX,p.boostFuel+CFG.BOOST_RECHARGE*dt);}

    const bm=wantBoost?CFG.BOOST_SPEED_MULT:1;
    const betaBoost=p.level===9?1.35:1.0;
    const effSpd=CFG.PLAYER_SPEED*bm*betaBoost;

    if(Input.keys.up){p.vx+=Math.cos(p.angle)*effSpd*dt*2.5;p.vy+=Math.sin(p.angle)*effSpd*dt*2.5;Particles.emitThrust(p,wantBoost);}
    if(Input.keys.sideLeft||Input.keys.sideRight){const dir=Input.keys.sideRight?1:-1;p.vx+=(-Math.sin(p.angle))*dir*CFG.SIDE_THRUST_SPEED*dt*4;p.vy+=(Math.cos(p.angle))*dir*CFG.SIDE_THRUST_SPEED*dt*4;Particles.emitSide(p,dir);}
    const drag=Input.keys.down?0.88:0.97;
    const fd=Math.pow(drag,dt*60);if(!isNaN(fd)){p.vx*=fd;p.vy*=fd;}
    const spd=Math.hypot(p.vx,p.vy);if(spd>effSpd){p.vx=p.vx/spd*effSpd;p.vy=p.vy/spd*effSpd;}

    // Map border — mode-dependent
    let nx=p.x+p.vx*dt, ny=p.y+p.vy*dt;
    const M=CFG.MAP_SIZE;
    // Always tick down border cooldown
    if(GS.borderCrossTimer>0) GS.borderCrossTimer=Math.max(0,GS.borderCrossTimer-dt);
    if(gameMode==='takeover'){
      // Hard walls — no crossing at all
      if(nx<CFG.PLAYER_RADIUS){nx=CFG.PLAYER_RADIUS;p.vx=Math.abs(p.vx)*0.3;}
      if(nx>M-CFG.PLAYER_RADIUS){nx=M-CFG.PLAYER_RADIUS;p.vx=-Math.abs(p.vx)*0.3;}
      if(ny<CFG.PLAYER_RADIUS){ny=CFG.PLAYER_RADIUS;p.vy=Math.abs(p.vy)*0.3;}
      if(ny>M-CFG.PLAYER_RADIUS){ny=M-CFG.PLAYER_RADIUS;p.vy=-Math.abs(p.vy)*0.3;}
      p.x=nx;p.y=ny;
    } else if(gameMode==='ffa'){
      // FFA: free wrap, no cooldown ever
      p.x=((nx%M)+M)%M; p.y=((ny%M)+M)%M;
    } else {
      // BR and Teams: wrap allowed only when cooldown is 0
      const atEdgeX=(nx<0||nx>=M);
      const atEdgeY=(ny<0||ny>=M);
      const crossed=atEdgeX||atEdgeY;
      if(crossed&&GS.borderCrossTimer<=0){
        // Wrap and start cooldown
        p.x=((nx%M)+M)%M;p.y=((ny%M)+M)%M;
        GS.borderCrossTimer=CFG.BORDER_CROSS_COOLDOWN;
      } else if(crossed&&GS.borderCrossTimer>0){
        // Blocked by cooldown — push back hard
        if(atEdgeX){p.vx*=-0.5;nx=Math.max(CFG.PLAYER_RADIUS,Math.min(M-CFG.PLAYER_RADIUS,p.x));}
        if(atEdgeY){p.vy*=-0.5;ny=Math.max(CFG.PLAYER_RADIUS,Math.min(M-CFG.PLAYER_RADIUS,p.y));}
        p.x=Math.max(0,Math.min(M,nx));p.y=Math.max(0,Math.min(M,ny));
      } else {
        p.x=nx;p.y=ny;
      }
    }

    // Regen
    if(p.hp<p.maxHp&&(nowSec-p.lastDamageTime)>=CFG.REGEN_DELAY)
      p.hp=Math.min(p.maxHp,p.hp+CFG.REGEN_RATE*dt);

    // Shooting — cooldown-gated, no edge-trigger (works while moving)
    const lv=LEVELS[Math.min(p.level||0,LEVELS.length-1)];
    if(p.shootCooldown>0) p.shootCooldown-=dt;
    if(Input.keys.shoot&&p.shootCooldown<=0&&p.ammo>0&&!p._pendingOmega){
      spawnBullets(p);
      p.ammo=Math.max(0,p.ammo-1);
      p.shootCooldown=lv.shootCd;
    }

    // Level up check
    checkLevelUp(p);
  } else {
    if(deathLingerTimer>0){deathLingerTimer-=dt;if(deathLingerTimer<=0)UI.showRespawnScreen();}
  }

  // ── BOTS ────────────────────────────────────────────────────────────────
  for(const bot of GS.bots){
    if(!bot.alive){
      if(bot.lives===undefined) bot.lives=Infinity;
      if(bot.lives>0){
        bot._ai.respawnTimer-=dt;
        if(bot._ai.respawnTimer<=0){
          const rp=randPos(300);bot.x=rp.x;bot.y=rp.y;bot.vx=0;bot.vy=0;
          bot.hp=bot.maxHp;bot.alive=true;bot.invuln=CFG.RESPAWN_INVULN;
          bot.shootCooldown=0;bot.lastDamageTime=-999;
          bot._ai.state='patrol';bot._ai.fleeTimer=0;
        }
      }
      continue;
    }
    tickAI(bot,allShips,p,dt,nowSec);
  }

  // ── BULLETS ─────────────────────────────────────────────────────────────
  GS.bullets=GS.bullets.filter(b=>{
    b.lifetime-=dt;if(b.lifetime<=0)return false;
    const M=CFG.MAP_SIZE;
    b.x=((b.x+b.vx*dt)%M+M)%M;
    b.y=((b.y+b.vy*dt)%M+M)%M;

    // Check ships
    for(const target of allShips){
      if(!target.alive||target.id===b.ownerId||target.invuln>0)continue;
      if(b.ownerTeam!==-1&&b.ownerTeam===target.team)continue;
      if(Math.hypot(target.x-b.x,target.y-b.y)<CFG.PLAYER_RADIUS+b.radius){
        target.hp-=b.dmg;target.lastDamageTime=nowSec;
        Particles.emitHit(b.x,b.y,'#00d4ff');
        if(target.hp<=0){
          target.hp=0;target.alive=false;
          Particles.emitExplosion(target.x,target.y);
          if(target.isPlayer){
            GS.deaths++;
            if(gameMode!=='ffa') GS.lives--;
            else{GS.lives=99;GS.score=0;p.score=0;} // FFA: infinite respawns, lose score
            deathLingerTimer=3;UI.startDeathLinger();
          } else {
            const killer=allShips.find(s=>s.id===b.ownerId);
            if(killer){
              killer.kills++;killer.score+=50;
              if(killer.isPlayer){GS.kills++;GS.score+=50;checkLevelUp(p);}
            }
            if(target.lives===undefined) target.lives=Infinity;
            if(target.lives!==Infinity) target.lives--;
            target._ai.respawnTimer=(target.lives>0)?CFG.ENEMY_RESPAWN_TIME:999999;
            UI.addKillFeed(killer?.username,target.username);
          }
          checkWinCondition();
        }
        return false;
      }
    }

    // Check enemy safes (takeover only)
    if(gameMode==='takeover'){
      for(const safe of GS.safes){
        if(safe.hp<=0) continue;
        // Only enemy team bullets damage a safe
        if(b.ownerTeam===safe.team) continue; // friendly fire on own safe blocked
        if(b.ownerTeam===-1) continue; // neutral can't damage safes
        if(Math.hypot(safe.x-b.x,safe.y-b.y)<safe.radius+b.radius){
          safe.hp=Math.max(0,safe.hp-b.dmg);
          Particles.emitHit(b.x,b.y,safe.team===0?'#00d4ff':'#ff4060');
          return false;
        }
      }
    }

    // Check asteroids — hp = pts*20, bullets chip away with b.dmg
    for(let ai=0;ai<GS.asteroids.length;ai++){
      const ast=GS.asteroids[ai];
      if(Math.hypot(ast.x-b.x,ast.y-b.y)<ast.size+b.radius){
        ast.hp-=b.dmg*1.5; // asteroids take 1.5x bullet damage
        Particles.emitAsteroidHit(b.x,b.y,ast.size);
        if(ast.hp<=0){
          const killer=allShips.find(s=>s.id===b.ownerId);
          if(killer){killer.score+=ast.pts;if(killer.isPlayer){GS.score+=ast.pts;checkLevelUp(p);}}
          // Spawn shards from high-value rocks only (pts>=10)
          if(ast.pts>=10){
            const shards=1+Math.floor(Math.random()*2);
            for(let s=0;s<shards;s++){
              const sp=Math.max(3,Math.floor(ast.pts*0.3*(0.6+Math.random()*0.8)));
              const smhp=sp*20;
              const st=(sp-3)/27;
              const ssz=CFG.PLAYER_RADIUS*(0.45+st*2.35)*(0.85+Math.random()*0.3);
              const ssides=5+Math.floor(Math.random()*4);
              const sv=[];
              for(let vi=0;vi<ssides;vi++){const va=(vi/ssides)*Math.PI*2;sv.push([Math.cos(va)*ssz*(0.72+Math.random()*0.52),Math.sin(va)*ssz*(0.72+Math.random()*0.52)]);}
              const sd=Math.random()*Math.PI*2,ss2=20+Math.random()*40;
              GS.asteroids.push({id:nextId++,x:ast.x+(Math.random()-.5)*ast.size*1.5,y:ast.y+(Math.random()-.5)*ast.size*1.5,vx:Math.cos(sd)*ss2,vy:Math.sin(sd)*ss2,rot:Math.random()*Math.PI*2,rotSpeed:(Math.random()-.5)*0.8,size:ssz,pts:sp,hp:smhp,maxHp:smhp,verts:sv,pulse:Math.random()*Math.PI*2});
            }
          }
          Particles.emitExplosion(ast.x,ast.y);
          GS.asteroids.splice(ai,1);
          setTimeout(()=>{ if(gameRunning) GS.asteroids.push(createAsteroid()); },3000+Math.random()*5000);
        }
        return false;
      }
    }

    return true;
  });

  // ── ASTEROIDS (movement + player collision) ───────────────────────────
  for(let ai=0;ai<GS.asteroids.length;ai++){
    const ast=GS.asteroids[ai];
    ast.rot+=ast.rotSpeed*dt;ast.pulse+=dt*2;
    const M=CFG.MAP_SIZE;
    ast.x=((ast.x+ast.vx*dt)%M+M)%M;
    ast.y=((ast.y+ast.vy*dt)%M+M)%M;
    // Asteroid ramming player
    if(p.alive&&p.invuln<=0&&Math.hypot(ast.x-p.x,ast.y-p.y)<ast.size+CFG.PLAYER_RADIUS){
      // Ram damage scales with pts (3-30), capped at 25% of player maxHp per hit
      const ramDmg=Math.min(p.maxHp*0.25, 5+ast.pts*1.2);
      p.hp-=ramDmg;p.lastDamageTime=nowSec;
      Particles.emitAsteroidHit(p.x,p.y,ast.size);
      const pushA=Math.atan2(p.y-ast.y,p.x-ast.x);
      p.vx+=Math.cos(pushA)*80;p.vy+=Math.sin(pushA)*80;
      if(p.hp<=0){
        p.hp=0;p.alive=false;Particles.emitExplosion(p.x,p.y);
        GS.deaths++;GS.lives--;
        deathLingerTimer=3;UI.startDeathLinger();
        checkWinCondition();
      }
    }
  }

  // ── AMMO PICKUPS ────────────────────────────────────────────────────────
  if(p.alive){
    for(let ai2=0;ai2<GS.ammoPickups.length;ai2++){
      const ap=GS.ammoPickups[ai2];if(!ap)continue;
      ap.pulse+=dt*3;
      if(Math.hypot(p.x-ap.x,p.y-ap.y)<CFG.AMMO_PICKUP_RADIUS+CFG.PLAYER_RADIUS){
        p.ammo=Math.min(CFG.AMMO_MAX,p.ammo+CFG.AMMO_PER_PICKUP);
        Particles.emitAmmoPickup(ap.x,ap.y);
        respawnAmmoPickup(ai2);
      }
    }
  }


  // ── BOMBS ───────────────────────────────────────────────────────────────
  if(playerBombCd>0) playerBombCd-=dt;
  GS.bombs=GS.bombs.filter(bm=>{
    bm.timer-=dt; bm.age+=dt;
    // Check proximity to all ships
    for(const ship of allShips){
      if(!ship.alive||ship.invuln>0) continue;
      if(Math.hypot(ship.x-bm.x,ship.y-bm.y)<bm.radius+CFG.PLAYER_RADIUS){
        ship.hp-=50; ship.lastDamageTime=nowSec;
        Particles.emitExplosion(bm.x,bm.y);
        if(ship.hp<=0){
          ship.hp=0; ship.alive=false;
          Particles.emitExplosion(ship.x,ship.y);
          if(ship.isPlayer){GS.deaths++;if(gameMode!=='ffa')GS.lives--;else{GS.lives=99;GS.score=0;p.score=0;}deathLingerTimer=3;UI.startDeathLinger();}
          else{const killer=allShips.find(s=>s.id===bm.ownerId);if(killer){killer.kills++;killer.score+=50;if(killer.isPlayer){GS.kills++;GS.score+=50;checkLevelUp(p);}}}
          checkWinCondition();
        }
        return false; // bomb consumed on hit
      }
    }
    if(bm.timer<=0){Particles.emitExplosion(bm.x,bm.y);return false;} // expired
    return true;
  });
  // ── SAFES / TAKEOVER ────────────────────────────────────────────────────
  if(gameMode==='takeover'&&GS.safes.length){
    // Score trickle: players inside their OWN safe radius earn points
    const allS=[p,...GS.bots];
    for(const safe of GS.safes){
      if(safe.hp<=0) continue;
      for(const s of allS){
        if(!s.alive) continue;
        if(s.team===safe.team&&Math.hypot(s.x-safe.x,s.y-safe.y)<safe.radius){
          s.score+=dt*1.5;
          if(s.isPlayer) GS.score=Math.floor(p.score);
        }
      }
    }
    // Win check
    const deadSafes=GS.safes.filter(s=>s.hp<=0);
    if(deadSafes.length>0){
      const destroyed=deadSafes[0];
      const winner=destroyed.team===0?1:0; // enemy team wins
      if(!GS.over){
        if(p.team===winner) endGame(true,'ENEMY BASE DESTROYED');
        else endGame(false,'YOUR BASE WAS DESTROYED');
      }
    }
  }
  UI.updateBombHUD();

  Particles.tick(dt);
  UI.updateHUD();
}

// ─── AI TICK ─────────────────────────────────────────────────────────────────
// AI decision model:
//   - Normally bots mine asteroids (best pts-per-distance ratio)
//   - When a player/enemy is within range, probability of attacking scales with closeness
//   - Close (<400): 75% attack, 25% keep mining
//   - Medium (400-800): 45% attack
//   - Far (800-1500): 15% attack
//   - Very far (>1500): ~3% — rare aggression burst from distance
//   - Once a bot commits to attacking, it sticks to that target for several seconds
function tickAI(bot,allShips,player,dt,nowSec){
  const ai=bot._ai;
  if(bot.invuln>0) bot.invuln-=dt;
  ai.stateTimer-=dt;

  // ── FLEE CHECK ───────────────────────────────────────────────────────────
  const fleeHp=bot.maxHp*0.20, fleeRecover=bot.maxHp*0.35;
  if(bot.hp<=fleeHp && ai.state!=='evade'){
    ai.state='evade';
    ai.fleeTimer=3+Math.random()*3;
    ai.combatTarget=null; // drop combat when fleeing
  }
  if(ai.state==='evade'){
    ai.fleeTimer-=dt;
    if(ai.fleeTimer<=0 && bot.hp>=fleeRecover){
      ai.state='mine'; ai.stateTimer=0; ai.combatTarget=null;
    }
  }

  // ── COMBAT TARGET STICKINESS TIMER ──────────────────────────────────────
  // Once a bot picks a combat target it commits for combatLockTimer seconds
  if(ai.combatLockTimer>0) ai.combatLockTimer-=dt;
  if(ai.combatTarget && (!ai.combatTarget.alive || ai.combatLockTimer<=0)){
    ai.combatTarget=null; ai.combatLockTimer=0;
  }

  // ── TARGET SELECTION ────────────────────────────────────────────────────
  let combatTarget=ai.combatTarget;
  let mineTarget=null;
  let goFight=false;

  if(ai.state!=='evade'){
    const enemies=allShips.filter(s=>s.alive && s.id!==bot.id && areEnemies(bot,s));

    // If already locked onto a combat target, check whether to keep it
    if(combatTarget && combatTarget.alive && ai.combatLockTimer>0){
      goFight=true;
    } else {
      // Evaluate nearest enemy and decide whether to engage
      if(enemies.length){
        enemies.sort((a,b)=>Math.hypot(a.x-bot.x,a.y-bot.y)-Math.hypot(b.x-bot.x,b.y-bot.y));
        const nearest=enemies[0];
        const distToNearest=Math.hypot(nearest.x-bot.x, nearest.y-bot.y);

        // Attack probability increases as enemy gets closer
        let attackChance;
        if(distToNearest < 400)       attackChance=0.75;
        else if(distToNearest < 700)  attackChance=0.45;
        else if(distToNearest < 1200) attackChance=0.15;
        else if(distToNearest < 2000) attackChance=0.05;
        else                          attackChance=0.02; // rare long-range aggression

        // Re-roll decision only when stateTimer expired
        if(ai.stateTimer<=0){
          ai.stateTimer=1.5+Math.random()*2; // re-evaluate every 1.5-3.5s
          if(Math.random()<attackChance){
            // Pick target: slight bias towards player
            combatTarget=(player.alive && Math.random()<0.45) ? player : nearest;
            ai.combatTarget=combatTarget;
            ai.combatLockTimer=4+Math.random()*4; // commit for 4-8s
            goFight=true;
          } else {
            combatTarget=null; ai.combatTarget=null;
          }
        } else {
          // Between re-evaluations keep previous decision
          goFight=!!ai.combatTarget;
          combatTarget=ai.combatTarget;
        }
      }
    }

    // ── ASTEROID MINING TARGET ─────────────────────────────────────────────
    if(!goFight || !combatTarget){
      // Find nearest asteroid worth mining — weight by pts/dist ratio
      if(GS.asteroids.length){
        let bestScore=-1, bestAst=null;
        const check=Math.min(GS.asteroids.length, 20); // scan up to 20 rocks
        for(let i=0;i<check;i++){
          const a=GS.asteroids[i];
          const d=Math.hypot(a.x-bot.x, a.y-bot.y);
          const score=a.pts / (d+1);
          if(score>bestScore){ bestScore=score; bestAst=a; }
        }
        mineTarget=bestAst;
      }
    }
  }

  // ── RESOLVE EFFECTIVE TARGET ─────────────────────────────────────────────
  const eff=goFight && combatTarget ? combatTarget : mineTarget;
  const dx=eff ? eff.x-bot.x : 0;
  const dy=eff ? eff.y-bot.y : 0;
  const dist=eff ? Math.hypot(dx,dy) : Infinity;
  const angleToTarget=eff ? Math.atan2(dy,dx) : bot.angle;

  let wantThrust=false, wantShoot=false, targetAngle=bot.angle;

  if(ai.state==='evade'){
    const threats=allShips.filter(s=>s.alive&&s.id!==bot.id&&areEnemies(bot,s));
    threats.sort((a,b)=>Math.hypot(a.x-bot.x,a.y-bot.y)-Math.hypot(b.x-bot.x,b.y-bot.y));
    const t=threats[0];
    const fleeAngle=t ? Math.atan2(bot.y-t.y, bot.x-t.x) : bot.angle+Math.PI;
    targetAngle=fleeAngle+(Math.random()-.5)*0.5;
    wantThrust=true;

  } else if(!eff){
    // Patrol — drift around
    if(ai.stateTimer<=0){
      ai.patrolAngle+=((Math.random()-.5)*1.8);
      ai.stateTimer=2+Math.random()*3;
    }
    targetAngle=ai.patrolAngle; wantThrust=Math.random()<0.55;

  } else if(goFight && combatTarget){
    // Attack mode
    targetAngle=angleToTarget; wantThrust=dist>180;
    if(Math.abs(angleDiff(bot.angle,angleToTarget))<0.30) wantShoot=true;

  } else {
    // Mining mode — approach and shoot at rock
    targetAngle=angleToTarget; wantThrust=dist>120;
    // Shoot at asteroid when aimed
    if(Math.abs(angleDiff(bot.angle,angleToTarget))<0.28) wantShoot=true;
  }

  // ── STEERING & MOVEMENT ──────────────────────────────────────────────────
  const steerDiff=angleDiff(bot.angle, targetAngle);
  bot.angle+=Math.sign(steerDiff)*Math.min(Math.abs(steerDiff), Math.PI*3.5*dt);
  bot.angle=((bot.angle+Math.PI)%(Math.PI*2))-Math.PI;

  if(wantThrust){
    bot.vx+=Math.cos(bot.angle)*CFG.PLAYER_SPEED*dt*2;
    bot.vy+=Math.sin(bot.angle)*CFG.PLAYER_SPEED*dt*2;
  }
  bot.vx*=0.97; bot.vy*=0.97;
  const spd=Math.hypot(bot.vx,bot.vy);
  if(spd>CFG.PLAYER_SPEED){bot.vx=bot.vx/spd*CFG.PLAYER_SPEED; bot.vy=bot.vy/spd*CFG.PLAYER_SPEED;}

  const M2=CFG.MAP_SIZE;
  bot.x=((bot.x+bot.vx*dt)%M2+M2)%M2;
  bot.y=((bot.y+bot.vy*dt)%M2+M2)%M2;

  // ── SHOOTING ─────────────────────────────────────────────────────────────
  if(bot.shootCooldown>0) bot.shootCooldown-=dt;
  if(wantShoot && bot.shootCooldown<=0){
    spawnBullets(bot);
    const blv=LEVELS[Math.min(bot.level||0, LEVELS.length-1)];
    bot.shootCooldown=blv.shootCd*(1+Math.random()*0.4);
  }

  // ── REGEN ────────────────────────────────────────────────────────────────
  if(bot.hp<bot.maxHp && (nowSec-bot.lastDamageTime)>=CFG.REGEN_DELAY)
    bot.hp=Math.min(bot.maxHp, bot.hp+CFG.REGEN_RATE*dt);

  checkLevelUp(bot);
}

// ─── WIN CONDITION ────────────────────────────────────────────────────────────
function checkWinCondition(){
  if(gameMode==='ffa') return; // FFA: no win/lose, infinite play
  if(GS.lives<=0&&!GS.player.alive){
    endGame(false,'ELIMINATED — OUT OF LIVES');
    return;
  }
  if(gameMode==='battleroyal'){
    // Count bots with lives remaining
    const aliveOrRespawnable=GS.bots.filter(b=>b.alive||(b.lives>0&&b._ai.respawnTimer<999999)).length;
    if(aliveOrRespawnable===0&&GS.player.alive) endGame(true,'LAST PILOT STANDING');
  }
}

function endGame(won,subtitle){
  GS.over=true;gameRunning=false;
  setTimeout(()=>{
    document.getElementById('end-screen').classList.remove('hidden');
    document.getElementById('end-title').textContent=won?'VICTORY':'DEFEATED';
    document.getElementById('end-title').className='end-title '+(won?'win':'lose');
    document.getElementById('end-sub').textContent=subtitle;
    document.getElementById('end-kills').textContent=GS.kills;
    document.getElementById('end-score').textContent=GS.score;
    document.getElementById('end-deaths').textContent=GS.deaths;
    document.getElementById('end-level').textContent=GS.player?GS.player.level+1:1;
    document.getElementById('end-system-name').textContent=currentSystemName;
  },won?1200:800);
}

// ─── RENDERER ─────────────────────────────────────────────────────────────────
const Render={
  canvas:null,ctx:null,
  init(){ this.canvas=document.getElementById('game-canvas');this.ctx=this.canvas.getContext('2d');this.resize();window.addEventListener('resize',()=>this.resize()); },
  resize(){ this.canvas.width=innerWidth;this.canvas.height=innerHeight; },
  draw(now){
    const ctx=this.ctx,W=this.canvas.width,H=this.canvas.height,p=GS.player;
    ctx.clearRect(0,0,W,H);ctx.fillStyle='#050810';ctx.fillRect(0,0,W,H);
    if(!p)return;
    const camX=p.x-W/2,camY=p.y-H/2;
    ctx.save();ctx.translate(-camX,-camY);

    // ── WORLD STARS ────────────────────────────────────────────────────
    const nowT=now/1000;
    for(const ws of GS.worldStars){
      // Only draw if in viewport (with margin)
      if(ws.x<camX-8||ws.x>camX+W+8||ws.y<camY-8||ws.y>camY+H+8) continue;
      let a=ws.a;
      if(ws.twinkle) a*=0.55+0.45*Math.sin(nowT*ws.ts+ws.tp);
      ctx.globalAlpha=a;
      if(ws.tint) ctx.fillStyle=Math.sin(ws.tp)>0?'rgba(180,210,255,1)':'rgba(255,240,180,1)';
      else ctx.fillStyle='rgba(220,235,255,1)';
      ctx.beginPath();ctx.arc(ws.x,ws.y,ws.r,0,Math.PI*2);ctx.fill();
    }
    ctx.globalAlpha=1;

    // Grid
    ctx.strokeStyle='rgba(26,42,74,0.28)';ctx.lineWidth=.5;
    const gs=300,x0=Math.floor(camX/gs)*gs,y0=Math.floor(camY/gs)*gs;
    for(let gx=x0;gx<camX+W+gs;gx+=gs){ctx.beginPath();ctx.moveTo(gx,camY);ctx.lineTo(gx,camY+H);ctx.stroke();}
    for(let gy=y0;gy<camY+H+gs;gy+=gs){ctx.beginPath();ctx.moveTo(camX,gy);ctx.lineTo(camX+W,gy);ctx.stroke();}

    // Map border
    ctx.strokeStyle='rgba(0,212,255,0.3)';ctx.lineWidth=5;ctx.strokeRect(0,0,CFG.MAP_SIZE,CFG.MAP_SIZE);
    // Border glow
    ctx.shadowColor='rgba(0,212,255,0.5)';ctx.shadowBlur=12;
    ctx.strokeStyle='rgba(0,212,255,0.1)';ctx.lineWidth=22;ctx.strokeRect(0,0,CFG.MAP_SIZE,CFG.MAP_SIZE);
    ctx.shadowBlur=0;

    Particles.draw(ctx);

    // ── ASTEROIDS ──────────────────────────────────────────────────────
    for(const ast of GS.asteroids){
      ctx.save();ctx.translate(ast.x,ast.y);ctx.rotate(ast.rot);
      const hpRatio=ast.hp/ast.maxHp;
      // Color shifts red as HP drops
      const brightness=Math.floor(32+hpRatio*28);
      const saturation=Math.floor(35+hpRatio*20);
      const hue=Math.floor(25+hpRatio*5);
      const glow=0.35+0.25*Math.sin(ast.pulse);
      ctx.fillStyle=`hsl(${hue},${saturation}%,${brightness}%)`;
      // Stroke color: dim gray to orange as pts increase
      const ptFrac=(ast.pts-3)/27;
      const strokeH=Math.floor(15+ptFrac*15);
      ctx.strokeStyle=`hsla(${strokeH},70%,55%,${glow+ptFrac*0.25})`;
      ctx.lineWidth=1.5+ptFrac*1.5;
      ctx.beginPath();
      ctx.moveTo(ast.verts[0][0],ast.verts[0][1]);
      for(let vi=1;vi<ast.verts.length;vi++) ctx.lineTo(ast.verts[vi][0],ast.verts[vi][1]);
      ctx.closePath();ctx.fill();ctx.stroke();
      // HP bar below asteroid
      if(ast.hp<ast.maxHp){
        const bw=ast.size*1.6,bh=3,bx=-bw/2,by=ast.size*1.1;
        ctx.fillStyle='rgba(0,0,0,0.5)';ctx.fillRect(bx,by,bw,bh);
        ctx.fillStyle=hpRatio>0.5?'#ffaa00':hpRatio>0.25?'#ff6600':'#ff2200';
        ctx.fillRect(bx,by,bw*hpRatio,bh);
      }
      // Points + HP badge (show on all non-tiny rocks)
      ctx.rotate(-ast.rot); // unrotate text
      const fontSize=Math.max(9,Math.floor(ast.size*.3));
      ctx.font=`bold ${fontSize}px Share Tech Mono`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      // Points label: color scales from white (low) to gold (high)
      const ptColor=ptFrac>0.6?'#ffd700':ptFrac>0.3?'#ffcc44':'rgba(255,230,160,0.9)';
      ctx.fillStyle=ptColor;
      ctx.fillText('+'+ast.pts,0,0);
      // HP remaining underneath for bigger rocks
      if(ast.size>CFG.PLAYER_RADIUS*0.7){
        ctx.font=`${Math.max(7,Math.floor(fontSize*0.6))}px Share Tech Mono`;
        ctx.fillStyle='rgba(200,200,200,0.55)';
        ctx.fillText(Math.ceil(ast.hp)+'/'+ast.maxHp,0,fontSize*0.9);
      }
      ctx.restore();
    }

    // ── SAFE ZONES (TAKEOVER) ──────────────────────────────────────────────
    for(const safe of GS.safes){
      if(safe.hp<=0){
        // Destroyed — show rubble
        ctx.save();ctx.translate(safe.x,safe.y);
        ctx.strokeStyle='rgba(255,80,0,0.4)';ctx.lineWidth=2;
        ctx.setLineDash([6,10]);ctx.beginPath();ctx.arc(0,0,safe.radius,0,Math.PI*2);ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle='rgba(255,50,0,0.06)';ctx.beginPath();ctx.arc(0,0,safe.radius,0,Math.PI*2);ctx.fill();
        ctx.fillStyle='rgba(255,100,0,0.6)';ctx.font='bold 16px Orbitron,sans-serif';
        ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('DESTROYED',0,0);
        ctx.restore();
        continue;
      }
      ctx.save();ctx.translate(safe.x,safe.y);
      const isTeam0=safe.team===0;
      const teamCol=isTeam0?'rgba(0,212,255,':'rgba(255,64,96,';
      const hpRatio=safe.hp/safe.maxHp;
      const pulse=0.5+0.5*Math.sin(Date.now()*0.003);

      // Outer boundary ring (dashed)
      ctx.strokeStyle=teamCol+(0.2+hpRatio*0.2)+')';ctx.lineWidth=1.5;
      ctx.setLineDash([14,8]);ctx.beginPath();ctx.arc(0,0,safe.radius,0,Math.PI*2);ctx.stroke();ctx.setLineDash([]);

      // HP fill — fades as damaged
      ctx.fillStyle=teamCol+(0.04+hpRatio*0.06)+')';ctx.beginPath();ctx.arc(0,0,safe.radius,0,Math.PI*2);ctx.fill();

      // HP arc ring
      ctx.strokeStyle=teamCol+'0.85)';ctx.lineWidth=5;
      ctx.beginPath();ctx.arc(0,0,safe.radius-10,-Math.PI/2,-Math.PI/2+hpRatio*Math.PI*2);ctx.stroke();
      // Depleted portion darker
      if(hpRatio<1){
        ctx.strokeStyle=teamCol+'0.15)';ctx.lineWidth=5;
        ctx.beginPath();ctx.arc(0,0,safe.radius-10,-Math.PI/2+hpRatio*Math.PI*2,-Math.PI/2+Math.PI*2);ctx.stroke();
      }

      // Center structure — hexagonal base
      ctx.shadowColor=teamCol+'0.9)';ctx.shadowBlur=14+pulse*8;
      ctx.strokeStyle=teamCol+(0.7+pulse*0.25)+')';ctx.lineWidth=2;
      ctx.beginPath();
      for(let vi=0;vi<6;vi++){const va=(vi/6)*Math.PI*2;const vr=28*(0.9+pulse*0.08);const nx2=Math.cos(va)*vr,ny2=Math.sin(va)*vr;vi===0?ctx.moveTo(nx2,ny2):ctx.lineTo(nx2,ny2);}
      ctx.closePath();ctx.stroke();
      ctx.fillStyle=teamCol+'0.12)';ctx.fill();

      // Core glow
      const cg=ctx.createRadialGradient(0,0,0,0,0,18);
      cg.addColorStop(0,teamCol+'0.9)');cg.addColorStop(0.5,teamCol+'0.35)');cg.addColorStop(1,'transparent');
      ctx.beginPath();ctx.arc(0,0,18,0,Math.PI*2);ctx.fillStyle=cg;ctx.fill();
      ctx.shadowBlur=0;

      // Team label
      ctx.fillStyle=teamCol+'0.95)';ctx.font='bold 11px Orbitron,sans-serif';
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(isTeam0?'TEAM A':'TEAM B',0,0);

      // HP text below
      ctx.font='10px Share Tech Mono';ctx.fillStyle='rgba(255,255,255,0.75)';
      ctx.fillText(Math.ceil(safe.hp)+' HP',0,38);

      ctx.shadowBlur=0;ctx.restore();
    }

    // ── AMMO PICKUPS ───────────────────────────────────────────────────
    for(const ap of GS.ammoPickups){
      if(!ap)continue;
      const glow=0.55+0.45*Math.sin(ap.pulse);
      ctx.save();ctx.translate(ap.x,ap.y);
      const ag=ctx.createRadialGradient(0,0,0,0,0,14);
      ag.addColorStop(0,`rgba(255,210,0,${glow*0.6})`);ag.addColorStop(1,'rgba(255,180,0,0)');
      ctx.fillStyle=ag;ctx.beginPath();ctx.arc(0,0,14,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=`rgba(255,220,60,${0.7+0.3*glow})`;ctx.beginPath();ctx.arc(0,0,5,0,Math.PI*2);ctx.fill();
      ctx.restore();
    }

    // ── SHIPS ──────────────────────────────────────────────────────────
    const allShips=[p,...GS.bots];
    for(const ship of allShips){
      if(!ship.alive)continue;
      ctx.save();ctx.translate(ship.x,ship.y);

      // Invulnerability flash
      if(ship.invuln>0&&Math.floor(ship.invuln*8)%2===0){ctx.restore();continue;}

      // Determine skin
      let skin;
      if(ship.isPlayer) skin={fill:'rgba(0,212,255,0.15)',body:'#00d4ff',cockpit:'rgba(180,240,255,0.5)'};
      else if(gameMode==='teams'&&ship.team===p.team) skin={fill:'rgba(0,255,136,0.13)',body:'#00ff88',cockpit:'rgba(180,255,200,0.45)'};
      else skin={fill:'rgba(255,64,96,0.13)',body:'#ff4060',cockpit:'rgba(255,180,180,0.38)'};

      // Engine glow
      if(ship.boosting||ship.isPlayer&&Input.keys.up){
        ctx.shadowColor=skin.body;ctx.shadowBlur=18;
      }

      drawShipDesign(ctx,ship.level||0,skin,CFG.PLAYER_RADIUS,ship.angle,now/1000);
      ctx.shadowBlur=0;

      // HP bar above ship
      const hpRatio=ship.hp/ship.maxHp;
      const bw=CFG.PLAYER_RADIUS*2.2,bh=4,by=-CFG.PLAYER_RADIUS*1.6;
      ctx.fillStyle='rgba(0,0,0,0.5)';ctx.fillRect(-bw/2,by,bw,bh);
      ctx.fillStyle=hpRatio>0.5?'#00ff88':hpRatio>0.25?'#ffcc00':'#ff4060';
      ctx.fillRect(-bw/2,by,bw*hpRatio,bh);

      // Name + level label
      ctx.fillStyle=ship.isPlayer?'#00d4ff':skin.body;
      ctx.font=`${ship.isPlayer?'bold ':''}.62rem Share Tech Mono`;
      ctx.textAlign='center';ctx.textBaseline='bottom';
      ctx.fillText(`${ship.username} L${(ship.level||0)+1}`,-0,-CFG.PLAYER_RADIUS*1.9);

      ctx.restore();
    }

    // ── BULLETS — elongated capsule with glow ──────────────────────────
    for(const b of GS.bullets){
      ctx.save();
      const lv=Math.min(7,b.level||0);
      const bs=BULLET_STYLE[lv];
      const angle=Math.atan2(b.vy,b.vx);
      const len=b.radius*3.5+4; // length of capsule
      const wid=b.radius*0.85;   // half-width
      ctx.translate(b.x,b.y);
      ctx.rotate(angle);
      // Outer glow pass
      ctx.shadowColor=bs.glow;
      ctx.shadowBlur=b.radius>7?28:16;
      // Trail gradient along length
      const grad=ctx.createLinearGradient(-len,0,len*0.6,0);
      grad.addColorStop(0,bs.trail);
      grad.addColorStop(0.55,bs.core);
      grad.addColorStop(1,'rgba(255,255,255,0.95)');
      ctx.fillStyle=grad;
      ctx.beginPath();
      ctx.ellipse(0,0,len,wid,0,0,Math.PI*2);
      ctx.fill();
      ctx.shadowBlur=0;
      // Bright core streak
      const coreGrad=ctx.createLinearGradient(-len*0.3,0,len*0.55,0);
      coreGrad.addColorStop(0,'transparent');
      coreGrad.addColorStop(0.4,bs.core);
      coreGrad.addColorStop(1,'rgba(255,255,255,0.9)');
      ctx.fillStyle=coreGrad;
      ctx.beginPath();
      ctx.ellipse(len*0.1,0,len*0.55,wid*0.45,0,0,Math.PI*2);
      ctx.fill();
      ctx.restore();
    }

    // ── BOMBS ────────────────────────────────────────────────────────────
    for(const bm of GS.bombs){
      ctx.save();ctx.translate(bm.x,bm.y);
      const pulse=0.6+0.4*Math.sin(bm.age*8);
      const danger=bm.timer<3; // flash faster when about to blow
      const flashOn=!danger||Math.floor(bm.age*6)%2===0;
      if(flashOn){
        ctx.shadowColor='rgba(255,60,0,0.9)';ctx.shadowBlur=18+pulse*10;
        // Outer ring
        ctx.strokeStyle=`rgba(255,80,0,${0.5+pulse*0.4})`;ctx.lineWidth=2;
        ctx.beginPath();ctx.arc(0,0,14+pulse*3,0,Math.PI*2);ctx.stroke();
        // Inner circle
        const bg=ctx.createRadialGradient(0,0,0,0,0,10);
        bg.addColorStop(0,'rgba(255,200,0,0.9)');bg.addColorStop(0.5,'rgba(255,80,0,0.8)');bg.addColorStop(1,'rgba(180,0,0,0.6)');
        ctx.fillStyle=bg;ctx.beginPath();ctx.arc(0,0,10,0,Math.PI*2);ctx.fill();
        // Skull symbol
        ctx.shadowBlur=0;ctx.fillStyle='rgba(0,0,0,0.85)';ctx.font='bold 10px Arial';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('✕',0,0);
        // Timer ring arc
        ctx.strokeStyle='rgba(255,220,0,0.9)';ctx.lineWidth=2.5;
        ctx.beginPath();ctx.arc(0,0,16,-Math.PI/2,-Math.PI/2+(bm.timer/10)*Math.PI*2);ctx.stroke();
        // Timer text
        ctx.fillStyle='#ffdd00';ctx.font='bold 8px Share Tech Mono';ctx.textAlign='center';ctx.textBaseline='top';
        ctx.fillText(Math.ceil(bm.timer)+'s',0,18);
      }
      ctx.shadowBlur=0;ctx.restore();
    }

    // ── COORDS ─────────────────────────────────────────────────────────
    document.getElementById('coords').textContent=`${Math.floor(p.x)} , ${Math.floor(p.y)}`;

    ctx.restore(); // camera
    this.drawMinimap(p,now);
  },

  _radarAngle:0,
  drawMinimap(p,now){
    const mc=document.getElementById('minimap-canvas'),mctx=mc.getContext('2d'),S=mc.width,sc=S/CFG.MAP_SIZE;
    mctx.clearRect(0,0,S,S);
    // Dark bg
    mctx.fillStyle='rgba(2,6,16,0.92)';mctx.fillRect(0,0,S,S);

    // Radar sweep — rotates over 3s
    this._radarAngle=(this._radarAngle||0)+(0.018); // ~deg per frame @60fps ≈ full rotation ~3s
    const ra=this._radarAngle;
    // Sweep gradient fan
    const fanGrad=mctx.createConicalGradient?undefined:null; // fallback
    const S2=S/2;
    mctx.save();mctx.translate(S2,S2);
    // Draw sweep as a filled arc with gradient
    const sweepWidth=Math.PI/5;
    const grad=mctx.createRadialGradient(0,0,0,0,0,S2);
    grad.addColorStop(0,'rgba(0,255,160,0.35)');
    grad.addColorStop(0.7,'rgba(0,255,160,0.12)');
    grad.addColorStop(1,'rgba(0,255,160,0)');
    mctx.beginPath();mctx.moveTo(0,0);mctx.arc(0,0,S2,ra-sweepWidth,ra);mctx.closePath();
    mctx.fillStyle=grad;mctx.fill();
    // Bright leading edge line
    mctx.strokeStyle='rgba(0,255,160,0.85)';mctx.lineWidth=1.2;
    mctx.beginPath();mctx.moveTo(0,0);mctx.lineTo(Math.cos(ra)*S2,Math.sin(ra)*S2);mctx.stroke();
    mctx.restore();

    // Radar rings
    mctx.strokeStyle='rgba(0,180,80,0.15)';mctx.lineWidth=0.8;
    [0.25,0.5,0.75,1.0].forEach(r=>{mctx.beginPath();mctx.arc(S2,S2,S2*r,0,Math.PI*2);mctx.stroke();});
    // Cross hairs
    mctx.strokeStyle='rgba(0,180,80,0.1)';mctx.lineWidth=0.6;
    mctx.beginPath();mctx.moveTo(S2,0);mctx.lineTo(S2,S);mctx.stroke();
    mctx.beginPath();mctx.moveTo(0,S2);mctx.lineTo(S,S2);mctx.stroke();

    // Asteroids
    mctx.fillStyle='rgba(180,120,40,0.55)';
    for(const ast of GS.asteroids){mctx.fillRect(ast.x*sc-1,ast.y*sc-1,2,2);}
    // Bots
    for(const b of GS.bots){
      if(!b.alive)continue;
      mctx.beginPath();mctx.arc(b.x*sc,b.y*sc,2,0,Math.PI*2);
      mctx.fillStyle=(gameMode==='teams'&&b.team===p.team)?'#00ff88':'#ff6060';mctx.fill();
    }
    // Ammo
    mctx.fillStyle='rgba(255,210,0,0.6)';
    for(const ap of GS.ammoPickups){if(ap)mctx.fillRect(ap.x*sc-1,ap.y*sc-1,2,2);}
    // Bombs
    for(const bm of GS.bombs){
      mctx.beginPath();mctx.arc(bm.x*sc,bm.y*sc,3,0,Math.PI*2);mctx.fillStyle='rgba(255,80,0,0.85)';mctx.fill();
    }
    // Player — white glowing dot with direction tick
    const px=p.x*sc,py=p.y*sc;
    mctx.shadowColor='rgba(255,255,255,0.9)';mctx.shadowBlur=6;
    mctx.beginPath();mctx.arc(px,py,3.5,0,Math.PI*2);mctx.fillStyle='#ffffff';mctx.fill();
    // Direction indicator line
    mctx.strokeStyle='rgba(255,255,255,0.7)';mctx.lineWidth=1.5;
    mctx.beginPath();mctx.moveTo(px,py);mctx.lineTo(px+Math.cos(p.angle)*7,py+Math.sin(p.angle)*7);mctx.stroke();
    mctx.shadowBlur=0;
  }
};

