    ctx.beginPath();
    ctx.moveTo(R*1.6,0);ctx.lineTo(R*.2,R*.12);ctx.lineTo(-R*1.15,R*.18);
    ctx.lineTo(-R*1.28,0);ctx.lineTo(-R*1.15,-R*.18);ctx.lineTo(R*.2,-R*.12);
    ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    // Twin scythe wings — curved, swept forward then back
    [1,-1].forEach(s=>{
      ctx.beginPath();
      ctx.moveTo(R*.8,s*R*.12);
      ctx.bezierCurveTo(R*1.1,s*R*.5, R*.4,s*R*1.0, -R*.1,s*R*1.1);
      ctx.lineTo(-R*.6,s*R*.85);
      ctx.bezierCurveTo(-R*.2,s*R*.7, R*.3,s*R*.45, R*.4,s*R*.12);
      ctx.closePath();
      ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.6;ctx.stroke();
      // Razor tip
      ctx.shadowColor=body;ctx.shadowBlur=10;
      _edge(ctx,body,-R*.1,s*R*1.1,-R*.22,s*R*1.28,3);
      ctx.shadowBlur=0;
    });
    // Glowing engine stripe
    ctx.shadowColor=cock;ctx.shadowBlur=8;
    _edge(ctx,cock,R*1.6,0,-R*1.28,0,1.2);
    ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(R*.6,0,R*.18,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===6){
    // ── LV7 DREADNOUGHT — delta fortress with massive swept delta wings ───
    // Narrow central spine
    ctx.beginPath();
    ctx.moveTo(R*1.8,0);ctx.lineTo(R*.4,R*.2);ctx.lineTo(-R*1.1,R*.28);
    ctx.lineTo(-R*1.35,0);ctx.lineTo(-R*1.1,-R*.28);ctx.lineTo(R*.4,-R*.2);
    ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    // Giant swept delta wings — the main visual
    [1,-1].forEach(s=>{
      ctx.beginPath();
      ctx.moveTo(R*1.0,s*R*.2);
      ctx.lineTo(R*1.2,s*R*.55);
      ctx.lineTo(R*.3,s*R*1.35); // sharp outer tip
      ctx.lineTo(-R*.6,s*R*1.45); // rear tip
      ctx.lineTo(-R*1.1,s*R*.85);
      ctx.lineTo(-R*1.1,s*R*.28);
      ctx.closePath();
      ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
      // Wing leading edge glow
      ctx.shadowColor=body;ctx.shadowBlur=12;
      _edge(ctx,body,R*1.0,s*R*.2,R*1.2,s*R*.55,2);
      _edge(ctx,body,R*1.2,s*R*.55,R*.3,s*R*1.35,2.5);
      _edge(ctx,body,R*.3,s*R*1.35,-R*.6,s*R*1.45,2);
      ctx.shadowBlur=0;
      // Rear serrated edge marks
      ctx.globalAlpha=0.45;
      _edge(ctx,body,-R*.3,s*R*1.2,-R*.5,s*R*1.0,1.2);
      _edge(ctx,body,-R*.1,s*R*1.3,-R*.35,s*R*1.1,1.2);
      ctx.globalAlpha=1;
    });
    // Cross brace
    _edge(ctx,body,R*.8,0,-R*1.1,0,1);
    // Cockpit
    const cg6=ctx.createRadialGradient(R*.6,0,0,R*.6,0,R*.28);
    cg6.addColorStop(0,'rgba(255,255,200,0.95)');cg6.addColorStop(0.6,cock);cg6.addColorStop(1,'transparent');
    ctx.beginPath();ctx.arc(R*.6,0,R*.28,0,Math.PI*2);ctx.fillStyle=cg6;ctx.fill();

