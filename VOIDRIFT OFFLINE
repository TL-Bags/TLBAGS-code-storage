// ─── ASTEROID GENERATION ──────────────────────────────────────────────────────
// pts: 3–30 (random), hp = pts * 20 (so a 3-pt rock needs 60 dmg, 30-pt needs 600)
// size scales proportionally with pts so big rocks look big
function createAsteroid(){
  const R=CFG.PLAYER_RADIUS;
  // pts: weighted so small asteroids are more common
  // ~50% chance 3-8, ~35% chance 9-18, ~15% chance 19-30
  let pts;
  const roll=Math.random();
  if(roll<0.50) pts=3+Math.floor(Math.random()*6);       // 3–8
  else if(roll<0.85) pts=9+Math.floor(Math.random()*10); // 9–18
  else pts=19+Math.floor(Math.random()*12);              // 19–30

  const maxHp=pts*20; // 60 – 600 total damage needed
  const hp=maxHp;

  // Size: linearly interpolate from 0.45R (3pts) to 2.8R (30pts)
  const t=(pts-3)/27; // 0 at 3pts, 1 at 30pts
  const size=R*(0.45+t*2.35)*(0.85+Math.random()*0.3);

  // Speed: big rocks move slower
  const speed=(30-t*22)+Math.random()*15;

  const pos=randPos(200);
  const sides=6+Math.floor(Math.random()*5);
  const verts=[];
  for(let i=0;i<sides;i++){
    const a=(i/sides)*Math.PI*2;
    const r=size*(0.72+Math.random()*0.52);
    verts.push([Math.cos(a)*r,Math.sin(a)*r]);
  }
  const dir=Math.random()*Math.PI*2;
  return {
    id:nextId++,
    x:pos.x,y:pos.y,
    vx:Math.cos(dir)*speed,vy:Math.sin(dir)*speed,
    rot:Math.random()*Math.PI*2, rotSpeed:(Math.random()-.5)*(0.8-t*0.6),
