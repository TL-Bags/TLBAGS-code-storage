    const all=[p,...GS.bots].filter(s=>s.score>0||s.isPlayer).sort((a,b)=>b.score-a.score).slice(0,8);
    document.getElementById('score-list').innerHTML=all.map(s=>{
      const cls=s.isPlayer?'player-row':s.team===0?'ally-row':'enemy-row';
      return `<div class="score-row ${cls}"><span class="sname">${s.username}</span><span>${s.score}</span></div>`;
    }).join('')||'<div class="score-row" style="color:var(--dim)">No scores yet</div>';

    // Minimap
    const mc=document.getElementById('minimap-canvas'),mctx=mc.getContext('2d'),S=mc.width,sc=S/CFG.MAP_SIZE;
    mctx.clearRect(0,0,S,S);
    // Takeover: tinted sides + center divider line + safe icons
    if(gameMode==='takeover'){
      var midM=S/2;
      mctx.fillStyle='rgba(0,212,255,0.06)';mctx.fillRect(0,0,midM,S);
      mctx.fillStyle='rgba(255,64,96,0.06)';mctx.fillRect(midM,0,midM,S);
      mctx.strokeStyle='rgba(255,60,80,0.65)';mctx.lineWidth=1;
      mctx.setLineDash([4,3]);
      mctx.beginPath();mctx.moveTo(midM,0);mctx.lineTo(midM,S);mctx.stroke();
      mctx.setLineDash([]);
      for(var sfi=0;sfi<GS.safes.length;sfi++){
        var msf=GS.safes[sfi];
        if(msf.hp<=0) continue;
        var sfx=msf.x*sc,sfy=msf.y*sc;
        mctx.fillStyle=msf.team===0?'rgba(0,255,136,0.95)':'rgba(255,64,96,0.95)';
        mctx.strokeStyle=msf.team===0?'#00ff88':'#ff4060';
        mctx.lineWidth=1.5;
        mctx.fillRect(sfx-4,sfy-4,8,8);
        mctx.strokeRect(sfx-4,sfy-4,8,8);
      }
    }
    for(const b of GS.bots){
      if(!b.alive)continue;
      mctx.beginPath();mctx.arc(b.x*sc,b.y*sc,2,0,Math.PI*2);
      mctx.fillStyle=b.team===0?'#00ff88':b.team===-1?'#bb88ff':'#ff4060';mctx.fill();
    }
    // Ammo pickups on minimap
    mctx.fillStyle='rgba(255,210,0,0.7)';
    for(var ami=0;ami<GS.ammoPickups.length;ami++){
      var amp=GS.ammoPickups[ami];if(!amp)continue;
      mctx.fillRect(amp.x*sc-1.5,amp.y*sc-1.5,3,3);
    }
    if(p){mctx.beginPath();mctx.arc(p.x*sc,p.y*sc,4,0,Math.PI*2);mctx.fillStyle='#00d4ff';mctx.fill();}
  },
  addKillFeed(killer,victim){
    if(!killer&&!victim)return;
    const feed=document.getElementById('kill-feed'),el=document.createElement('div');
    el.className='kill-entry';el.textContent=`${killer||'?'} ✕ ${victim||'?'}`;
    feed.prepend(el);setTimeout(()=>el.remove(),4100);
    while(feed.children.length>6)feed.lastChild.remove();
  },
};

// ─── CONNECTION SEQUENCE ─────────────────────────────────────────────────────
const CONN_MESSAGES=[
  'Initializing warp drive...',
  'Calculating jump coordinates...',
  'Charging hyperdrive capacitors...',
  'Scanning sector for hostiles...',
  'Deploying combat systems...',
  'Entering battle zone...',
];

function runConnectionSequence(onDone){
  const sysName=SYSTEMS[Math.floor(Math.random()*SYSTEMS.length)];
  currentSystemName=sysName;

  document.getElementById('enter-screen').classList.add('hidden');
  document.getElementById('connecting-screen').classList.remove('hidden');
  document.getElementById('conn-system-name').textContent=sysName;
  document.getElementById('conn-mode-label').textContent=gameMode==='ffa'?'FREE FOR ALL SECTOR':gameMode==='br'?'BATTLE ROYALE SECTOR':gameMode==='takeover'?'TEAM TAKEOVER SECTOR':'TEAM SKIRMISH SECTOR';
  document.getElementById('conn-log').innerHTML='';
  document.getElementById('conn-bar').style.width='0%';

  let step=0;
  const totalSteps=CONN_MESSAGES.length;
  function nextStep(){
    if(step>=totalSteps){
      document.getElementById('conn-bar').style.width='100%';
      setTimeout(onDone,500);return;
    }
    const log=document.getElementById('conn-log');
    const line=document.createElement('div');
    line.className='conn-line';
    // Build children separately so we have direct refs — no querySelector needed
    const icon=document.createElement('span');
    icon.className='spin';icon.textContent='◌';
    const txt=document.createElement('span');
    txt.textContent=CONN_MESSAGES[step];
    line.appendChild(icon);line.appendChild(txt);
    log.appendChild(line);
    // Fade in on next frame
    setTimeout(()=>line.classList.add('show'),20);
    const pct=((step+1)/totalSteps*100);
    document.getElementById('conn-bar').style.width=pct+'%';
    step++;
    // Each step holds for a random duration between 250ms and 900ms
    var holdMs=250+Math.random()*650;
    // Then a short gap before next (50–150ms)
    var gapMs=50+Math.random()*100;
    setTimeout(function(){
      try{icon.className='ok';icon.textContent='✓';}catch(e){}
      setTimeout(nextStep,gapMs);
    },holdMs);
  }
  setTimeout(nextStep,300);
}

// ─── ESC MENU ────────────────────────────────────────────────────────────────
const EscMenu={
  open(){ document.getElementById('esc-overlay').classList.remove('hidden');gameRunning=false; },
  close(){ document.getElementById('esc-overlay').classList.add('hidden');gameRunning=true; },
  quit(){
    this.close();gameRunning=false;GS.over=false;
    GS.player=null;GS.bots=[];GS.bullets=[];GS.safes=[];GS.ammoPickups=[];GS.score=0;GS.kills=0;GS.deaths=0;GS.borderAnchored=false;
    Particles.pool=[];usedNames.clear();deathLingerTimer=0;
    document.getElementById('game-screen').classList.add('hidden');
    document.getElementById('hud').classList.add('hidden');
    document.getElementById('respawn-screen').classList.add('hidden');
    document.getElementById('end-screen').classList.add('hidden');
    document.getElementById('enter-screen').classList.remove('hidden');
    document.getElementById('launch-btn').disabled=false;
    UI.setStatus('');
    // Hide individual HUD elements so they don't bleed through
    document.getElementById('scoreboard').style.display='none';
    document.getElementById('mini-map').style.display='none';
    document.getElementById('status-bars-wrap').style.display='none';
    var awEl=document.getElementById('ammo-warning');if(awEl) awEl.style.display='none';
    document.getElementById('alive-counter').style.display='none';
    document.getElementById('team-bar-wrap').style.display='none';
    var safeBarsEl2=document.getElementById('safe-bars-wrap');
    if(safeBarsEl2) safeBarsEl2.style.display='none';
