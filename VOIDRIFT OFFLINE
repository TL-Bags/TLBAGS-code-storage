(function animPreviews(){
  ['omega-alpha-preview','omega-beta-preview'].forEach((id,i)=>{
    const cv=document.getElementById(id);if(!cv)return;
    const ctx2=cv.getContext('2d');
    ctx2.save();ctx2.clearRect(0,0,cv.width,cv.height);
    const skin={fill:'rgba(180,60,255,0.18)',body:'#cc00ff',cockpit:'rgba(220,160,255,0.55)'};
    ctx2.translate(cv.width/2,cv.height/2);
    drawShipDesign(ctx2,8+i,skin,18,0,performance.now()/1000);
    ctx2.restore();
  });
  requestAnimationFrame(animPreviews);
})();

