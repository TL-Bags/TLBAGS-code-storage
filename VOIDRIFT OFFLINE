  let layers=[],nebCanvas=document.createElement('canvas'),nebCtx=nebCanvas.getContext('2d');
  function build(){
    c.width=innerWidth;c.height=innerHeight;nebCanvas.width=c.width;nebCanvas.height=c.height;
    nebCtx.clearRect(0,0,c.width,c.height);
    [{x:.15,y:.25,r:.38,col:'rgba(0,55,115,'},{x:.78,y:.62,r:.3,col:'rgba(40,0,80,'},{x:.5,y:.82,r:.24,col:'rgba(0,38,75,'},{x:.88,y:.18,r:.2,col:'rgba(55,0,75,'}].forEach(b=>{
      const gx=b.x*c.width,gy=b.y*c.height,gr=b.r*Math.max(c.width,c.height);
      const g=nebCtx.createRadialGradient(gx,gy,0,gx,gy,gr);
      g.addColorStop(0,b.col+'.06)');g.addColorStop(.5,b.col+'.025)');g.addColorStop(1,b.col+'0)');
      nebCtx.fillStyle=g;nebCtx.beginPath();nebCtx.arc(gx,gy,gr,0,Math.PI*2);nebCtx.fill();
    });
    layers=[
      Array.from({length:320},()=>({x:Math.random()*c.width,y:Math.random()*c.height,r:.4+Math.random()*.5,a:.12+Math.random()*.2,speed:.007+Math.random()*.011,tw:false})),
      Array.from({length:130},()=>({x:Math.random()*c.width,y:Math.random()*c.height,r:.75+Math.random()*.85,a:.28+Math.random()*.32,speed:.022+Math.random()*.028,tw:Math.random()<.18,ts:.8+Math.random()*1.6,tp:Math.random()*Math.PI*2})),
      Array.from({length:45},()=>({x:Math.random()*c.width,y:Math.random()*c.height,r:1.1+Math.random()*1.9,a:.5+Math.random()*.42,speed:.055+Math.random()*.055,tw:true,ts:.35+Math.random()*.9,tp:Math.random()*Math.PI*2,tint:Math.random()<.3})),
    ];
  }
  build();window.addEventListener('resize',build);
  let t=0;
  (function draw(ts){t=(ts||0)/1000;ctx.clearRect(0,0,c.width,c.height);ctx.drawImage(nebCanvas,0,0);
    for(const layer of layers)for(const s of layer){let a=s.a;if(s.tw)a*=.62+.38*Math.sin(t*s.ts+s.tp);ctx.globalAlpha=a;ctx.fillStyle=s.tint?`rgba(${180+Math.random()*30},${200+Math.random()*30},255,1)`:'rgba(210,228,255,1)';ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fill();s.y+=s.speed;if(s.y>c.height+2){s.y=-2;s.x=Math.random()*c.width;}}
    ctx.globalAlpha=1;requestAnimationFrame(draw);})(0);
})();

// ─── GAME STATE ───────────────────────────────────────────────────────────────
let nextId=1,gameRunning=false,deathLingerTimer=0;
let currentSystemName='';
let gameMode='ffa'; // 'ffa', 'br', or 'teams'

const GS = {
  player:null,
  bots:[],       // all AI ships
  bullets:[],
  score:0, kills:0, deaths:0,
  borderAnchored:false,
  over:false,
  safes:[],      // [{team, x, y, hp, maxHp}] — team takeover mode
  ammoPickups:[], // [{x, y, pulse}] — ammo dots on the map
};

// Team IDs: 0 = player team, 1 = enemy team, -1 = FFA/BR (free-for-all)
function teamOf(ship){
  if(!ship) return -1;
  return ship.team??-1;
}
function areEnemies(a,b){
  if(teamOf(a)===-1||teamOf(b)===-1) return a.id!==b.id; // FFA: everyone's an enemy
  return teamOf(a)!==teamOf(b);
}

const NAMES_POOL=['Vega','Drax','Orion','Lyra','Siris','Nova','Cygnus','Pulsar','Quasar','Zenith','Altair','Rigel','Deneb','Spica','Mizar','Corvus','Hades','Lycon','Tanis','Pyrex','Solus','Kalix','Vorn','Trex','Aeon','Brix','Cael','Dusk','Eryx','Flux','Gale','Haze','Iris','Jett','Kova'];
let usedNames=new Set();
function pickName(){
  const avail=NAMES_POOL.filter(n=>!usedNames.has(n));
  if(!avail.length){usedNames.clear();return NAMES_POOL[Math.floor(Math.random()*NAMES_POOL.length)];}
  const n=avail[Math.floor(Math.random()*avail.length)];
  usedNames.add(n);return n;
}

function randPos(margin,side){
  if(margin===undefined) margin=200;
  var half=CFG.MAP_SIZE/2;
  var xMin,xMax;
  if(side==='left'){
    xMin=margin; xMax=half-margin;
  } else if(side==='right'){
    xMin=half+margin; xMax=CFG.MAP_SIZE-margin;
  } else {
    xMin=margin; xMax=CFG.MAP_SIZE-margin;
  }
  var yMin=margin, yMax=CFG.MAP_SIZE-margin;
  return {x:xMin+Math.random()*(xMax-xMin), y:yMin+Math.random()*(yMax-yMin)};
}
function angleDiff(a,b){let d=((b-a+Math.PI)%(Math.PI*2))-Math.PI;if(d<-Math.PI)d+=Math.PI*2;return d;}

function createShipBase(id,username,team,spawnSide){
  const p=randPos(200,spawnSide);
  return {
    id,username,team,
    x:p.x,y:p.y,angle:Math.random()*Math.PI*2,vx:0,vy:0,
    hp:CFG.PLAYER_MAX_HP,maxHp:CFG.PLAYER_MAX_HP,
    alive:true,invuln:CFG.RESPAWN_INVULN,shootCooldown:0,
    boostFuel:CFG.BOOST_MAX,boostRechargeTimer:0,boosting:false,
    ammo:CFG.AMMO_MAX,
    borderAnchored:false,lastDamageTime:-999,
    cosmetics:{bulletStyle:'default'},
    kills:0,score:0,
  };
}

function createPlayer(username,team,spawnSide){
  return Object.assign({},createShipBase(nextId++,username,team,spawnSide),{isPlayer:true});
}

function createBot(team,spawnSide){
  const base=createShipBase(nextId++,pickName(),team,spawnSide);
  base.isPlayer=false;
  base._ai={state:'patrol',patrolAngle:Math.random()*Math.PI*2,stateTimer:0,
            currentTarget:null,fleeTimer:0,respawnTimer:0,takeoverTask:null};
  return base;
}

// ─── AMMO PICKUPS ────────────────────────────────────────────────────────────
function spawnAmmoPickups(){
  GS.ammoPickups=[];
  for(var i=0;i<CFG.AMMO_PICKUP_COUNT;i++){
    var p=randPos(100);
    GS.ammoPickups.push({x:p.x,y:p.y,pulse:Math.random()*Math.PI*2});
  }
}

function respawnAmmoPickup(idx){
  // Respawn dot at a new random location
  var p=randPos(100);
  GS.ammoPickups[idx]={x:p.x,y:p.y,pulse:Math.random()*Math.PI*2};
}

// ─── AI ──────────────────────────────────────────────────────────────────────
function tickAI(bot,allShips,player,dt,nowSec){
  if(!bot.alive){ bot._ai.respawnTimer-=dt; return; }
  var ai=bot._ai;
  if(bot.invuln>0) bot.invuln-=dt;
  ai.stateTimer-=dt;

  var fleeHpThreshold=bot.maxHp*0.20; // flee below 20% HP
  var fleeRecoverThreshold=bot.maxHp*0.30; // stop fleeing above 30%

  // ── FLEE CHECK (highest priority, overrides everything) ──────────────────
  if(bot.hp<=fleeHpThreshold && ai.state!=='evade'){
    ai.state='evade';
    ai.fleeTimer=4+Math.random()*3;
    // After fleeing, re-roll takeover task so the bot picks a fresh objective
    if(gameMode==='takeover') ai.takeoverTask=null;
  }
  if(ai.state==='evade'){
    ai.fleeTimer-=dt;
    // Only exit flee when HP has recovered enough AND flee timer expired
    if(ai.fleeTimer<=0 && bot.hp>=fleeRecoverThreshold){
      ai.state='patrol';
      ai.stateTimer=0; // force re-decision next tick
    }
  }

  // ── TAKEOVER MODE TARGET LOGIC ───────────────────────────────────────────
  var target=null;
  if(gameMode==='takeover' && ai.state!=='evade'){

    // Pick a task if we don't have one (on spawn, respawn, or after fleeing)
    if(!ai.takeoverTask){
      // 50/50: attack enemy safe OR fight enemies (player focus biased)
      ai.takeoverTask=Math.random()<0.5?'safe':'fight';
    }

    var enemySafe=null;
    for(var si2=0;si2<GS.safes.length;si2++){
      if(GS.safes[si2].team!==bot.team&&GS.safes[si2].hp>0){enemySafe=GS.safes[si2];break;}
    }
    // If the enemy safe is already dead, switch to fight
    if(!enemySafe) ai.takeoverTask='fight';

    if(ai.takeoverTask==='safe'&&enemySafe){
      // Head for and shoot the enemy safe.
      // If an enemy ship gets very close (within 350 units), briefly engage it
      var closeEnemy=null,closeDist=350;
      for(var ci=0;ci<allShips.length;ci++){
        var cs=allShips[ci];
        if(!cs.alive||cs.id===bot.id||!areEnemies(bot,cs)) continue;
        var cd=Math.hypot(cs.x-bot.x,cs.y-bot.y);
        if(cd<closeDist){closeDist=cd;closeEnemy=cs;}
      }
      target=(closeEnemy&&closeDist<180)?closeEnemy:enemySafe;

    } else {
      // Fight task: pick a target — bias toward player
      var fightEnemies=allShips.filter(function(s){
        return s.alive&&s.id!==bot.id&&areEnemies(bot,s);
      });
      if(fightEnemies.length){
        // Sort by distance
        fightEnemies.sort(function(a,b){
          return Math.hypot(a.x-bot.x,a.y-bot.y)-Math.hypot(b.x-bot.x,b.y-bot.y);
        });
        // Player focus weight: prefer player if alive and enemy
        if(player.alive&&areEnemies(bot,player)&&Math.random()<CFG.PLAYER_FOCUS_WEIGHT){
          target=player;
        } else {
          target=fightEnemies[0];
        }
      }
      // Fall back to enemy safe if no ships to fight
      if(!target&&enemySafe) target=enemySafe;
    }

  // ── FFA / BR / TEAMS TARGET LOGIC ────────────────────────────────────────
  } else if(ai.state!=='evade'){
    var enemies=allShips.filter(function(s){
      return s.alive&&s.id!==bot.id&&areEnemies(bot,s);
    });
    if(enemies.length){
      enemies.sort(function(a,b){
        return Math.hypot(a.x-bot.x,a.y-bot.y)-Math.hypot(b.x-bot.x,b.y-bot.y);
      });
      if(player.alive&&areEnemies(bot,player)&&Math.random()<CFG.PLAYER_FOCUS_WEIGHT){
        target=player;
      } else {
        target=enemies[0];
      }
    }
  }

  ai.currentTarget=target;

  var dx=target?target.x-bot.x:0;
  var dy=target?target.y-bot.y:0;
  var dist=target?Math.hypot(dx,dy):Infinity;
  var angleToTarget=target?Math.atan2(dy,dx):bot.angle;

  var wantThrust=false,wantShoot=false,targetAngle=bot.angle;

  if(ai.state==='evade'){
    // Flee away from nearest threat
    var nearestThreat=null,nearestThreatDist=Infinity;
    for(var ti=0;ti<allShips.length;ti++){
      var ts=allShips[ti];
      if(!ts.alive||ts.id===bot.id||!areEnemies(bot,ts)) continue;
      var td=Math.hypot(ts.x-bot.x,ts.y-bot.y);
      if(td<nearestThreatDist){nearestThreatDist=td;nearestThreat=ts;}
    }
    var fleeAngle=nearestThreat
      ?Math.atan2(bot.y-nearestThreat.y,bot.x-nearestThreat.x)
      :bot.angle+Math.PI;
    targetAngle=fleeAngle+(Math.random()-.5)*0.6;
    wantThrust=true;

  } else if(!target){
    // Patrol
    ai.state='patrol';
    if(ai.stateTimer<0){
      ai.patrolAngle+=((Math.random()-.5)*1.5);
      ai.stateTimer=2+Math.random()*3;
    }
    targetAngle=ai.patrolAngle;
    wantThrust=Math.random()<0.7;

  } else if(dist>500){
    targetAngle=angleToTarget;wantThrust=true;
  } else if(dist>CFG.SAFE_RADIUS+60){
    // In range — move closer and shoot when aimed
    targetAngle=angleToTarget;wantThrust=dist>CFG.SAFE_RADIUS+80;
    if(Math.abs(angleDiff(bot.angle,angleToTarget))<0.3) wantShoot=true;
  } else {
    // Very close — hold position and shoot
    targetAngle=angleToTarget;wantThrust=false;
    if(Math.abs(angleDiff(bot.angle,angleToTarget))<0.28) wantShoot=true;
  }

  // Steer
  var diff=angleDiff(bot.angle,targetAngle);
  bot.angle+=Math.sign(diff)*Math.min(Math.abs(diff),Math.PI*3.5*dt);
  bot.angle=((bot.angle+Math.PI)%(Math.PI*2))-Math.PI;

  if(wantThrust){
    bot.vx+=Math.cos(bot.angle)*CFG.PLAYER_SPEED*dt*2;
    bot.vy+=Math.sin(bot.angle)*CFG.PLAYER_SPEED*dt*2;
  }
  bot.vx*=0.97;bot.vy*=0.97;
  var spd=Math.hypot(bot.vx,bot.vy);
  if(spd>CFG.PLAYER_SPEED){bot.vx=bot.vx/spd*CFG.PLAYER_SPEED;bot.vy=bot.vy/spd*CFG.PLAYER_SPEED;}

  // Border — wrap for non-takeover, clamp for takeover
  var M2=CFG.MAP_SIZE;
  if(gameMode==='takeover'){
    bot.x=Math.max(0,Math.min(M2,bot.x+bot.vx*dt));
    bot.y=Math.max(0,Math.min(M2,bot.y+bot.vy*dt));
  } else {
    bot.x=((bot.x+bot.vx*dt)%M2+M2)%M2;
    bot.y=((bot.y+bot.vy*dt)%M2+M2)%M2;
  }

  // Shoot
  if(bot.shootCooldown>0) bot.shootCooldown-=dt;
  if(wantShoot&&bot.shootCooldown<=0){
    spawnBullet(bot);
    bot.shootCooldown=CFG.SHOOT_COOLDOWN*(1+Math.random()*.4);
  }

  // Regen
  if(bot.hp<bot.maxHp&&(nowSec-bot.lastDamageTime)>=CFG.REGEN_DELAY)
    bot.hp=Math.min(bot.maxHp,bot.hp+CFG.REGEN_RATE*dt);
}

// ─── BULLETS ─────────────────────────────────────────────────────────────────
function spawnBullet(owner){
  GS.bullets.push({
    id:nextId++,ownerId:owner.id,ownerTeam:owner.team??-1,
    x:owner.x+Math.cos(owner.angle)*(CFG.PLAYER_RADIUS+4),
    y:owner.y+Math.sin(owner.angle)*(CFG.PLAYER_RADIUS+4),
    vx:Math.cos(owner.angle)*CFG.BULLET_SPEED+owner.vx*.3,
    vy:Math.sin(owner.angle)*CFG.BULLET_SPEED+owner.vy*.3,
    lifetime:CFG.BULLET_LIFETIME,
    bulletStyle:owner.cosmetics?.bulletStyle??'default',
  });
}

// ─── INPUT ───────────────────────────────────────────────────────────────────
const Input={
  keys:{up:false,down:false,shoot:false,sideLeft:false,sideRight:false,boost:false},
  mouseAngle:0,mouseX:innerWidth/2,mouseY:innerHeight/2,
  arrowLeft:false,arrowRight:false,
  _baPressed:false,
  init(){
    window.addEventListener('keydown',e=>this._down(e));
    window.addEventListener('keyup',e=>this._up(e));
    window.addEventListener('mousemove',e=>{this.mouseX=e.clientX;this.mouseY=e.clientY;});
    window.addEventListener('mousedown',e=>{if(!gameRunning)return;if(e.button===0)this.keys.shoot=true;if(e.button===2)this.keys.up=true;});
    window.addEventListener('mouseup',e=>{if(e.button===0)this.keys.shoot=false;if(e.button===2)this.keys.up=false;});
    window.addEventListener('contextmenu',e=>{if(gameRunning)e.preventDefault();});
  },
  _down(e){
    if(!document.getElementById('settings-overlay').classList.contains('hidden'))return;
    if(!document.getElementById('esc-overlay').classList.contains('hidden')){if(e.key==='Escape'||Binds.idFor(e.code)==='escMenu'){EscMenu.close();e.preventDefault();}return;}
    if(gameRunning&&(e.key==='Escape'||Binds.idFor(e.code)==='escMenu')){EscMenu.open();e.preventDefault();return;}
    this._apply(e.code,true,e);
  },
  _up(e){this._apply(e.code,false,e);},
  _apply(code,val,e){
    const id=Binds.idFor(code);if(!id)return;
    switch(id){
      case 'thrust':   this.keys.up=val;break;
      case 'brake':    this.keys.down=val;break;
      case 'sideLeft': this.keys.sideLeft=val;break;
      case 'sideRight':this.keys.sideRight=val;break;
      case 'rotLeft':  this.arrowLeft=val;if(val)e?.preventDefault();break;
      case 'rotRight': this.arrowRight=val;if(val)e?.preventDefault();break;
      case 'shoot':    this.keys.shoot=val;if(val)e?.preventDefault();break;
      case 'boost':    this.keys.boost=val;break;
      case 'borderAnchor':
        if(val&&!this._baPressed&&GS.player){
          GS.player.borderAnchored=!GS.player.borderAnchored;
          GS.borderAnchored=GS.player.borderAnchored;
          this._baPressed=true;
        }
        if(!val)this._baPressed=false;
        break;
    }
  },
  updateMouseAngle(){
    if(!Render.canvas)return;
    const W=Render.canvas.width,H=Render.canvas.height;
    if(!this.arrowLeft&&!this.arrowRight) this.mouseAngle=Math.atan2(this.mouseY-H/2,this.mouseX-W/2);
  },
};

// ─── PHYSICS TICK ────────────────────────────────────────────────────────────
let lastTickTime=0;

function tickGame(now){
  if(!gameRunning||GS.over)return;
  const dt=Math.min((now-lastTickTime)/1000,.05);
  lastTickTime=now;
  const nowSec=now/1000;
  const p=GS.player;
  if(!p)return;

  // All ships for AI targeting
  const allShips=[p,...GS.bots];

  // ── PLAYER ──────────────────────────────────────────────────────────────
  if(p.alive){
    if(p.invuln>0)p.invuln-=dt;

    if(Input.arrowLeft||Input.arrowRight){
      const dir=(Input.arrowRight?1:0)+(Input.arrowLeft?-1:0);
      p.angle+=dir*Math.PI*4*dt;p.angle=((p.angle+Math.PI)%(Math.PI*2))-Math.PI;
      Input.mouseAngle=p.angle;
    } else p.angle=Input.mouseAngle;

    const wantBoost=Input.keys.boost&&p.boostFuel>0;
    p.boosting=wantBoost;
    if(wantBoost){p.boostFuel=Math.max(0,p.boostFuel-CFG.BOOST_DRAIN*dt);p.boostRechargeTimer=CFG.BOOST_RECHARGE_DELAY;}
    else{if(p.boostRechargeTimer>0)p.boostRechargeTimer-=dt;else p.boostFuel=Math.min(CFG.BOOST_MAX,p.boostFuel+CFG.BOOST_RECHARGE*dt);}

    const bm=wantBoost?CFG.BOOST_SPEED_MULT:1;
    const am=p.borderAnchored?(1-CFG.BORDER_ANCHOR_PENALTY):1;
    const effSpd=CFG.PLAYER_SPEED*bm*am;

    if(Input.keys.up){p.vx+=Math.cos(p.angle)*effSpd*dt*2.5;p.vy+=Math.sin(p.angle)*effSpd*dt*2.5;Particles.emitThrust(p,wantBoost);}
    if(Input.keys.sideLeft||Input.keys.sideRight){const dir=Input.keys.sideRight?1:-1;p.vx+=(-Math.sin(p.angle))*dir*CFG.SIDE_THRUST_SPEED*dt*4;p.vy+=(Math.cos(p.angle))*dir*CFG.SIDE_THRUST_SPEED*dt*4;Particles.emitSide(p,dir);}
    const drag=Input.keys.down?0.88:0.97;
    var _fd=Math.pow(drag,dt*60);if(!isNaN(_fd)){p.vx*=_fd;p.vy*=_fd;}
    const spd=Math.hypot(p.vx,p.vy);if(spd>effSpd){p.vx=p.vx/spd*effSpd;p.vy=p.vy/spd*effSpd;}

    // Border: takeover = hard clamp; others = wrap
    const M=CFG.MAP_SIZE;
    if(gameMode==='takeover'){
      var nx=p.x+p.vx*dt, ny=p.y+p.vy*dt;
      if(nx<0){nx=0;p.vx=Math.abs(p.vx)*0.3;}
      if(nx>M){nx=M;p.vx=-Math.abs(p.vx)*0.3;}
      if(ny<0){ny=0;p.vy=Math.abs(p.vy)*0.3;}
      if(ny>M){ny=M;p.vy=-Math.abs(p.vy)*0.3;}
      p.x=nx;p.y=ny;
    } else {
      p.x=((p.x+p.vx*dt)%M+M)%M;
      p.y=((p.y+p.vy*dt)%M+M)%M;
    }

    if(p.hp<p.maxHp&&(nowSec-p.lastDamageTime)>=CFG.REGEN_DELAY)
      p.hp=Math.min(p.maxHp,p.hp+CFG.REGEN_RATE*dt);

    if(p.shootCooldown>0)p.shootCooldown-=dt;
    if(Input.keys.shoot&&p.shootCooldown<=0&&p.ammo>0){
      spawnBullet(p);
      p.ammo=Math.max(0,p.ammo-1);
      p.shootCooldown=CFG.SHOOT_COOLDOWN;
    }
  } else {
    if(deathLingerTimer>0){deathLingerTimer-=dt;if(deathLingerTimer<=0)UI.showRespawnScreen();}
  }

  // ── BOTS ────────────────────────────────────────────────────────────────
  for(const bot of GS.bots){
    if(!bot.alive){
      // FFA and Takeover respawn bots; BR and Teams are elimination
      if((gameMode==='ffa'||gameMode==='takeover')&&CFG.ENEMY_RESPAWN_TIME>0){
        bot._ai.respawnTimer-=dt;
        if(bot._ai.respawnTimer<=0){
          var respawnSide=(gameMode==='takeover')?(bot.team===0?'left':'right'):undefined;
          const rp=randPos(200,respawnSide);bot.x=rp.x;bot.y=rp.y;bot.vx=0;bot.vy=0;
          bot.hp=bot.maxHp;bot.alive=true;bot.invuln=CFG.RESPAWN_INVULN;
          bot.shootCooldown=0;bot.lastDamageTime=-999;
          bot._ai.state='patrol';bot._ai.fleeTimer=0;bot._ai.takeoverTask=null;
        }
      }
      continue;
    }
    tickAI(bot,allShips,p,dt,nowSec);
  }

  // ── BULLETS ─────────────────────────────────────────────────────────────
  GS.bullets=GS.bullets.filter(b=>{
    b.lifetime-=dt;if(b.lifetime<=0)return false;
    const M=CFG.MAP_SIZE;
    b.x=((b.x+b.vx*dt)%M+M)%M;
    b.y=((b.y+b.vy*dt)%M+M)%M;

    // Check all possible targets
    for(const target of allShips){
      if(!target.alive||target.id===b.ownerId||target.invuln>0)continue;
      // Don't hit friendlies (teams mode)
      if(b.ownerTeam!==-1&&b.ownerTeam===target.team)continue;
      if(Math.hypot(target.x-b.x,target.y-b.y)<CFG.PLAYER_RADIUS){
        target.hp-=CFG.BULLET_DAMAGE;target.lastDamageTime=nowSec;
        Particles.emitHitSparks(b.x,b.y,b.bulletStyle);

        if(target.hp<=0){
          target.hp=0;target.alive=false;
          Particles.emitExplosion(target.x,target.y);

          if(target.isPlayer){
            GS.deaths++;
            deathLingerTimer=3;UI.startDeathLinger();
          } else {
            // Credit kill
            const killer=allShips.find(s=>s.id===b.ownerId);
            if(killer){
              killer.kills++;killer.score+=100;
              if(killer.isPlayer){GS.kills++;GS.score+=100;}
            }
            if(gameMode==='ffa'||gameMode==='takeover') target._ai.respawnTimer=CFG.ENEMY_RESPAWN_TIME;
            UI.addKillFeed(killer?.username,target.username);
          }
          checkWinCondition();
        }
        return false;
      }
    }
    // Safe collision (takeover mode)
    if(gameMode==='takeover'){
      for(var si=0;si<GS.safes.length;si++){
        var sf=GS.safes[si];
        if(sf.hp<=0) continue;
        // Only bullets from the opposing team can damage a safe
        if(b.ownerTeam===sf.team) continue;
        if(Math.abs(sf.x-b.x)<CFG.SAFE_RADIUS&&Math.abs(sf.y-b.y)<CFG.SAFE_RADIUS){
          sf.hp=Math.max(0,sf.hp-CFG.BULLET_DAMAGE);
          Particles.emitHitSparks(b.x,b.y,b.bulletStyle);
          if(sf.hp<=0){
            Particles.emitExplosion(sf.x,sf.y);
            var attackerShip=allShips.find(function(sh){return sh.id===b.ownerId;});
            if(attackerShip){
              attackerShip.score+=500;
              if(attackerShip.isPlayer) GS.score+=500;
            }
            UI.addKillFeed(attackerShip?attackerShip.username:'Unknown','Enemy Safe');
            checkWinCondition();
          }
          return false;
        }
      }
    }

    return true;
  });

  // ── AMMO PICKUPS ────────────────────────────────────────────────────────
  if(p.alive){
    for(var ai2=0;ai2<GS.ammoPickups.length;ai2++){
      var ap=GS.ammoPickups[ai2];
      if(!ap) continue;
      ap.pulse+=dt*3; // animate
      if(Math.hypot(p.x-ap.x,p.y-ap.y)<CFG.AMMO_PICKUP_RADIUS+CFG.PLAYER_RADIUS){
        p.ammo=Math.min(CFG.AMMO_MAX,p.ammo+CFG.AMMO_PER_PICKUP);
        Particles.emitAmmoPickup(ap.x,ap.y);
        respawnAmmoPickup(ai2);
      }
    }
  }

  Particles.tick(dt);
  UI.updateHUD();
}

// ─── WIN CONDITION ───────────────────────────────────────────────────────────
function checkWinCondition(){
  if(GS.over)return;
  const p=GS.player;

  if(gameMode==='ffa'){
    // FFA: endless bots respawn — no definitive win condition, just play forever.
    // (Player can still die and respawn.)
    return;

  } else if(gameMode==='br'){
    // True Battle Royale — no respawns for anyone.
    const aliveBots=GS.bots.filter(b=>b.alive);
    if(p.alive&&aliveBots.length===0){
      endGame(true,'LAST PILOT STANDING');
    } else if(!p.alive){
      endGame(false,'YOU WERE ELIMINATED');
    }

  } else if(gameMode==='teams'){
    var aliveAllies=GS.bots.filter(function(b){return b.team===0&&b.alive;});
    var aliveEnemies=GS.bots.filter(function(b){return b.team===1&&b.alive;});
    if(aliveEnemies.length===0&&p.alive){
      endGame(true,'ALL ENEMIES ELIMINATED');
    } else if(!p.alive&&aliveAllies.length===0){
      endGame(false,'YOUR TEAM WAS DESTROYED');
    } else if(aliveEnemies.length===0&&!p.alive){
      endGame(false,'YOUR TEAM WON — BUT YOU FELL');
    }
  } else if(gameMode==='takeover'){
    var ySafe=GS.safes.find(function(sf){return sf.team===0;});
    var eSafe=GS.safes.find(function(sf){return sf.team===1;});
    if(eSafe&&eSafe.hp<=0){
      endGame(true,'ENEMY SAFE DESTROYED');
    } else if(ySafe&&ySafe.hp<=0){
      endGame(false,'YOUR SAFE WAS DESTROYED');
    }
  }
}

function endGame(won,subtitle){
  GS.over=true;gameRunning=false;
  setTimeout(()=>{
    document.getElementById('end-screen').classList.remove('hidden');
    document.getElementById('end-title').textContent=won?'VICTORY':'DEFEATED';
    document.getElementById('end-title').className='end-title '+(won?'win':'lose');
    document.getElementById('end-sub').textContent=subtitle;
    document.getElementById('end-kills').textContent=GS.kills;
    document.getElementById('end-score').textContent=GS.score;
    document.getElementById('end-deaths').textContent=GS.deaths;
    document.getElementById('end-system-name').textContent=currentSystemName;
  }, won?1200:800);
}

// ─── RENDERER ────────────────────────────────────────────────────────────────
const Render={
  canvas:null,ctx:null,
  init(){this.canvas=document.getElementById('game-canvas');this.ctx=this.canvas.getContext('2d');this.resize();window.addEventListener('resize',()=>this.resize());},
  resize(){this.canvas.width=innerWidth;this.canvas.height=innerHeight;},
  draw(now){
    const ctx=this.ctx,W=this.canvas.width,H=this.canvas.height,p=GS.player;
    ctx.clearRect(0,0,W,H);ctx.fillStyle='#050810';ctx.fillRect(0,0,W,H);
    if(!p)return;
    const camX=p.x-W/2,camY=p.y-H/2;
    ctx.save();ctx.translate(-camX,-camY);
    // Grid
    ctx.strokeStyle='rgba(26,42,74,0.32)';ctx.lineWidth=.5;
    const gs=300,x0=Math.floor(camX/gs)*gs,y0=Math.floor(camY/gs)*gs;
    for(let gx=x0;gx<camX+W+gs;gx+=gs){ctx.beginPath();ctx.moveTo(gx,camY);ctx.lineTo(gx,camY+H);ctx.stroke();}
    for(let gy=y0;gy<camY+H+gs;gy+=gs){ctx.beginPath();ctx.moveTo(camX,gy);ctx.lineTo(camX+W,gy);ctx.stroke();}
    // Map border
    ctx.strokeStyle='rgba(0,212,255,0.2)';ctx.lineWidth=4;ctx.strokeRect(0,0,CFG.MAP_SIZE,CFG.MAP_SIZE);
    // Center divider (takeover mode)
    if(gameMode==='takeover'){
      var mid=CFG.MAP_SIZE/2;
      ctx.save();
      ctx.strokeStyle='rgba(255,60,80,0.55)';
      ctx.lineWidth=3;
      ctx.setLineDash([18,12]);
      ctx.beginPath();ctx.moveTo(mid,0);ctx.lineTo(mid,CFG.MAP_SIZE);ctx.stroke();
      ctx.setLineDash([]);
      // Label each side
      ctx.font='bold 22px "Share Tech Mono"';
      ctx.textAlign='center';
      ctx.fillStyle='rgba(0,212,255,0.18)';
      ctx.fillText('YOUR TERRITORY',mid/2,80);
      ctx.fillStyle='rgba(255,64,96,0.18)';
      ctx.fillText('ENEMY TERRITORY',mid+mid/2,80);
      ctx.restore();
    }
    // Draw safes (takeover mode)
    if(gameMode==='takeover'){
      for(var si=0;si<GS.safes.length;si++){
        var sf=GS.safes[si];
        if(sf.hp<=0) continue;
        var isAllySafe=(sf.team===0);
        var sfCol=isAllySafe?'#00ff88':'#ff4060';
        var sfFill=isAllySafe?'rgba(0,255,136,0.12)':'rgba(255,64,96,0.12)';
        ctx.save();ctx.translate(sf.x,sf.y);
        ctx.shadowColor=sfCol;ctx.shadowBlur=20;
        // Square body
        var SR=CFG.SAFE_RADIUS;
        ctx.strokeStyle=sfCol;ctx.lineWidth=3;ctx.fillStyle=sfFill;
        ctx.fillRect(-SR,-SR,SR*2,SR*2);
        ctx.strokeRect(-SR,-SR,SR*2,SR*2);
        // Inner cross
        ctx.lineWidth=2;
        ctx.beginPath();ctx.moveTo(-SR*0.5,0);ctx.lineTo(SR*0.5,0);ctx.stroke();
        ctx.beginPath();ctx.moveTo(0,-SR*0.5);ctx.lineTo(0,SR*0.5);ctx.stroke();
        // Corner brackets for detail
        ctx.lineWidth=1.5;
        var br=SR*0.28;
        [[- SR,-SR],[SR,-SR],[SR,SR],[-SR,SR]].forEach(function(c){
          var cx=c[0],cy=c[1];
          var dx=cx<0?br:-br,dy=cy<0?br:-br;
          ctx.beginPath();ctx.moveTo(cx+dx,cy);ctx.lineTo(cx,cy);ctx.lineTo(cx,cy+dy);ctx.stroke();
        });
        // HP bar above safe
        var sfPct=sf.hp/sf.maxHp;
        var bw=CFG.SAFE_RADIUS*2.4;
        ctx.shadowBlur=0;
        ctx.fillStyle='rgba(0,0,0,0.6)';ctx.fillRect(-bw/2,-CFG.SAFE_RADIUS-14,bw,7);
        ctx.fillStyle=sfPct>0.5?'#00ff88':sfPct>0.25?'#ffcc00':'#ff4060';
        ctx.fillRect(-bw/2,-CFG.SAFE_RADIUS-14,bw*sfPct,7);
        // Label
        ctx.font='bold 10px "Share Tech Mono"';ctx.textAlign='center';
        ctx.fillStyle=sfCol;ctx.fillText(isAllySafe?'YOUR SAFE':'ENEMY SAFE',0,-CFG.SAFE_RADIUS-18);
        ctx.fillStyle='rgba(255,255,255,0.6)';
        ctx.font='9px "Share Tech Mono"';
        ctx.fillText(sf.hp+' HP',0,CFG.SAFE_RADIUS+16);
        ctx.restore();
      }
    }
    Particles.draw(ctx);
    // Ammo pickup dots
    for(var api=0;api<GS.ammoPickups.length;api++){
      var apc=GS.ammoPickups[api];
      if(!apc) continue;
      var glow=0.55+0.45*Math.sin(apc.pulse);
      var outerR=7+2*Math.sin(apc.pulse*0.7);
      ctx.save();
      ctx.translate(apc.x,apc.y);
      // Outer glow
      var ag=ctx.createRadialGradient(0,0,0,0,0,outerR*2.5);
      ag.addColorStop(0,'rgba(255,210,0,'+glow*0.6+')');
      ag.addColorStop(1,'rgba(255,180,0,0)');
      ctx.fillStyle=ag;
      ctx.beginPath();ctx.arc(0,0,outerR*2.5,0,Math.PI*2);ctx.fill();
      // Core dot
      ctx.shadowColor='rgba(255,220,0,0.9)';ctx.shadowBlur=10;
      ctx.fillStyle='rgba(255,220,60,'+glow+')';
      ctx.beginPath();ctx.arc(0,0,outerR,0,Math.PI*2);ctx.fill();
      // Inner bright core
      ctx.shadowBlur=0;
      ctx.fillStyle='rgba(255,255,200,0.9)';
      ctx.beginPath();ctx.arc(0,0,3,0,Math.PI*2);ctx.fill();
      ctx.restore();
    }
    // Bullets
    for(const b of GS.bullets){
      const bs=COSMETICS.bulletStyle[b.bulletStyle]??COSMETICS.bulletStyle.default;
      ctx.save();ctx.translate(b.x,b.y);ctx.rotate(Math.atan2(b.vy,b.vx));
      const g=ctx.createRadialGradient(0,0,0,0,0,9);g.addColorStop(0,bs.glow);g.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=g;ctx.beginPath();ctx.arc(0,0,9,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#fff';ctx.beginPath();ctx.ellipse(0,0,bs.radius*2,bs.radius*.7,0,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=bs.color;ctx.beginPath();ctx.arc(0,0,bs.radius,0,Math.PI*2);ctx.fill();
      ctx.restore();
    }
    // Bots
    for(const bot of GS.bots){if(!bot.alive)continue;this.drawShip(ctx,bot,false);}
    // Player
    if(p.alive) this.drawShip(ctx,p,true);
    else if(deathLingerTimer>0){ctx.save();ctx.globalAlpha=0.3;this.drawShip(ctx,{...p,invuln:false},true);ctx.restore();}
    ctx.restore();
    // Crosshair
    if(p.alive){const mx=Input.mouseX,my=Input.mouseY;ctx.save();ctx.strokeStyle='rgba(0,212,255,0.6)';ctx.lineWidth=1;ctx.beginPath();ctx.arc(mx,my,7,0,Math.PI*2);ctx.stroke();ctx.beginPath();ctx.moveTo(mx-12,my);ctx.lineTo(mx-8,my);ctx.stroke();ctx.beginPath();ctx.moveTo(mx+8,my);ctx.lineTo(mx+12,my);ctx.stroke();ctx.beginPath();ctx.moveTo(mx,my-12);ctx.lineTo(mx,my-8);ctx.stroke();ctx.beginPath();ctx.moveTo(mx,my+8);ctx.lineTo(mx,my+12);ctx.stroke();ctx.restore();}
    // Low-HP danger vignette (takeover) OR anchor vignette (other modes)
    var showVignette=false,vigAlpha=0;
    if(gameMode==='takeover'&&p&&p.alive){
      var hpFrac=p.hp/p.maxHp;
      if(hpFrac<0.35){
        showVignette=true;
        // Pulse: stronger as HP drops, flicker effect
        vigAlpha=0.08+(0.35-hpFrac)*0.5*(0.7+0.3*Math.sin(performance.now()/140));
      }
    } else if(GS.borderAnchored){
      showVignette=true; vigAlpha=0.18;
    }
    if(showVignette){
      ctx.save();
      var a='rgba(255,40,70,'+vigAlpha+')';
      var a0='rgba(255,40,70,0)';
      var gV2=ctx.createLinearGradient(0,0,0,H);
      gV2.addColorStop(0,a);gV2.addColorStop(0.12,a0);gV2.addColorStop(0.88,a0);gV2.addColorStop(1,a);
      ctx.fillStyle=gV2;ctx.fillRect(0,0,W,H);
      var gH2=ctx.createLinearGradient(0,0,W,0);
      gH2.addColorStop(0,a);gH2.addColorStop(0.08,a0);gH2.addColorStop(0.92,a0);gH2.addColorStop(1,a);
      ctx.fillStyle=gH2;ctx.fillRect(0,0,W,H);
      ctx.restore();
    }
    document.getElementById('coords').textContent=`${Math.round(p.x)} , ${Math.round(p.y)}`;
  },

  getSkin(ship){
    if(ship.isPlayer) return COSMETICS.playerSkin;
    if(ship.team===0) return COSMETICS.allySkin;
    if(ship.team===1) return COSMETICS.enemySkin;
    return COSMETICS.neutralSkin;
  },

  drawShip(ctx,p,isMe){
    const R=CFG.PLAYER_RADIUS,skin=this.getSkin(p);
    ctx.save();ctx.translate(p.x,p.y);
    if(p.invuln) ctx.globalAlpha=.45+.55*Math.abs(Math.sin(performance.now()/130));
    ctx.rotate(p.angle);
    const thrusting=isMe?Input.keys.up:p._thrusting;
    if(thrusting){const fl=R*(1.0+Math.random()*.5),eg=ctx.createRadialGradient(-fl,0,0,-fl,0,R*1.8);eg.addColorStop(0,'rgba(60,200,255,0.65)');eg.addColorStop(1,'rgba(0,0,0,0)');ctx.fillStyle=eg;ctx.beginPath();ctx.arc(-fl*.7,0,R*1.8,0,Math.PI*2);ctx.fill();}
    ctx.shadowColor=skin.body;ctx.shadowBlur=isMe?14:9;
    ctx.strokeStyle=skin.body;ctx.fillStyle=skin.fill;ctx.lineWidth=isMe?2:1.5;
    ctx.beginPath();ctx.moveTo(R,0);ctx.lineTo(R*.55,R*.12);ctx.lineTo(-R*.25,R*.15);ctx.lineTo(-R*.55,R*.12);ctx.lineTo(-R*.65,0);ctx.lineTo(-R*.55,-R*.12);ctx.lineTo(-R*.25,-R*.15);ctx.lineTo(R*.55,-R*.12);ctx.closePath();ctx.fill();ctx.stroke();
    ctx.beginPath();ctx.moveTo(R*.4,R*.12);ctx.lineTo(0,R*.85);ctx.lineTo(-R*.35,R*.75);ctx.lineTo(-R*.5,R*.18);ctx.lineTo(-R*.2,R*.15);ctx.closePath();ctx.fill();ctx.stroke();
    ctx.beginPath();ctx.moveTo(R*.4,-R*.12);ctx.lineTo(0,-R*.85);ctx.lineTo(-R*.35,-R*.75);ctx.lineTo(-R*.5,-R*.18);ctx.lineTo(-R*.2,-R*.15);ctx.closePath();ctx.fill();ctx.stroke();
    for(const sy of[R*.52,-R*.52]){ctx.lineWidth=isMe?1.5:1;ctx.beginPath();ctx.moveTo(-R*.15,sy*.25);ctx.lineTo(-R*.38,sy);ctx.stroke();ctx.fillStyle=skin.fill;ctx.beginPath();ctx.ellipse(-R*.38,sy,R*.2,R*.1,0,0,Math.PI*2);ctx.fill();ctx.stroke();}
    ctx.shadowBlur=0;ctx.fillStyle=skin.cockpit;ctx.lineWidth=1;ctx.beginPath();ctx.ellipse(R*.35,0,R*.22,R*.1,0,0,Math.PI*2);ctx.fill();ctx.stroke();
    ctx.rotate(-p.angle);ctx.shadowBlur=0;
    // HP bar
    const hf=Math.max(0,p.hp)/p.maxHp,bw=R*3.2;
    ctx.fillStyle='rgba(0,0,0,0.55)';ctx.fillRect(-bw/2,R*1.7,bw,6);
    ctx.fillStyle=hf>.5?'#00ff88':hf>.25?'#ffcc00':'#ff4060';ctx.fillRect(-bw/2,R*1.7,bw*Math.min(1,hf),6);
    if(Settings.showNames){ctx.font=`${isMe?'bold ':''}11px "Share Tech Mono"`;ctx.textAlign='center';ctx.fillStyle=isMe?'rgba(0,212,255,0.95)':skin.body+'cc';ctx.fillText(p.username,0,R*1.7+18);}
    if(isMe&&p.borderAnchored&&gameMode!=='takeover'){ctx.fillStyle='rgba(255,64,96,0.85)';ctx.font='9px "Share Tech Mono"';ctx.fillText('[ANCHORED]',0,R*1.7+30);}
    ctx.restore();
  },
};

// ─── UI ──────────────────────────────────────────────────────────────────────
const USERNAME_RE=/^[a-zA-Z0-9_]{3,20}$/;
const UI={
  setStatus(msg,cls=''){const el=document.getElementById('enter-status');el.textContent=msg;el.className='status-line '+cls;},
  validateName(showAlert){
    const v=document.getElementById('username-input').value.trim();
    const h=document.getElementById('name-hint');
    const i=document.getElementById('username-input');
    const statusEl=document.getElementById('enter-status');
    if(!v||v.length<3){
      h.textContent='Min 3 characters required';h.className='field-hint err';
      i.classList.add('invalid');
      if(showAlert){
        statusEl.textContent='You need at least 3 characters in your name!';
        statusEl.style.color='#ff4060';statusEl.style.fontWeight='bold';
        i.focus();
        // Shake the input
        i.style.transition='transform 0.08s';
        var shakes=0;
