const NAMES_POOL=['Vega','Drax','Orion','Lyra','Siris','Nova','Cygnus','Pulsar','Quasar','Zenith','Altair','Rigel','Deneb','Spica','Mizar','Corvus','Hades','Lycon','Tanis','Pyrex','Solus','Kalix','Vorn','Trex','Aeon','Brix','Cael','Dusk','Eryx','Flux','Gale','Haze','Iris','Jett','Kova','Nex','Pyre','Rook','Sola','Typh'];
let usedNames=new Set();
function pickName(){ const av=NAMES_POOL.filter(n=>!usedNames.has(n)); if(!av.length){usedNames.clear();return NAMES_POOL[Math.floor(Math.random()*NAMES_POOL.length)];} const n=av[Math.floor(Math.random()*av.length)];usedNames.add(n);return n; }

function randPos(margin){ margin=margin||200; return {x:margin+Math.random()*(CFG.MAP_SIZE-margin*2),y:margin+Math.random()*(CFG.MAP_SIZE-margin*2)}; }
function angleDiff(a,b){let d=((b-a+Math.PI)%(Math.PI*2))-Math.PI;if(d<-Math.PI)d+=Math.PI*2;return d;}

// ─── SHIP DESIGNS BY LEVEL ────────────────────────────────────────────────────
// Helper to stroke a sharp glowing edge line
function _edge(ctx,body,x1,y1,x2,y2,w=1.2){ctx.strokeStyle=body;ctx.lineWidth=w;ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();}

function drawShipDesign(ctx, level, skin, R, angle, animT){
  ctx.save();
  ctx.rotate(angle);
  const fill=skin.fill, body=skin.body, cock=skin.cockpit;
  animT=animT||0;

  if(level===0){
    // ── LV1 SCOUT — needle dart ──────────────────────────────────────────
    ctx.beginPath();
    ctx.moveTo(R*1.1,0);ctx.lineTo(R*.0,R*.35);ctx.lineTo(-R*.5,R*.28);
    ctx.lineTo(-R*.6,0);ctx.lineTo(-R*.5,-R*.28);ctx.lineTo(R*.0,-R*.35);
    ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.4;ctx.stroke();
    // spine
    _edge(ctx,body,R*1.1,0,-R*.6,0,0.8);
    ctx.beginPath();ctx.arc(R*.3,0,R*.14,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===1){
    // ── LV2 FIGHTER — delta with swept fins ──────────────────────────────
    // Central body
    ctx.beginPath();
    ctx.moveTo(R*1.15,0);ctx.lineTo(R*.1,R*.22);ctx.lineTo(-R*.55,R*.18);
    ctx.lineTo(-R*.65,0);ctx.lineTo(-R*.55,-R*.18);ctx.lineTo(R*.1,-R*.22);
    ctx.closePath();ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.stroke();
    // Swept wing panels
    ctx.beginPath();ctx.moveTo(R*.3,R*.22);ctx.lineTo(-R*.35,R*.9);ctx.lineTo(-R*.6,R*.55);ctx.lineTo(-R*.3,R*.18);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.2;ctx.stroke();
    ctx.beginPath();ctx.moveTo(R*.3,-R*.22);ctx.lineTo(-R*.35,-R*.9);ctx.lineTo(-R*.6,-R*.55);ctx.lineTo(-R*.3,-R*.18);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.2;ctx.stroke();
    // Wing tips — sharp spikes
    _edge(ctx,body,-R*.35,R*.9,-R*.5,R*1.05,1.8);
    _edge(ctx,body,-R*.35,-R*.9,-R*.5,-R*1.05,1.8);
    ctx.beginPath();ctx.arc(R*.35,0,R*.18,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===2){
    // ── LV3 DESTROYER — Y-wing style twin boom ───────────────────────────
    // Central fuselage
    ctx.beginPath();ctx.moveTo(R*1.2,0);ctx.lineTo(R*.4,R*.18);ctx.lineTo(-R*.9,R*.22);ctx.lineTo(-R*1.0,0);ctx.lineTo(-R*.9,-R*.22);ctx.lineTo(R*.4,-R*.18);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    // Upper boom
    ctx.beginPath();ctx.moveTo(R*.2,R*.18);ctx.lineTo(R*.3,R*.65);ctx.lineTo(-R*.8,R*.72);ctx.lineTo(-R*.9,R*.52);ctx.lineTo(-R*.85,R*.22);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.stroke();
    // Lower boom
    ctx.beginPath();ctx.moveTo(R*.2,-R*.18);ctx.lineTo(R*.3,-R*.65);ctx.lineTo(-R*.8,-R*.72);ctx.lineTo(-R*.9,-R*.52);ctx.lineTo(-R*.85,-R*.22);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.stroke();
    // Engine nacelles at boom tips
    [[R*.05,R*.68],[-R*.82,R*.62]].forEach(([ex,ey])=>{
      ctx.beginPath();ctx.ellipse(ex,ey,R*.18,R*.08,0.15,0,Math.PI*2);ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1;ctx.stroke();
    });
    [[R*.05,-R*.68],[-R*.82,-R*.62]].forEach(([ex,ey])=>{
      ctx.beginPath();ctx.ellipse(ex,ey,R*.18,R*.08,-0.15,0,Math.PI*2);ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1;ctx.stroke();
    });
    ctx.beginPath();ctx.arc(R*.45,0,R*.2,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===3){
    // ── LV4 INTERCEPTOR — trident / delta arrow ───────────────────────────
    // Main arrowhead
    ctx.beginPath();ctx.moveTo(R*1.3,0);ctx.lineTo(R*.5,R*.28);ctx.lineTo(R*.1,R*.28);ctx.lineTo(-R*.7,R*.18);ctx.lineTo(-R*.85,0);ctx.lineTo(-R*.7,-R*.18);ctx.lineTo(R*.1,-R*.28);ctx.lineTo(R*.5,-R*.28);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    // Trident prong upper
    ctx.beginPath();ctx.moveTo(R*.3,R*.28);ctx.lineTo(R*.55,R*.78);ctx.lineTo(R*.38,R*.88);ctx.lineTo(R*.12,R*.38);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.stroke();
    // Trident prong lower
    ctx.beginPath();ctx.moveTo(R*.3,-R*.28);ctx.lineTo(R*.55,-R*.78);ctx.lineTo(R*.38,-R*.88);ctx.lineTo(R*.12,-R*.38);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.5;ctx.stroke();
    // Prong tips glow
    ctx.shadowColor=body;ctx.shadowBlur=6;
    _edge(ctx,body,R*.55,R*.78,R*.38,R*.88,2.2);
    _edge(ctx,body,R*.55,-R*.78,R*.38,-R*.88,2.2);
    ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(R*.5,0,R*.2,0,Math.PI*2);ctx.fillStyle=cock;ctx.fill();

  } else if(level===4){
    // ── LV5 GUNSHIP — X-wing quad nacelle ────────────────────────────────
    // Body
    ctx.beginPath();ctx.moveTo(R*1.1,0);ctx.lineTo(R*.5,R*.22);ctx.lineTo(-R*.6,R*.3);ctx.lineTo(-R*.85,0);ctx.lineTo(-R*.6,-R*.3);ctx.lineTo(R*.5,-R*.22);ctx.closePath();
    ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=2;ctx.stroke();
    // 4 swept wing struts
    [1,-1].forEach(s=>{
      // outer wing
      ctx.beginPath();ctx.moveTo(R*.2,s*R*.22);ctx.lineTo(R*.4,s*R*.65);ctx.lineTo(-R*.2,s*R*.85);ctx.lineTo(-R*.55,s*R*.65);ctx.lineTo(-R*.55,s*R*.3);ctx.closePath();
      ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle=body;ctx.lineWidth=1.4;ctx.stroke();
