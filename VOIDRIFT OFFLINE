// ─── MODE SELECT ─────────────────────────────────────────────────────────────
function setMode(m){
  gameMode=m;
  ['ffa','br','teams','takeover'].forEach(function(id){
    var el=document.getElementById('mode-'+id);
    if(el) el.classList.toggle('active',m===id);
  });
  // Bot count box only for ffa/br
  document.getElementById('br-config').style.display=(m==='ffa'||m==='br')?'':'none';
  document.getElementById('teams-config').classList.toggle('hidden-cfg',m!=='teams');
  document.getElementById('takeover-config').classList.toggle('hidden-cfg',m!=='takeover');
  var cfgLabel=document.querySelector('#br-config .field-label');
  if(cfgLabel) cfgLabel.textContent=m==='ffa'?'Bot count (respawn enabled)':'Bot count (elimination)';
}

// ─── SETTINGS UI ─────────────────────────────────────────────────────────────
function buildSettingsUI(){
  const list=document.getElementById('keybind-list');list.innerHTML='';let lid=null;
  for(const def of BIND_DEFS){
    const row=document.createElement('div');row.className='keybind-row';
    row.innerHTML=`<span class="keybind-label">${def.label}</span><button class="keybind-btn" data-id="${def.id}">${Binds.label(Binds.map[def.id])}</button>`;
    list.appendChild(row);
  }
  list.addEventListener('click',e=>{
    const btn=e.target.closest('.keybind-btn');if(!btn)return;
    list.querySelectorAll('.keybind-btn.listening').forEach(b=>{b.classList.remove('listening');b.textContent=Binds.label(Binds.map[b.dataset.id]);});
    btn.classList.add('listening');btn.textContent='Press a key...';lid=btn.dataset.id;
  });
  document.addEventListener('keydown',e=>{
    if(!lid)return;
    if(e.key==='Escape'){list.querySelectorAll('.keybind-btn.listening').forEach(b=>{b.classList.remove('listening');b.textContent=Binds.label(Binds.map[b.dataset.id]);});lid=null;return;}
    const conflict=Object.entries(Binds.map).find(([oid,c])=>c===e.code&&oid!==lid);
    if(conflict){Binds.map[conflict[0]]=Binds.map[lid];const cb=list.querySelector(`[data-id="${conflict[0]}"]`);if(cb)cb.textContent=Binds.label(Binds.map[conflict[0]]);}
    Binds.map[lid]=e.code;Binds.save();
    const ab=list.querySelector(`[data-id="${lid}"]`);if(ab){ab.classList.remove('listening');ab.textContent=Binds.label(e.code);}
    lid=null;updateControlsHint();e.preventDefault();
  });
  const tn=document.getElementById('tog-names');tn.checked=Settings.showNames;
  tn.addEventListener('change',()=>{Settings.showNames=tn.checked;Settings.save();});
}
function updateControlsHint(){
  const B=id=>Binds.label(Binds.map[id]);
  document.getElementById('controls-hint-display').innerHTML=
    `<span>${B('thrust')}</span> thrust &nbsp;·&nbsp; <span>${B('brake')}</span> brake &nbsp;·&nbsp; <span>${B('sideLeft')}/${B('sideRight')}</span> strafe &nbsp;·&nbsp; <span>${B('rotLeft')}/${B('rotRight')}</span> rotate<br>`+
    `<span>${B('shoot')}/LMB</span> shoot &nbsp;·&nbsp; <span>RMB</span> thrust &nbsp;·&nbsp; <span>${B('boost')}</span> boost &nbsp;·&nbsp; <span>${B('borderAnchor')}</span> anchor`;
}

// ─── MAIN LOOP ────────────────────────────────────────────────────────────────
function mainLoop(now){
  try{
    Input.updateMouseAngle();
    if(gameRunning&&!GS.over) tickGame(now);
    if(GS.player) Render.draw(now);
  }catch(e){
    console.error('Game loop error:',e);
  }
  requestAnimationFrame(mainLoop);
}

// ─── BOOT ─────────────────────────────────────────────────────────────────────
Input.init();Render.init();buildSettingsUI();updateControlsHint();setMode('ffa');
document.getElementById('mode-ffa').addEventListener('click',function(){setMode('ffa');});
document.getElementById('mode-br').addEventListener('click',function(){setMode('br');});
document.getElementById('mode-teams').addEventListener('click',function(){setMode('teams');});
document.getElementById('mode-takeover').addEventListener('click',function(){setMode('takeover');});

document.getElementById('username-input').addEventListener('input',function(){UI.validateName(false);});
document.getElementById('username-input').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('launch-btn').click();});

document.getElementById('launch-btn').addEventListener('click',()=>{
  if(!UI.validateName(true))return;
  const username=document.getElementById('username-input').value.trim();

  // Read config
  var botCount,allyCount,enemyCount,toAllyCount,toEnemyCount;
  if(gameMode==='ffa'||gameMode==='br'){
    botCount=Math.max(1,Math.min(49,parseInt(document.getElementById('br-bots').value)||24));
  } else if(gameMode==='teams'){
    allyCount=Math.max(0,Math.min(29,parseInt(document.getElementById('t-ally').value)||9));
    enemyCount=Math.max(1,Math.min(30,parseInt(document.getElementById('t-enemy').value)||10));
  } else if(gameMode==='takeover'){
    toAllyCount=Math.max(0,Math.min(29,parseInt(document.getElementById('to-ally').value)||9));
    toEnemyCount=Math.max(1,Math.min(30,parseInt(document.getElementById('to-enemy').value)||10));
    CFG.SAFE_HP=Math.max(100,Math.min(99999,parseInt(document.getElementById('to-safe-hp').value)||4000));
  }

  document.getElementById('launch-btn').disabled=true;

  runConnectionSequence(()=>{
    // Init game state
    usedNames.clear();GS.over=false;GS.score=0;GS.kills=0;GS.deaths=0;GS.borderAnchored=false;GS.bullets=[];GS.ammoPickups=[];deathLingerTimer=0;Particles.pool=[];spawnAmmoPickups();

    if(gameMode==='ffa'||gameMode==='br'){
      GS.player=createPlayer(username,-1);
      GS.bots=Array.from({length:botCount},function(){return createBot(-1);});
      GS.safes=[];
    } else if(gameMode==='teams'){
      GS.player=createPlayer(username,0);
      GS.bots=[].concat(
        Array.from({length:allyCount},function(){return createBot(0);}),
        Array.from({length:enemyCount},function(){return createBot(1);})
      );
      GS.safes=[];
    } else if(gameMode==='takeover'){
      GS.player=createPlayer(username,0,'left');
      GS.bots=[].concat(
        Array.from({length:toAllyCount},function(){return createBot(0,'left');}),
        Array.from({length:toEnemyCount},function(){return createBot(1,'right');})
      );
      // Place safes far apart on opposite sides of the map
      var margin=800;
      GS.safes=[
        {team:0,x:margin,y:CFG.MAP_SIZE/2,hp:CFG.SAFE_HP,maxHp:CFG.SAFE_HP},
        {team:1,x:CFG.MAP_SIZE-margin,y:CFG.MAP_SIZE/2,hp:CFG.SAFE_HP,maxHp:CFG.SAFE_HP}
      ];
    }

    gameRunning=true;lastTickTime=performance.now();
    UI.showGame();
  });
});

document.getElementById('settings-btn').addEventListener('click',()=>document.getElementById('settings-overlay').classList.remove('hidden'));
document.getElementById('settings-close-btn').addEventListener('click',()=>document.getElementById('settings-overlay').classList.add('hidden'));
document.getElementById('settings-overlay').addEventListener('click',e=>{if(e.target===document.getElementById('settings-overlay'))document.getElementById('settings-overlay').classList.add('hidden');});
document.getElementById('esc-resume-btn').addEventListener('click',()=>EscMenu.close());
document.getElementById('esc-quit-btn').addEventListener('click',()=>EscMenu.quit());
document.getElementById('esc-settings-btn').addEventListener('click',()=>{EscMenu.close();document.getElementById('settings-overlay').classList.remove('hidden');});
document.getElementById('end-quit-btn').addEventListener('click',()=>EscMenu.quit());

document.getElementById('respawn-btn').addEventListener('click',()=>{
  if(gameMode!=='ffa'&&gameMode!=='takeover')return; // FFA and takeover allow respawn
  const p=GS.player;if(!p)return;
  var prSide=(gameMode==='takeover')?'left':undefined;
  const rp=randPos(200,prSide);p.x=rp.x;p.y=rp.y;p.vx=0;p.vy=0;
  p.hp=p.maxHp;p.alive=true;p.invuln=CFG.RESPAWN_INVULN;
  p.ammo=CFG.AMMO_MAX;
  p.boostFuel=CFG.BOOST_MAX;p.boostRechargeTimer=0;
  p.borderAnchored=false;p.lastDamageTime=-999;GS.borderAnchored=false;
  deathLingerTimer=0;gameRunning=true;
  document.getElementById('respawn-screen').classList.add('hidden');
});
document.getElementById('respawn-quit-btn').addEventListener('click',()=>EscMenu.quit());

requestAnimationFrame(mainLoop);
</script>
