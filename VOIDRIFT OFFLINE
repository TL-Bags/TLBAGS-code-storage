<script>
// ══════════════════════════════════════════════════════════════════════════════
// VOIDRIFT — OFFLINE EDITION  v2
// FFA + Battle Royale + Teams mode, AI bots, connection sequence
// ══════════════════════════════════════════════════════════════════════════════

// ─── SYSTEM NAMES ARRAY ───────────────────────────────────────────────────────
// system array here
const SYSTEMS = [
  'UTIPA', 'XYLAR', 'NOVAN', 'DREVOS', 'KETHON', 'ZIRAEL',
  'PROSYN', 'VELUUN', 'AXTROS', 'CALYPH', 'OREMIS', 'THALVEX',
];

// ─── GAME CONFIG (edit these values freely) ──────────────────────────────────
const CFG = {
  MAP_SIZE:             3000,
  PLAYER_SPEED:         340,
  SIDE_THRUST_SPEED:    80,
  BORDER_ANCHOR_PENALTY:0.10,
  PLAYER_RADIUS:        27,
  BULLET_SPEED:         820,
  BULLET_LIFETIME:      3.5,
  BULLET_DAMAGE:        10,
  PLAYER_MAX_HP:        100,
  SHOOT_COOLDOWN:       0.25,
  RESPAWN_INVULN:       3.0,
  REGEN_RATE:           2,
  REGEN_DELAY:          10,
  BOOST_MAX:            100,
  BOOST_DRAIN:          20,
  BOOST_RECHARGE:       4,
  BOOST_SPEED_MULT:     2.2,
  BOOST_RECHARGE_DELAY: 1.0,
  ENEMY_RESPAWN_TIME:   5,    // FFA mode only — bots respawn; 0 = no respawn
  PLAYER_FOCUS_WEIGHT:  0.4,  // 0–1: how much bots prefer targeting the player vs others
  AMMO_MAX:             100,  // starting ammo (each shot = 1 ammo)
  AMMO_PER_PICKUP:      10,   // ammo restored per pickup dot
  AMMO_PICKUP_COUNT:    20,   // number of ammo dots on map at once
  AMMO_PICKUP_RADIUS:   18,   // pickup collection radius
  SAFE_HP:              4000, // Takeover: safe starting health (modifiable)
  SAFE_RADIUS:          40,   // collision radius of the safe
  SAFE_RESPAWN_DELAY:   4,    // respawn delay in takeover mode
};

// ─── KEY BINDINGS ────────────────────────────────────────────────────────────
const BIND_DEFS = [
  {id:'thrust',       label:'Thrust Forward',      def:'KeyW'},
  {id:'brake',        label:'Brake',               def:'KeyS'},
  {id:'sideLeft',     label:'Strafe Left',         def:'KeyA'},
  {id:'sideRight',    label:'Strafe Right',        def:'KeyD'},
  {id:'rotLeft',      label:'Rotate Left',         def:'ArrowLeft'},
  {id:'rotRight',     label:'Rotate Right',        def:'ArrowRight'},
  {id:'shoot',        label:'Shoot',               def:'Space'},
  {id:'boost',        label:'Boost',               def:'ShiftLeft'},
  {id:'borderAnchor', label:'Border Anchor Toggle', def:'KeyX'},
  {id:'escMenu',      label:'Pause Menu',          def:'Escape'},
];
const Binds = {
  map:{},
  load(){ const sv=JSON.parse(localStorage.getItem('vr_binds')||'{}'); for(const d of BIND_DEFS) this.map[d.id]=sv[d.id]||d.def; },
  save(){ localStorage.setItem('vr_binds',JSON.stringify(this.map)); },
  idFor(code){ for(const[id,c]of Object.entries(this.map))if(c===code)return id; return null; },
  label(code){ return code.replace('Key','').replace('ArrowLeft','←').replace('ArrowRight','→').replace('ArrowUp','↑').replace('ArrowDown','↓').replace('Space','SPACE').replace('Shift','SHIFT').replace('Left','').replace('Right',''); },
};
Binds.load();

const Settings = {
  showNames:true,
  load(){ const s=JSON.parse(localStorage.getItem('vr_settings')||'{}'); this.showNames=s.showNames??true; },
  save(){ localStorage.setItem('vr_settings',JSON.stringify({showNames:this.showNames})); },
};
Settings.load();

// ─── COSMETICS ────────────────────────────────────────────────────────────────
const COSMETICS = {
  bulletStyle:{ default:{color:'#00d4ff',glow:'rgba(0,212,255,0.9)',radius:3} },
  playerSkin:{ body:'#00d4ff', fill:'rgba(0,212,255,0.13)', cockpit:'rgba(180,240,255,0.45)' },
  allySkin:  { body:'#00ff88', fill:'rgba(0,255,136,0.12)', cockpit:'rgba(180,255,200,0.4)' },
  enemySkin: { body:'#ff4060', fill:'rgba(255,64,96,0.13)', cockpit:'rgba(255,180,180,0.35)' },
  neutralSkin:{ body:'#bb88ff', fill:'rgba(180,136,255,0.12)', cockpit:'rgba(220,200,255,0.35)' },
};

// ─── PARTICLES ───────────────────────────────────────────────────────────────
const Particles = {
  pool:[],
  spawn(x,y,vx,vy,color,size,life){ this.pool.push({x,y,vx,vy,color,size,life,maxLife:life}); },
  tick(dt){ this.pool=this.pool.filter(p=>{p.life-=dt;p.x+=p.vx*dt;p.y+=p.vy*dt;p.vx*=.91;p.vy*=.91;return p.life>0;}); },
  draw(ctx){ for(const p of this.pool){ctx.globalAlpha=Math.max(0,p.life/p.maxLife);ctx.fillStyle=p.color;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();}ctx.globalAlpha=1; },
  emitThrust(ship,boosting=false){
    const R=CFG.PLAYER_RADIUS,ba=ship.angle+Math.PI,cnt=boosting?6:3;
    for(let i=0;i<cnt;i++){
      const a=ba+(Math.random()-.5)*(boosting?.7:.45),sp=(boosting?120:55)+Math.random()*85;
      const col=boosting?`hsl(${40+Math.random()*30},100%,${60+Math.random()*20}%)`:`hsl(${185+Math.random()*30},100%,${58+Math.random()*22}%)`;
      this.spawn(ship.x+Math.cos(ba)*R*.45,ship.y+Math.sin(ba)*R*.45,Math.cos(a)*sp+ship.vx*.25,Math.sin(a)*sp+ship.vy*.25,col,boosting?2.8:1.8+Math.random()*1.8,.3+Math.random()*.15);
    }
  },
  emitSide(ship,dir){
    const R=CFG.PLAYER_RADIUS,oa=ship.angle+Math.PI/2*dir+Math.PI;
    for(let i=0;i<2;i++){const sp=35+Math.random()*50;this.spawn(ship.x+Math.cos(oa)*R*.55,ship.y+Math.sin(oa)*R*.55,Math.cos(oa+(Math.random()-.5)*.55)*sp,Math.sin(oa+(Math.random()-.5)*.55)*sp,'rgba(0,200,255,0.75)',1.4+Math.random()*1.3,.16+Math.random()*.1);}
  },
  emitHitSparks(x,y,bulletStyle){
    const st=COSMETICS.bulletStyle[bulletStyle]??COSMETICS.bulletStyle.default;
    for(let i=0;i<10;i++){const a=Math.random()*Math.PI*2,sp=80+Math.random()*160;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,st.color,1.2+Math.random()*1.5,.18+Math.random()*.18);}
    this.spawn(x,y,0,0,'rgba(255,255,255,0.9)',4,.08);
  },
  emitAmmoPickup(x,y){
    for(var i=0;i<8;i++){
      var a=Math.random()*Math.PI*2,sp=40+Math.random()*80;
      this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,'rgba(255,220,0,0.9)',1.5+Math.random()*1.5,.25+Math.random()*.2);
    }
    this.spawn(x,y,0,0,'rgba(255,255,180,0.95)',5,.1);
  },
  emitExplosion(x,y){
    for(let i=0;i<20;i++){const a=Math.random()*Math.PI*2,sp=120+Math.random()*220;const h=Math.random()<.5?`hsl(${20+Math.random()*30},100%,60%)`:`hsl(${185+Math.random()*30},100%,65%)`;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,h,2.5+Math.random()*2.5,.5+Math.random()*.4);}
    for(let i=0;i<30;i++){const a=Math.random()*Math.PI*2,sp=30+Math.random()*90;this.spawn(x,y,Math.cos(a)*sp,Math.sin(a)*sp,'rgba(255,220,100,0.9)',1+Math.random()*2,.8+Math.random()*.6);}
    this.spawn(x,y,0,0,'rgba(255,255,255,1)',18,.12);
    this.spawn(x,y,0,0,'rgba(255,180,60,0.8)',12,.22);
  },
};

//fullscreen alert thingy
function checkFullscreen() {
  alert("VOIDRIFT is best played in Fullscreen.");
}
