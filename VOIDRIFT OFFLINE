    } else {
      // Level 7 placeholder — shown when reaching lv7 but before omega pick
      // Same as dreadnought but with purple glow
      ctx.beginPath();ctx.moveTo(R*1.5,0);ctx.lineTo(R*.8,R*.5);ctx.lineTo(-R*.2,R*1.0);ctx.lineTo(-R*1.0,R*.7);ctx.lineTo(-R*1.3,0);ctx.lineTo(-R*1.0,-R*.7);ctx.lineTo(-R*.2,-R*1.0);ctx.lineTo(R*.8,-R*.5);ctx.closePath();
      ctx.fillStyle=fill;ctx.fill();ctx.strokeStyle='rgba(180,80,255,0.9)';ctx.lineWidth=2.5;ctx.stroke();
