document.getElementById('respawn-btn').addEventListener('click',()=>{
  if(GS.lives<=0){EscMenu.quit();return;}
  const p=GS.player;if(!p)return;
  const rp=randPos(300);p.x=rp.x;p.y=rp.y;p.vx=0;p.vy=0;
  p.hp=p.maxHp;p.alive=true;p.invuln=CFG.RESPAWN_INVULN;
  p.ammo=CFG.AMMO_MAX;p.boostFuel=CFG.BOOST_MAX;p.boostRechargeTimer=0;
  p.lastDamageTime=-999;GS.borderCrossTimer=0;
  deathLingerTimer=0;gameRunning=true;  document.getElementById('respawn-screen').classList.add('hidden');
});
document.getElementById('respawn-quit-btn').addEventListener('click',()=>EscMenu.quit());


// ─── DEV PIN ─────────────────────────────────────────────────────────────────
(function(){
  const btn=document.getElementById('dev-pin-btn');
  const inp=document.getElementById('dev-pin-input');
  const st=document.getElementById('dev-pin-status');
  if(!btn||!inp) return;
  function tryPin(){
    if(inp.value==='sussyballz123'){
      devMode=true;
      st.textContent='GRANTED';st.style.color='#00ff88';
      document.getElementById('dev-pin-panel').style.borderColor='rgba(0,255,136,0.35)';
      document.getElementById('dev-pin-panel').style.background='rgba(0,255,136,0.04)';
    } else {
      st.textContent='DENIED';st.style.color='#ff4060';
      setTimeout(()=>{st.textContent='';},2000);
    }
    inp.value='';
  }
  btn.addEventListener('click',tryPin);
  inp.addEventListener('keydown',e=>{if(e.key==='Enter')tryPin();});
})();

